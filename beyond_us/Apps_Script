function adminGetRaffleAttendance() {
  syncDefaultRaffleExcludedUsers_();
  const userSheet = getUsersSheet_();
  const userCol = getUserColumns_(userSheet);
  const usersRows = getUserRows_(userSheet);
  const attendanceSheet = getOrCreateRetreatAttendanceSheet();
  const attendanceCol = getRetreatAttendanceColumns_(attendanceSheet);
  const attendanceMap = getRetreatAttendanceMapFromRows_(getRetreatAttendanceRows_(attendanceSheet), attendanceCol);
  const raffleSummary = getActiveRaffleTicketSummary_(getRaffleTicketRows_());

  const users = usersRows
    .filter(function(row) { return String(row[userCol.nickname] || '').trim(); })
    .map(function(row) {
      const nickname = String(row[userCol.nickname] || '').trim();
      const attended = attendanceMap[nickname] === true;
      const raffleExcluded = getUserRaffleExcludedFromRow_(row, userCol);
      return {
        parish: String(row[userCol.parish] || '').trim(),
        name: String(row[userCol.name] || '').trim(),
        nickname: nickname,
        attended: attended,
        raffleExcluded: raffleExcluded,
        raffleTickets: raffleSummary.byUser[nickname] || 0,
      };
    })
    .sort(function(a, b) {
      return String(a.parish).localeCompare(String(b.parish), 'ko') ||
        String(a.name).localeCompare(String(b.name), 'ko') ||
        String(a.nickname).localeCompare(String(b.nickname), 'ko');
    });

  return {
    ok: true,
    users: users,
    totalUsers: users.length,
    attendedCount: users.filter(function(user) { return user.attended === true; }).length,
    raffleExcludedCount: users.filter(function(user) { return user.raffleExcluded === true; }).length,
  };
}

