function getOrCreateTradesSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.TRADES);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_NAMES.TRADES);
    sheet.appendRow(getSchemaHeaders_(SCHEMA.TRADES));
  } else {
    const header = sheet.getRange(1, 1, 1, Math.max(sheet.getLastColumn(), 12)).getValues()[0];
    const col = getTradesColumns_(sheet);
    if (
      String(header[col.requesterPrayed] || '') !== SCHEMA.TRADES.columns.requesterPrayed ||
      String(header[col.targetPrayed] || '') !== SCHEMA.TRADES.columns.targetPrayed
    ) {
      sheet.getRange(SCHEMA.TRADES.headerRow, 1, 1, 12).setValues([getSchemaHeaders_(SCHEMA.TRADES)]);
    }
  }
  return sheet;
}

function requestTrade(body) {
  const requester       = String(body.nickname       || '').trim();
  const requesterCardId = Number(body.requesterCardId);
  const target          = String(body.targetNickname  || '').trim();
  const targetCardId    = Number(body.targetCardId);

  if (!requester || !target || !requesterCardId || !targetCardId)
    return { error: '필수 항목이 누락됐어요.' };
  if (requester === target)
    return { error: '자기 자신과 교환할 수 없어요.' };
  if (requesterCardId === 10 || targetCardId === 10)
    return { error: '히든 카드는 교환할 수 없어요.' };

  const reqCard = SPIRIT_CARDS.find(c => c.id === requesterCardId);
  const tgtCard = SPIRIT_CARDS.find(c => c.id === targetCardId);
  if (!reqCard || !tgtCard) return { error: '유효하지 않은 카드예요.' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
  // 보유 확인
  const reqColl = getUserCollection(requester);
  if (!(reqColl[requesterCardId] >= 2)) return { error: '중복 보유한 카드(2장 이상)만 교환할 수 있어요.' };
  const tgtColl = getUserCollection(target);
  if (!(tgtColl[targetCardId] >= 2)) return { error: '상대방이 해당 카드를 중복 보유하고 있지 않아요.' };

  const createdAt = new Date().toISOString();
  const id = String(new Date().getTime());
  getOrCreateTradesSheet().appendRow([
    id, requester, requesterCardId, reqCard.name,
    target, targetCardId, tgtCard.name,
    'pending', createdAt, ''
  ]);
  Events_append_(EVENT_TYPES.TRADE_REQUESTED, requester, {
    timestamp: createdAt,
    refId: id,
    payload: {
      target: target,
      requesterCardId: requesterCardId,
      requesterCardName: reqCard.name,
      targetCardId: targetCardId,
      targetCardName: tgtCard.name,
    },
    source: EVENT_SOURCES.WEB,
  });
  return { ok: true, tradeId: id };
  } finally {
    lock.releaseLock();
  }
}

function acceptTrade(body) {
  const tradeId  = String(body.tradeId   || '');
  const nickname = String(body.nickname  || '').trim();
  if (!tradeId || !nickname) return { error: '필수 항목이 누락됐어요.' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
  const sheet = getOrCreateTradesSheet();
  const last  = sheet.getLastRow();
  if (last < SCHEMA.TRADES.dataStartRow) return { error: 'not_found' };
  const col = getTradesColumns_(sheet);

  _expireOldTrades(sheet);
  const rows = getTradesRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    const rowIndex = i + SCHEMA.TRADES.dataStartRow;
    if (String(rows[i][col.id]) !== tradeId) continue;
    if (String(rows[i][col.target]) !== nickname) return { error: 'unauthorized' };
    if (String(rows[i][col.status]) !== 'pending') return { error: '이미 처리된 요청이에요.' };

    const requester       = String(rows[i][col.requester]);
    const requesterCardId = Number(rows[i][col.requesterCardId]);
    const targetCardId    = Number(rows[i][col.targetCardId]);
    // status, createdAt, resolvedAt이 sheet 컬럼 H/I/J (인접)이므로
    // setValue 2회 → setValues 1회로 묶기. createdAt은 기존값 그대로 보존.
    const tradeRowSpan = col.resolvedAt - col.status + 1;
    const writeTradeResolution = function(status, resolvedAt) {
      sheet.getRange(rowIndex, col.status + 1, 1, tradeRowSpan).setValues([
        [status, rows[i][col.createdAt], resolvedAt],
      ]);
    };

    // 카드 보유 재확인
    if (!(getUserCollection(requester)[requesterCardId] >= 2)) {
      writeTradeResolution('실패 (카드 없음)', new Date().toISOString());
      return { error: '상대방이 더 이상 해당 카드를 중복 보유하지 않아요.' };
    }
    if (!(getUserCollection(nickname)[targetCardId] >= 2)) {
      writeTradeResolution('실패 (카드 없음)', new Date().toISOString());
      return { error: '내가 더 이상 해당 카드를 중복 보유하지 않아요.' };
    }

    const resolvedAt = new Date().toISOString();
    writeTradeResolution('accepted', resolvedAt);
    Events_append_(EVENT_TYPES.TRADE_ACCEPTED, requester, {
      timestamp: resolvedAt,
      refId: tradeId,
      payload: {
        status: 'accepted',
        target: nickname,
      },
      source: EVENT_SOURCES.WEB,
    });
    // 양쪽 사용자 rebuild에 공유할 events 1회 읽기 — 전체 Events 스캔 2회 → 1회
    const sharedEvents = Events_readAll_();
    rebuildCollectionRow_(requester, sharedEvents);
    rebuildCollectionRow_(nickname, sharedEvents);
    return { ok: true };
  }
  return { error: 'not_found' };
  } finally {
    lock.releaseLock();
  }
}

function rejectTrade(body) {
