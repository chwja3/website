    sheet = ss.insertSheet(SHEET_NAMES.BBB_PHOTOS);
    sheet.appendRow(getSchemaHeaders_(SCHEMA.BBB_PHOTOS));
    sheet.setFrozenRows(1);
  } else {
    const header = sheet.getRange(1, 1, 1, Math.max(sheet.getLastColumn(), 4)).getValues()[0];
    const col = getBbbPhotoColumns_(sheet);
