  for (var r = 0; r < data.length; r++) {
    var name   = data[r][col.name];
    var parish = data[r][col.parish];
    var prayer = data[r][col.content];
    for (var f = 0; f < fixes.length; f++) {
      if (name === fixes[f][0] && parish === fixes[f][1] && prayer.indexOf(fixes[f][2]) !== -1) {
        var newPrayer = prayer.replace(fixes[f][2], fixes[f][3]);
        sheet.getRange(r + SCHEMA.HOLD_PRAY.dataStartRow, col.content + 1).setValue(newPrayer);
        Logger.log('수정: ' + name + ' [' + fixes[f][2] + '] → [' + fixes[f][3] + ']');
        fixed++;
      }
    }
  }

  Logger.log('총 ' + fixed + '건 수정 완료');
}

// ── 공통 ─────────────────────────────────────────
function jsonOutput(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}
