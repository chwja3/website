function phase2EHealthCheck_(options) {
  const opts = options || {};
  const started = new Date().getTime();
  const inputs = getCollectionProjectionInputs_();
  const userIds = getCollectionProjectionCandidateUserIds_(inputs.events, inputs);
  const comparisons = userIds.map(function(userId) {
    return compareCollectionProjectionForUser_(userId, inputs.events, inputs);
  });
  const mismatches = comparisons.filter(function(item) { return item.diffs.length > 0; });
  const performance = phase2EMeasurePerformance_(opts);
  const legacySheets = getLegacySheetVisibilityStatus_();
  return {
    ok: mismatches.length === 0 &&
      performance.ok === true &&
      (opts.allowVisibleLegacySheets === true || legacySheets.every(function(item) { return !item.exists || item.hidden; })),
    sheetsApiV4Available: isSheetsValuesApiAvailable_(),
    legacySheets: legacySheets,
    projection: {
      checked: comparisons.length,
      mismatchCount: mismatches.length,
      mismatches: mismatches.slice(0, 20),
    },
    performance: performance,
    elapsedMs: new Date().getTime() - started,
  };
}

function phase2EMeasurePerformance_(options) {
  const opts = options || {};
  const timings = {};
  const currentWeek = getCurrentWeek_();
  const sampleUserId = String(opts.userId || opts.nickname || getFirstProjectionCandidateUserId_()).trim();
  measurePhase2EStep_(timings, 'getTicketStats', function() { getTicketStats(); });
  measurePhase2EStep_(timings, 'getCardStats', function() { getCardStats(); });
  measurePhase2EStep_(timings, 'getDashboardDataUncached', function() { getDashboardData(); });
  measurePhase2EStep_(timings, 'projectionPreview', function() {
    const inputs = getCollectionProjectionInputs_();
    const userIds = getCollectionProjectionCandidateUserIds_(inputs.events, inputs);
    userIds.slice(0, Math.min(userIds.length, 50)).forEach(function(userId) {
      compareCollectionProjectionForUser_(userId, inputs.events, inputs);
    });
  });
  if (sampleUserId) {
    measurePhase2EStep_(timings, 'getUserStatusSample', function() {
      getUserStatus(sampleUserId, 'w' + currentWeek);
    });
  }
  return {
    ok: Object.keys(timings).every(function(key) { return timings[key].ok; }),
    sampleUserId: sampleUserId,
    timingsMs: timings,
  };
}

