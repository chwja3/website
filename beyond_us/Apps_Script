// CardDraws → Collection 마이그레이션 (rebuildCollectionSheet로 대체됨 — 하위 호환용 유지)
function migrateCardDrawsToCollection() {
  // 데이터 없어도 시트는 항상 생성
  getOrCreateCollectionSheet();
  getOrCreateTradesSheet();

  const draws = getOrCreateDrawSheet();
  const last = draws.getLastRow();
  if (last < 2) return { ok: true, migrated: 0 };

  const rows = draws.getRange(2, 1, last - 1, 5).getValues();
  const userCounts = {};
  for (const row of rows) {
    const uid = String(row[0]);
    const cid = Number(row[2]);
    if (!uid || !cid) continue;
    if (!userCounts[uid]) userCounts[uid] = {};
    userCounts[uid][cid] = (userCounts[uid][cid] || 0) + 1;
  }

  const collSheet = getOrCreateCollectionSheet();
  if (collSheet.getLastRow() > 1) {
    collSheet.getRange(2, 1, collSheet.getLastRow() - 1, 14).clearContent();
  }
  for (const [uid, cards] of Object.entries(userCounts)) {
    const row = new Array(14).fill(0);
    row[0] = uid;
    for (let i = 1; i <= 9; i++) {
      row[i + 3] = cards[i] || 0; // cardId i → col i+4 → idx i+3
    }
    row[13] = Object.values(cards).reduce((s, n) => s + n, 0); // 총카드수
    collSheet.appendRow(row);
  }
  return { ok: true, migrated: Object.keys(userCounts).length };
}

