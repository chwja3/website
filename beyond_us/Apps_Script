    allowVisibleLegacySheets: allowVisibleLegacySheets,
    requiredProperties: props.properties,
    phase2E: phase2E,
    sheets: sheetStatus,
    latestEvent: getLatestEventSummary_(),
    elapsedMs: new Date().getTime() - started,
