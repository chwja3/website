function rebuildCollectionRowsFromEvents_() {
  const inputs = getCollectionProjectionInputs_();
  const events = inputs.events;
  const userIds = getCollectionProjectionCandidateUserIds_(events, inputs);
  const sheet = inputs.collectionSheet;
  const col = inputs.collectionCol;
  const last = sheet.getLastRow();
