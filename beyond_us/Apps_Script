function adminGrantHiddenCard(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const userId = String(body.userId || '').trim();
  if (!userId) return { error: 'missing_userId' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
  const now = new Date().toISOString();
  Events_append_(EVENT_TYPES.CARD_GRANTED, userId, {
    timestamp: now,
    amount: 1,
    refId: 10,
    source: EVENT_SOURCES.ADMIN,
    payload: {
      cardName: '히든',
      reason: 'admin_hidden_grant',
    },
  });
  rebuildCollectionRow_(userId);
  return { ok: true };
  } finally {
    lock.releaseLock();
  }
}

function adminGrantTestCard(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  if (!isTestAdminToolsEnabled_()) return { error: 'test_admin_tools_disabled' };

  const userId = String(body.userId || body.nickname || '').trim();
  const cardId = Number(body.cardId);
  const amount = Math.floor(Number(body.amount) || 1);
  if (!userId) return { error: 'missing_userId' };
  if (!(cardId >= 1 && cardId <= 10)) return { error: 'invalid_cardId' };
  if (!(amount >= 1 && amount <= 20)) return { error: 'invalid_amount' };

  const card = SPIRIT_CARDS.find(function(c) { return c.id === cardId; });
  if (!card) return { error: 'invalid_cardId' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    const now = new Date().toISOString();
    const event = Events_append_(EVENT_TYPES.CARD_GRANTED, userId, {
      timestamp: now,
      amount: amount,
      refId: cardId,
      source: EVENT_SOURCES.ADMIN,
      payload: {
        cardName: card.name,
        reason: 'test_card_grant',
      },
    });
    const rebuild = rebuildCollectionRow_(userId);
    return {
      ok: true,
      userId: userId,
      cardId: cardId,
      amount: amount,
      eventId: event.event.eventId,
      collection: getUserCollection(userId),
      tickets: getCollectionTickets(userId),
      rebuild: {
        ok: rebuild.ok,
        diffCountBeforeWrite: rebuild.diffCountBeforeWrite,
      },
    };
  } finally {
    lock.releaseLock();
  }
}

function adminCreateCardEvent(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  if (!isTestAdminToolsEnabled_()) return { error: 'test_admin_tools_disabled' };

  const eventMode = String(body.eventMode || body.mode || '').trim();
  const userId = String(body.userId || body.nickname || '').trim();
  const cardId = Number(body.cardId);
  const amount = Math.floor(Number(body.amount) || 1);
  if (eventMode !== 'add' && eventMode !== 'remove') return { error: 'invalid_eventMode' };
  if (!userId) return { error: 'missing_userId' };
  if (!(cardId >= 1 && cardId <= 10)) return { error: 'invalid_cardId' };
  if (!(amount >= 1 && amount <= 20)) return { error: 'invalid_amount' };

  const card = SPIRIT_CARDS.find(function(c) { return c.id === cardId; });
  if (!card) return { error: 'invalid_cardId' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    const now = new Date().toISOString();
    const eventType = eventMode === 'remove' ? EVENT_TYPES.CARD_REMOVED : EVENT_TYPES.CARD_GRANTED;
    const reason = String(body.reason || (eventMode === 'remove' ? 'admin_card_remove' : 'admin_card_grant')).trim();
    const event = Events_append_(eventType, userId, {
      timestamp: now,
      amount: amount,
      refId: cardId,
      source: EVENT_SOURCES.ADMIN,
      payload: {
        cardName: card.name,
        reason: reason,
      },
    });
    const rebuild = rebuildCollectionRow_(userId);
    return {
      ok: true,
      eventMode: eventMode,
      eventType: eventType,
      userId: userId,
      cardId: cardId,
      amount: amount,
      eventId: event.event.eventId,
      collection: getUserCollection(userId),
      tickets: getCollectionTickets(userId),
      rebuild: {
        ok: rebuild.ok,
        diffCountBeforeWrite: rebuild.diffCountBeforeWrite,
      },
    };
  } finally {
    lock.releaseLock();
  }
}

function adminRebuildEventDerivedViews(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };

  const rowLimit = Math.max(Number(body.rowLimit) || USER_DASHBOARD_DEFAULT_ROWS, 1);
  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    const collection = rebuildCollectionRowsFromEvents_();
    const dashboard = setupUserDashboard(rowLimit);
    clearDashboardCache_();
    return {
      ok: true,
      collectionRebuilt: collection.rebuilt,
      dashboardRows: dashboard.rowsPrepared,
      collectionSheet: SHEET_NAMES.COLLECTION,
      dashboardSheet: SHEET_NAMES.USER_DASHBOARD,
    };
  } finally {
    lock.releaseLock();
  }
}

