function registerUser(body) {
  const sheet    = getSpreadsheet().getSheetByName('Users');
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const name     = String(body.name     || '').trim();
  const parish   = String(body.parish   || '').trim();

  if (!nickname || !password || !name || !parish) return { error: 'missing_fields' };

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname) return { error: 'duplicate' };
  }

  sheet.appendRow([nickname, '', name, parish, new Date()]);
  const pwCell = sheet.getRange(sheet.getLastRow(), 2);
  pwCell.setNumberFormat('@');
  pwCell.setValue(password);
  return { ok: true };
}

function loginUser(body) {
  const sheet    = getSpreadsheet().getSheetByName('Users');
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname) {
      if (String(data[i][1]).trim() === password) {
        return {
          ok:          true,
          parish:      data[i][3],
          isStaff:     data[i][5] === true,
          appOpenDate: getAppOpenDate()
        };
      }
      return { error: 'wrong_password' };
    }
  }
  return { error: 'not_found' };
}

function resetPassword(body) {
  const sheet       = getSpreadsheet().getSheetByName('Users');
  const nickname    = String(body.nickname    || '').trim();
  const name        = String(body.name        || '').trim();
  const parish      = String(body.parish      || '').trim();
  const newPassword = String(body.newPassword || '').trim();

  if (!newPassword || newPassword.length < 4) return { error: 'invalid_password' };

  const data = sheet.getDataRange().getValues();

  // 닉네임이 명시된 경우: 이름+교구+닉네임 정확히 일치하는 계정 변경
  if (nickname) {
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][0]).trim() === nickname &&
          String(data[i][2]).trim() === name &&
          String(data[i][3]).trim() === parish) {
        const cell = sheet.getRange(i + 1, 2);
        cell.setNumberFormat('@');
        cell.setValue(newPassword);
        return { ok: true };
      }
    }
    return { error: 'not_found' };
  }

  // 닉네임 없이 이름+교구로 검색
  const matches = [];
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][2]).trim() === name &&
        String(data[i][3]).trim() === parish) {
      matches.push({ row: i + 1, nickname: String(data[i][0]).trim() });
    }
  }

  if (matches.length === 0) return { error: 'not_found' };

  // 동명이인: 닉네임 선택 요청
  if (matches.length > 1) {
    return { duplicates: matches.map(m => m.nickname) };
  }

  // 1명: 바로 변경
  const cell = sheet.getRange(matches[0].row, 2);
  cell.setNumberFormat('@');
  cell.setValue(newPassword);
  return { ok: true };
}

function getUsers() {
