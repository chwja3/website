function Events_appendBatch_(items) {
  if (!Array.isArray(items) || !items.length) return { ok: true, events: [] };
  const sheet = getOrCreateEventsSheet();
  const rows = items.map(function(item) {
    return Events_buildRow_(item.type, item.userId, item.options || {});
  });
  const startRow = Math.max(sheet.getLastRow() + 1, SCHEMA.EVENTS.dataStartRow);
  sheet.getRange(startRow, 1, rows.length, EVENTS_COL_COUNT).setValues(rows);
  return {
    ok: true,
    events: rows.map(function(row) { return Events_rowToObject_(row); }),
  };
}

function Events_buildRow_(type, userId, options) {
  const opts = options || {};
  const amount = Object.prototype.hasOwnProperty.call(opts, 'amount') ? opts.amount : '';
  return [
    opts.eventId || Utilities.getUuid(),
    eventTimestampIso_(opts.timestamp, opts.timestampOffsetMs || 0),
    String(userId || '').trim(),
    String(type || '').trim(),
    opts.refId === null || opts.refId === undefined ? '' : String(opts.refId),
    amount === null || amount === undefined ? '' : amount,
    opts.weekKey === null || opts.weekKey === undefined ? '' : String(opts.weekKey),
    eventPayloadJson_(opts.payload),
    opts.source || EVENT_SOURCES.SERVER,
  ];
}

function Events_rowToObject_(row, columns) {
  const col = columns || EVENTS_COLUMN_FALLBACK;
  return {
    eventId: String(row[col.eventId] || ''),
    timestamp: String(row[col.timestamp] || ''),
    userId: String(row[col.userId] || ''),
    type: String(row[col.type] || ''),
    refId: String(row[col.refId] || ''),
    amount: row[col.amount],
    weekKey: String(row[col.weekKey] || ''),
    payload: parseEventPayload_(row[col.payload]),
    source: String(row[col.source] || ''),
  };
}

