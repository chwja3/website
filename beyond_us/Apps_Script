function adminFindRaffleTicket(rawTicketNo) {
  const raw = String(rawTicketNo || '').trim().replace(/[^0-9]/g, '');
  if (!raw) return { ok: false, error: 'missing_ticket_no' };
  const ticketNo = padTicketNo_(raw);
  const rows = getRaffleTicketRows_();
  for (let i = 0; i < rows.length; i++) {
    if (padTicketNo_(rows[i][RAFFLE_TICKET_COL.ticketNo]) === ticketNo) {
      const userId = String(rows[i][RAFFLE_TICKET_COL.userId] || '').trim();
      const status = String(rows[i][RAFFLE_TICKET_COL.status] || '').trim();
      if (!isActiveRaffleTicketRow_(rows[i])) {
        return {
          ok: false,
          error: 'available',
          ticket_no: ticketNo,
          status: status || 'available',
        };
      }
      return {
        ok: true,
        ticket_no: ticketNo,
        userId: userId,
        name: String(rows[i][RAFFLE_TICKET_COL.name] || ''),
        parish: String(rows[i][RAFFLE_TICKET_COL.parish] || '').trim(),
        issued_at: String(rows[i][RAFFLE_TICKET_COL.issuedAt] || ''),
        week_key: String(rows[i][RAFFLE_TICKET_COL.weekKey] || ''),
        condition: String(rows[i][RAFFLE_TICKET_COL.condition] || ''),
        condition_label: String(rows[i][RAFFLE_TICKET_COL.conditionLabel] || ''),
      };
    }
  }
  return { ok: false, error: 'not_found', ticket_no: ticketNo };
}

