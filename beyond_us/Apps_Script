function verifySession(nickname, sessionToken) {
  const cleanToken = String(sessionToken || '').trim();
  if (!String(nickname || '').trim() || !cleanToken) return false;
  try {
    const sheet = getUsersSheet_();
    const rowIndex = findUserRow_(sheet, nickname);
    if (rowIndex < 2) return false;
    const col = getUserColumns_(sheet);
    const rawTokens = sheet.getRange(rowIndex, col.sessionToken + 1).getValue();
    const updatedAt = sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).getValue();
    const tokens = parseTokenArray_(rawTokens);
    if (tokens.indexOf(cleanToken) === -1) return false;

    const updatedMs = updatedAt instanceof Date ? updatedAt.getTime() : new Date(String(updatedAt || '')).getTime();
    if (!isNaN(updatedMs) && Date.now() - updatedMs > SESSION_MAX_AGE_MS) return false;
    return true;
  } catch(e) {
    return false;
  }
}

function requireSessionForUser_(source, userId) {
  const uid = String(userId || '').trim();
  if (!uid) return { error: 'missing_userId' };
  if (!verifySession(uid, source && source.sessionToken)) {
    return { error: 'unauthorized', authRequired: true };
  }
  return null;
}

