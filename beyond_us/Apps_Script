function ensureMissionDefinitionWeekRows_(sheet, week) {
  const col = getMissionDefinitionsColumns_(sheet);
  const existing = getMissionDefinitionRowInfos_(week);
  const byItemNo = {};
  existing.forEach(function(info) {
    const itemNo = Number(info.row[col.itemNo]) || 0;
    if (itemNo >= 1 && itemNo <= CONFIG_LAYOUT.missionRowsPerWeek && !byItemNo[itemNo]) byItemNo[itemNo] = info;
  });

  for (let itemNo = 1; itemNo <= CONFIG_LAYOUT.missionRowsPerWeek; itemNo++) {
    if (byItemNo[itemNo]) continue;
    const row = new Array(MISSION_DEFINITIONS_COL_COUNT).fill('');
    row[col.weekKey] = 'w' + week;
    row[col.weekOrder] = week;
    row[col.weekTitle] = week + 'ņŻ╝ņ░©';
    row[col.drawThreshold] = 6;
    row[col.itemNo] = itemNo;
    row[col.enabled] = false;
    const rowIndex = Math.max(sheet.getLastRow() + 1, SCHEMA.MISSION_DEFINITIONS.dataStartRow);
    sheet.getRange(rowIndex, 1, 1, MISSION_DEFINITIONS_COL_COUNT).setValues([row]);
    byItemNo[itemNo] = { rowIndex: rowIndex, row: row };
  }

  return Object.keys(byItemNo)
    .map(function(itemNo) { return byItemNo[itemNo]; })
    .sort(function(a, b) {
      return (Number(a.row[col.itemNo]) || 0) - (Number(b.row[col.itemNo]) || 0);
    });
}

function setMissionConfigInDefinitions_(body) {
  const week = Number(body.week);
  const sheet = getOrCreateMissionDefinitionsSheet_();
  const col = getMissionDefinitionsColumns_(sheet);
  const infos = ensureMissionDefinitionWeekRows_(sheet, week);
  const title = String(body.title || '');
  const threshold = Number(body.threshold) || 6;
  const items = Array.isArray(body.items) ? body.items : [];

  infos.forEach(function(info, index) {
    const rowIndex = info.rowIndex;
    sheet.getRange(rowIndex, col.weekKey + 1).setValue('w' + week);
    sheet.getRange(rowIndex, col.weekOrder + 1).setValue(week);
    sheet.getRange(rowIndex, col.weekTitle + 1).setValue(title);
    sheet.getRange(rowIndex, col.drawThreshold + 1).setValue(threshold);
    sheet.getRange(rowIndex, col.itemNo + 1).setValue(index + 1);

    const item = items[index] || {};
    if (!String(item.item || '').trim()) return;
    sheet.getRange(rowIndex, col.itemText + 1).setValue(String(item.item));
    sheet.getRange(rowIndex, col.scoreWeight + 1).setValue(Number(item.score) || 1);
    sheet.getRange(rowIndex, col.category + 1).setValue(String(item.cat || 'L'));
    sheet.getRange(rowIndex, col.enabled + 1).setValue(true);
  });

  return { ok: true };
}

function migrate_step5_absorbToEvents(options) {
  const dryRun = options === true || !!(options && options.dryRun);
  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    const sheet = getOrCreateEventsSheet();
    const migration = buildEventsMigrationRows_();
    if (dryRun) {
      return logMigrationResult_('migrate_step5_absorbToEvents dryRun', {
        ok: true,
        dryRun: true,
        eventsPlanned: migration.rows.length,
        plannedByType: migration.byType,
        sourceRows: migration.sourceRows,
      });
    }

    const removedMigrationEvents = Events_clearMigrationEvents_();
    if (migration.rows.length) {
      sheet
        .getRange(Math.max(sheet.getLastRow() + 1, SCHEMA.EVENTS.dataStartRow), 1, migration.rows.length, EVENTS_COL_COUNT)
        .setValues(migration.rows);
    }
    sortEventsByTimestamp_(sheet);
    const verify = migrate_verify();
    return logMigrationResult_('migrate_step5_absorbToEvents result', {
      ok: verify.ok,
      dryRun: false,
      removedMigrationEvents: removedMigrationEvents,
      eventsWritten: migration.rows.length,
      plannedByType: migration.byType,
      sourceRows: migration.sourceRows,
      verify: verify,
    });
  } finally {
    lock.releaseLock();
  }
}

function migrate_step5_absorbToEvents_dryRun() {
  return migrate_step5_absorbToEvents({ dryRun: true });
}

function migrate_verify() {
  const expectedMigration = buildEventsMigrationRows_();
  const expected = expectedMigration.byType;
  const sheet = getOrCreateEventsSheet();
  const col = getEventsColumns_(sheet);
  const migrationRows = getEventsRows_(sheet).filter(function(row) {
    return String(row[col.source] || '') === EVENT_SOURCES.MIGRATION;
  });
  const actual = countEventRowsByType_(migrationRows);
  const issues = compareEventCounts_(expected, actual);
  const orphanUserIds = findOrphanEventUsers_(migrationRows);
  const invalidTradeRefs = findInvalidTradeEventRefs_(migrationRows);

  if (orphanUserIds.length) issues.push('orphan_event_users: ' + orphanUserIds.join(', '));
  if (invalidTradeRefs.length) issues.push('invalid_trade_refs: ' + invalidTradeRefs.join(', '));

  return logMigrationResult_('migrate_verify result', {
    ok: issues.length === 0,
    expected: expected,
    actual: actual,
    eventsChecked: migrationRows.length,
    sourceRows: expectedMigration.sourceRows,
    issues: issues,
    orphanUserIds: orphanUserIds,
    invalidTradeRefs: invalidTradeRefs,
  });
}

function buildEventsMigrationRows_() {
  const ss = getSpreadsheet();
  const rows = [];
  const sourceRows = {};

  collectRawCheckinEvents_(ss, rows, sourceRows);
  collectCardDrawEvents_(ss, rows, sourceRows);
  collectBonusDrawEvents_(ss, rows, sourceRows);
  collectTradeEvents_(ss, rows, sourceRows);
  collectHpGuessEvents_(ss, rows, sourceRows);
  collectCardReceivedEvents_(ss, rows, sourceRows);

  rows.sort(compareEventRows_);
  return {
    rows: rows,
    byType: countEventRowsByType_(rows),
    sourceRows: sourceRows,
  };
}

function getMigrationSheetContext_(ss, sheetName, columnFn, rowsFn, maxColumns) {
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return null;
  return {
    sheet: sheet,
    col: columnFn(sheet),
    rows: rowsFn(sheet, maxColumns),
  };
}

function collectRawCheckinEvents_(ss, eventRows, sourceRows) {
  const ctx = getMigrationSheetContext_(ss, SHEET_NAMES.RAW_CHECKINS, getRawColumns_, getRawRows_, 10);
  let converted = 0;
  if (ctx) {
    ctx.rows.forEach(function(row) {
      const userId = String(row[ctx.col.userId] || '').trim();
      if (!userId) return;
      converted++;
      const timestamp = row[ctx.col.timestamp];
      const weekKey = String(row[ctx.col.weekKey] || '').trim();
      pushMigrationEvent_(eventRows, EVENT_TYPES.MISSION_SUBMITTED, userId, {
        timestamp: timestamp,
        weekKey: weekKey,
        payload: {
          weekTitle: String(row[ctx.col.weekTitle] || ''),
          dateKey: eventDateKey_(row[ctx.col.dateKey]),
          score: Number(row[ctx.col.score]) || 0,
          weekCumScore: Number(row[ctx.col.weekCumScore]) || 0,
          items: parseJsonSafe_(row[ctx.col.itemsJson], []),
          indices: parseJsonSafe_(row[ctx.col.indicesJson], []),
        },
      });
      if (isTruthyEventValue_(row[ctx.col.ticketEarned])) {
        pushMigrationEvent_(eventRows, EVENT_TYPES.TICKET_GRANTED, userId, {
          timestamp: timestamp,
          timestampOffsetMs: 1,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'week_complete' },
        });
      }
    });
  }
  sourceRows[SHEET_NAMES.RAW_CHECKINS] = converted;
}

