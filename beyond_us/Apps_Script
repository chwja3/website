// ── GET ──────────────────────────────────────────
function doGet(e) {
  _devMode = (e && e.parameter && e.parameter.devMode === 'true');
  const action = (e && e.parameter && e.parameter.action) || 'dashboard';

  if (action === 'dashboard') return jsonOutput(getDashboardData());
  if (action === 'userStatus') {
    const userId  = e.parameter.userId  || '';
    const weekKey = e.parameter.weekKey || '';
    return jsonOutput(getUserStatus(userId, weekKey));
  }
  if (action === 'getUsers') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getUsers());
  }
  if (action === 'getTabSettings') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getTabSettings());
  }
  if (action === 'getNotices') return jsonOutput(getNotices());
  if (action === 'getInquiries') return jsonOutput(getInquiries());
  if (action === 'getHoldPray') return jsonOutput(getHoldPray(e.parameter.weekKey || '', e.parameter.nickname || ''));
  if (action === 'getCurrentWeek') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
    return jsonOutput({ ok: true, week: Number(sheet.getRange('B1').getValue()) || 1 });
  }
  if (action === 'getMissionConfig') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getMissionConfig(Number(e.parameter.week) || 1));
  }
  if (action === 'getCardStats') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getCardStats());
  }
  if (action === 'getPublicCollection') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput({ ok: true, collection: getUserCollection(uid) });
  }
  if (action === 'getTrades') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getTrades(uid));
  }
  if (action === 'getAdminTrades') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getAdminTrades());
  }
  if (action === 'migrateCardDrawsToCollection') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(migrateCardDrawsToCollection());
  }
  if (action === 'getBBB') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getBBB(uid));
  }
  if (action === 'getBBBMessages') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getBBBMessages(uid));
  }
  if (action === 'adminGetBBB') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(adminGetBBB());
  }

  return jsonOutput({ ok: false, message: 'Unknown action' });
}

// ── POST ─────────────────────────────────────────
function doPost(e) {
  try {
    const body   = JSON.parse(e.postData.contents || '{}');
    _devMode = (body.devMode === true);
    const action = body.action;

    if (action === 'submit') {
      saveCheckin(body.items || [], body.userId || '', body.weekKey || '', body.dateKey || '', body.score || 0);
      return jsonOutput({ ok: true });
    }
    if (action === 'drawCard') {
      return jsonOutput(drawCard(body.userId || '', body.weekKey || '', body.testMode || false));
    }
    if (action === 'adminLogin') {
      const ok = body.password === ADMIN_PASSWORD;
      return jsonOutput(ok ? { ok: true } : { error: 'wrong_password' });
    }
    if (action === 'adminResetPassword') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(adminResetPassword(body));
    }
    if (action === 'register') {
      return jsonOutput(registerUser(body));
    }
    if (action === 'login') {
      return jsonOutput(loginUser(body));
    }
    if (action === 'resetPassword') {
      return jsonOutput(resetPassword(body));
    }
    if (action === 'submitHoldPrayGuess') {
      return jsonOutput(submitHoldPrayGuess(body.weekKey || '', body.guess || '', body.nickname || ''));
    }
    if (action === 'postInquiry')   return jsonOutput(postInquiry(body));
    if (action === 'editInquiry')   return jsonOutput(editInquiry(body));
    if (action === 'deleteInquiry') return jsonOutput(deleteInquiry(body));
    if (action === 'replyInquiry')  return jsonOutput(replyInquiry(body));
    if (action === 'setTabSettings') {
      return jsonOutput(setTabSettings(body));
    }
    if (action === 'setCurrentWeek') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      const week = Number(body.week);
      if (!week || week < 1 || week > 6) return jsonOutput({ error: 'invalid_week' });
      const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
      sheet.getRange('B1').setValue(week);
      return jsonOutput({ ok: true, week });
    }
    if (action === 'setMissionConfig') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(setMissionConfig(body));
    }
    if (action === 'postNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(postNotice(body));
    }
    if (action === 'deleteNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(deleteNotice(body));
    }
    if (action === 'editNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(editNotice(body));
    }
    if (action === 'requestTrade') return jsonOutput(requestTrade(body));
    if (action === 'acceptTrade')  return jsonOutput(acceptTrade(body));
    if (action === 'rejectTrade')  return jsonOutput(rejectTrade(body));
    if (action === 'cancelTrade')  return jsonOutput(cancelTrade(body));
    if (action === 'guessBBBSecret')        return jsonOutput(guessBBBSecret(body));
    if (action === 'sendBBBMessage')        return jsonOutput(sendBBBMessage(body));
    if (action === 'adminSetBBBMessageOpen') return jsonOutput(adminSetBBBMessageOpen(body));
    if (action === 'adminSetupBBBMatching') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(setupBBBMatching());
    }

    return jsonOutput({ ok: false, message: 'Unknown action' });
  } catch (err) {
    return jsonOutput({ ok: false, message: err.message });
  }
}

// ── config 시트 구조 ──────────────────────────────
// B1: 현재 주차 번호 (1~6) ← 어드민에서 변경
// B2: prayer 탭 on/off
// B3: secret 탭 on/off
//
// 주차별 데이터 (8행 단위 블록):
// startRow = (week - 1) * 8 + 5
// startRow+0: B=주차 제목, C=drawThreshold
// startRow+1~6: A=항목 텍스트, B=점수, C=카테고리

function getSpreadsheet() {
  return SpreadsheetApp.openById(_devMode ? DEV_SPREADSHEET_ID : SPREADSHEET_ID);
}

function getConfig() {
  const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  if (!sheet) throw new Error('config 시트를 찾을 수 없습니다.');

  const currentWeek   = Number(sheet.getRange('B1').getValue()) || 1;
  const startRow      = (currentWeek - 1) * 8 + 5;
  const weekTitle     = sheet.getRange(startRow, 2).getValue();
  const drawThreshold = Number(sheet.getRange(startRow, 3).getValue()) || 6;

  const rawItems = sheet.getRange(startRow + 1, 1, 6, 3).getValues();
  const items  = [];
  const scores = {};
  const cats   = {};
  rawItems.forEach(([item, score, cat]) => {
    if (!item) return;
    const key = String(item);
    items.push(key);
    scores[key] = Number(score) || 1;
    cats[key]   = String(cat || 'L');
  });
  return { weekTitle, items, scores, cats, drawThreshold, currentWeek };
}

// ── raw_checkins 컬럼 구조 ────────────────────────
// [0] timestamp  [1] weekTitle  [2] items_json
// [3] userId     [4] weekKey    [5] dateKey  [6] score

function saveCheckin(items, userId, weekKey, dateKey, score) {
  const cleanItems = Array.isArray(items) ? items.filter(Boolean) : [];
  if (!cleanItems.length) throw new Error('No items selected');

  const ss       = getSpreadsheet();
  const rawSheet = ss.getSheetByName(RAW_SHEET_NAME);
  const config   = getConfig();
  if (!rawSheet) throw new Error('raw_checkins 시트를 찾을 수 없습니다');

  const today = dateKey || Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 서버사이드 중복 제출 방지: 텍스트 + 인덱스 둘 다 체크
  const submittedToday   = new Set();
  const submittedIndices = new Set();
  const lastRow = rawSheet.getLastRow();
  if (lastRow >= 2) {
    const rows = rawSheet.getRange(2, 1, lastRow - 1, 8).getValues();
    for (const row of rows) {
      const rowDate = row[5] instanceof Date ? Utilities.formatDate(row[5], 'Asia/Seoul', 'yyyy-MM-dd') : String(row[5]).trim();
      if (String(row[3]) === userId && rowDate === today) {
        try { JSON.parse(row[2] || '[]').forEach(item => {
          submittedToday.add(item);
          const idx = config.items.indexOf(item);
          if (idx >= 0) submittedIndices.add(idx);
        }); } catch(e) {}
        try { JSON.parse(row[7] || '[]').forEach(idx => { if (typeof idx === 'number') submittedIndices.add(idx); }); } catch(e) {}
      }
    }
  }

  const newItems = cleanItems.filter(item => {
    if (submittedToday.has(item)) return false;
    const idx = config.items.indexOf(item);
    return !(idx >= 0 && submittedIndices.has(idx));
  });
  if (!newItems.length) return; // 모두 이미 제출됨

  // 점수 서버에서 재계산
  const newScore = newItems.reduce((s, item) => s + (config.scores[item] || 1), 0);

  // 인덱스 저장: 텍스트 변경 시에도 제출 이력 유지
  const newIndices = newItems.map(item => config.items.indexOf(item));

  rawSheet.appendRow([new Date(), config.weekTitle, JSON.stringify(newItems), userId, weekKey, today, newScore, JSON.stringify(newIndices)]);
}

function getDashboardData() {
  const ss       = getSpreadsheet();
  const rawSheet = ss.getSheetByName(RAW_SHEET_NAME);
  const config   = getConfig();
  if (!rawSheet) throw new Error('raw_checkins 시트를 찾을 수 없습니다.');

  const lastRow = rawSheet.getLastRow();
  const values  = lastRow >= 2 ? rawSheet.getRange(2, 1, lastRow - 1, 8).getValues() : [];

  const currentWeekRows = values.filter(row => row[1] === config.weekTitle);
  const counts = {};
  config.items.forEach(item => counts[item] = 0);

  currentWeekRows.forEach(row => {
    const counted = new Set();
    // 텍스트 기반 카운트
    try {
      JSON.parse(row[2] || '[]').forEach(item => {
        if (counts[item] !== undefined) counted.add(item);
      });
    } catch(e) {}
    // 인덱스 기반 폴백 (텍스트 변경된 구 데이터 보완)
    try {
      JSON.parse(row[7] || '[]').forEach(idx => {
        if (typeof idx === 'number' && config.items[idx] !== undefined) counted.add(config.items[idx]);
      });
    } catch(e) {}
    counted.forEach(item => { counts[item]++; });
  });

  return {
    ok: true,
    weekTitle:       config.weekTitle,
    items:           config.items,
    scores:          config.scores,
    cats:            config.cats,
    drawThreshold:   config.drawThreshold,
    counts,
    totalCount:      Object.values(counts).reduce((s,n) => s+n, 0),
    submissionCount: currentWeekRows.length,
    tabSettings:     getTabSettings()
  };
}

// ── 카드 시스템 ───────────────────────────────────
function getOrCreateDrawSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName('CardDraws');
  if (!sheet) {
    sheet = ss.insertSheet('CardDraws');
    sheet.appendRow(['userId','weekKey','cardId','cardName','drawnAt']);
  }
  return sheet;
}

function getUserStatus(userId, weekKey) {
  const ss     = getSpreadsheet();
  const config = getConfig();
  let weekScore = 0, drawnThisWeek = false, weekCard = null;
  const collection = [];
  const todayItems   = [];
  const todayIndices = [];
  const weekDates    = [];

  const today = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 이번 주 월~일 범위 계산 (KST)
  const nowKST = new Date(new Date().getTime() + 9 * 60 * 60 * 1000);
  const dow = nowKST.getUTCDay() || 7;
  const monday = new Date(nowKST);
  monday.setUTCDate(nowKST.getUTCDate() - (dow - 1));
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  const weekStart = monday.toISOString().slice(0, 10);
  const weekEnd   = sunday.toISOString().slice(0, 10);

  // raw_checkins 전체 읽기 (이번 주 점수 + 오늘 항목 + 이월 계산에 재사용)
  let allRows = [];
  try {
    const raw     = ss.getSheetByName(RAW_SHEET_NAME);
    const lastRow = raw.getLastRow();
    if (lastRow >= 2) {
      allRows = raw.getRange(2, 1, lastRow - 1, 8).getValues();
      for (const row of allRows) {
        if (String(row[3]) !== userId) continue;
        if (String(row[1]) === config.weekTitle) {
          weekScore += Number(row[6]) || 0;
          const rowDate = row[5] instanceof Date ? Utilities.formatDate(row[5], 'Asia/Seoul', 'yyyy-MM-dd') : String(row[5]).trim();
          // 이번 주 제출 날짜 수집
          if (rowDate >= weekStart && rowDate <= weekEnd && !weekDates.includes(rowDate)) {
            weekDates.push(rowDate);
          }
          if (rowDate === today) {
            try { JSON.parse(row[2] || '[]').forEach(item => {
              todayItems.push(item);
              // 인덱스 미저장 구 데이터: 현재 config 텍스트와 매칭해 인덱스 역추적
              const idx = config.items.indexOf(item);
              if (idx >= 0) todayIndices.push(idx);
            }); } catch(e) {}
            // 신규 데이터: 저장된 인덱스 추가 (텍스트 변경 후에도 유지)
            try { JSON.parse(row[7] || '[]').forEach(idx => { if (typeof idx === 'number') todayIndices.push(idx); }); } catch(e) {}
          }
        }
      }
    }
  } catch(e) {}

  // 카드 뽑기 이력 (drawnThisWeek, weekCard, 총 뽑기 수 카운트용)
  let totalDraws = 0;
  try {
    const draws = getOrCreateDrawSheet();
    const last  = draws.getLastRow();
    if (last >= 2) {
      const rows = draws.getRange(2, 1, last - 1, 5).getValues();
      for (const row of rows) {
        if (String(row[0]) !== userId) continue;
        totalDraws++;
        const card = SPIRIT_CARDS.find(c => c.id === Number(row[2]));
        if (!card) continue;
        if (String(row[1]) === weekKey) { drawnThisWeek = true; weekCard = card; }
      }
    }
  } catch(e) {}

  // 컬렉션 (Collection 시트에서 읽기 — 교환 결과 반영됨)
  try {
    const collCounts = getUserCollection(userId);
    SPIRIT_CARDS.forEach(card => {
      const cnt = collCounts[card.id] || 0;
      for (let j = 0; j < cnt; j++) collection.push({...card});
    });
  } catch(e) {}

  // 이월 뽑기권 계산: 1~currentWeek 중 자격 얻은 주 수 - 실제 뽑은 수
  let pendingDraws = 0;
  try {
    const configSheet = ss.getSheetByName(CONFIG_SHEET_NAME);
    let qualifiedWeeks = 0;
    for (let w = 1; w <= config.currentWeek; w++) {
      const wTitle     = `${w}주차`;
      const startRow   = (w - 1) * 8 + 5;
      const wThreshold = Number(configSheet.getRange(startRow, 3).getValue()) || 6;
      const wScore     = allRows
        .filter(r => String(r[3]) === userId && String(r[1]) === wTitle)
        .reduce((s, r) => s + (Number(r[6]) || 0), 0);
      if (wScore >= wThreshold) qualifiedWeeks++;
    }
    pendingDraws = Math.max(0, qualifiedWeeks - totalDraws);
  } catch(e) {}

  return {
    ok: true,
    weekScore,
    drawThreshold: config.drawThreshold,
    canDraw: pendingDraws > 0,
    pendingDraws,
    drawnThisWeek,
    weekCard,
    collection,
    todayItems,
    todayIndices,
    weekDates
  };
}

function drawCard(userId, weekKey, testMode) {
  if (!userId) return { ok: false, error: '닉네임이 없습니다.' };

  const config = getConfig();
  const ss     = getSpreadsheet();

  // DEV 환경은 뽑기권 검증 스킵 (테스트 자유롭게)
  if (!_devMode) {
    let allRows = [];
    try {
      const raw  = ss.getSheetByName(RAW_SHEET_NAME);
      const last = raw.getLastRow();
      if (last >= 2) allRows = raw.getRange(2, 1, last - 1, 7).getValues();
    } catch(e) {}

    let totalDraws = 0;
    try {
      const draws = getOrCreateDrawSheet();
      const last  = draws.getLastRow();
      if (last >= 2) {
        totalDraws = draws.getRange(2, 1, last - 1, 2).getValues()
          .filter(r => String(r[0]) === userId).length;
      }
    } catch(e) {}

    const configSheet = ss.getSheetByName(CONFIG_SHEET_NAME);
    let qualifiedWeeks = 0;
    for (let w = 1; w <= config.currentWeek; w++) {
      const wTitle     = `${w}주차`;
      const startRow   = (w - 1) * 8 + 5;
      const wThreshold = Number(configSheet.getRange(startRow, 3).getValue()) || 6;
      const wScore     = allRows
        .filter(r => String(r[3]) === userId && String(r[1]) === wTitle)
        .reduce((s, r) => s + (Number(r[6]) || 0), 0);
      if (wScore >= wThreshold) qualifiedWeeks++;
    }
    const pendingDraws = Math.max(0, qualifiedWeeks - totalDraws);
    if (pendingDraws <= 0) {
      return { ok: false, error: '사용 가능한 뽑기권이 없습니다.' };
    }
  }

  const card = SPIRIT_CARDS[Math.floor(Math.random() * SPIRIT_CARDS.length)];
  // 항상 시트에 기록 (DEV → DEV 시트, PROD → PROD 시트)
  const draws = getOrCreateDrawSheet();
  draws.appendRow([userId, weekKey, card.id, card.name, new Date().toISOString()]);
  updateCollectionSheet(userId, card.id, 1);
  return { ok: true, card };
}

