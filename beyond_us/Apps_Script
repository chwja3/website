function migrate_step4_splitConfig(options) {
  const dryRun = options === true || !!(options && options.dryRun);
  const ss = getSpreadsheet();
  const configSheet = ss.getSheetByName(CONFIG_SHEET_NAME);
  if (!configSheet) {
    return logJsonResult_('migrate_step4_splitConfig result', {
      ok: false,
      error: 'config_missing',
    });
  }

  const plan = buildConfigSplitPlan_(configSheet);
  if (dryRun) {
    return logJsonResult_('migrate_step4_splitConfig dryRun', {
      ok: true,
      dryRun: true,
      appSettingsPlanned: plan.appSettingsRows.length,
      missionDefinitionsPlanned: plan.missionDefinitionRows.length,
      appSettingKeys: plan.appSettingsRows.map(function(row) { return row[0]; }),
      enabledMissionCounts: plan.enabledMissionCounts,
    });
  }

  const appSettingsSheet = getOrCreateAppSettingsSheet_();
  clearSheetDataRows_(appSettingsSheet, SCHEMA.APP_SETTINGS, APP_SETTINGS_COL_COUNT);
  if (plan.appSettingsRows.length) {
    appSettingsSheet
      .getRange(SCHEMA.APP_SETTINGS.dataStartRow, 1, plan.appSettingsRows.length, APP_SETTINGS_COL_COUNT)
      .setValues(plan.appSettingsRows);
  }

  const missionDefinitionsSheet = getOrCreateMissionDefinitionsSheet_();
  clearSheetDataRows_(missionDefinitionsSheet, SCHEMA.MISSION_DEFINITIONS, MISSION_DEFINITIONS_COL_COUNT);
  if (plan.missionDefinitionRows.length) {
    missionDefinitionsSheet
      .getRange(SCHEMA.MISSION_DEFINITIONS.dataStartRow, 1, plan.missionDefinitionRows.length, MISSION_DEFINITIONS_COL_COUNT)
      .setValues(plan.missionDefinitionRows);
  }

  return logJsonResult_('migrate_step4_splitConfig result', {
    ok: true,
    dryRun: false,
    appSettingsWritten: plan.appSettingsRows.length,
    missionDefinitionsWritten: plan.missionDefinitionRows.length,
    enabledMissionCounts: plan.enabledMissionCounts,
  });
}

function migrate_step4_splitConfig_dryRun() {
  return migrate_step4_splitConfig({ dryRun: true });
}

