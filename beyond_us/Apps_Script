function buildMissionDefinitionRowsFromConfig_(configSheet) {
  const rows = [];
  for (let week = 1; week <= 6; week++) {
    const startRow = getConfigWeekStartRow_(week);
    const weekKey = 'w' + week;
    const weekTitle = String(configSheet.getRange(startRow, CONFIG_LAYOUT.missionTitleCol).getValue() || (week + '주차')).trim();
    const drawThreshold = Number(configSheet.getRange(startRow, CONFIG_LAYOUT.missionThresholdCol).getValue()) || 6;
    const rawItems = configSheet
      .getRange(startRow + 1, CONFIG_LAYOUT.missionItemCol, CONFIG_LAYOUT.missionRowsPerWeek, 3)
      .getValues();

    for (let i = 0; i < CONFIG_LAYOUT.missionRowsPerWeek; i++) {
      const itemText = String(rawItems[i][0] || '').trim();
      const enabled = itemText !== '';
      rows.push([
        weekKey,
        week,
        weekTitle,
        '',
        '',
        drawThreshold,
        i + 1,
        itemText,
        enabled ? (Number(rawItems[i][1]) || 1) : '',
        enabled ? String(rawItems[i][2] || 'L').trim() : '',
        enabled,
      ]);
    }
  }
  return rows;
}

function countEnabledMissionRowsByWeek_(configSheet) {
  const counts = {};
  for (let week = 1; week <= 6; week++) {
    const weekKey = 'w' + week;
    const startRow = getConfigWeekStartRow_(week);
    const items = configSheet
      .getRange(startRow + 1, CONFIG_LAYOUT.missionItemCol, CONFIG_LAYOUT.missionRowsPerWeek, 1)
      .getValues();
    counts[weekKey] = items.filter(function(row) {
      return String(row[0] || '').trim() !== '';
    }).length;
  }
  return counts;
}

function getAppSetting_(key, defaultValue) {
  const ss = getSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAMES.APP_SETTINGS);
  if (!sheet || sheet.getLastRow() < SCHEMA.APP_SETTINGS.dataStartRow) return defaultValue;
  const col = getAppSettingsColumns_(sheet);
  const rows = getAppSettingsRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.key] || '').trim() === key) {
      return coerceAppSettingValue_(rows[i][col.value], rows[i][col.type], defaultValue);
    }
  }
  return defaultValue;
}

function setAppSetting_(key, value, type, note) {
  const sheet = getOrCreateAppSettingsSheet_();
  const col = getAppSettingsColumns_(sheet);
  const rows = getAppSettingsRows_(sheet);
  const cleanKey = String(key || '').trim();
  if (!cleanKey) return { ok: false, error: 'missing_key' };

  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.key] || '').trim() !== cleanKey) continue;
    const rowIndex = i + SCHEMA.APP_SETTINGS.dataStartRow;
    sheet.getRange(rowIndex, col.value + 1).setValue(value);
    if (type) sheet.getRange(rowIndex, col.type + 1).setValue(type);
    if (note) sheet.getRange(rowIndex, col.note + 1).setValue(note);
    return { ok: true, key: cleanKey, updated: true };
  }

  const row = new Array(APP_SETTINGS_COL_COUNT).fill('');
  row[col.key] = cleanKey;
  row[col.value] = value;
  row[col.type] = type || '';
  row[col.note] = note || '';
  sheet.getRange(Math.max(sheet.getLastRow() + 1, SCHEMA.APP_SETTINGS.dataStartRow), 1, 1, APP_SETTINGS_COL_COUNT).setValues([row]);
  return { ok: true, key: cleanKey, inserted: true };
}

function coerceAppSettingValue_(value, type, defaultValue) {
  const typeName = String(type || '').trim().toLowerCase();
  if (value === '' || value === null || value === undefined) return defaultValue;
  if (typeName === 'number') {
    const numberValue = Number(value);
    return isNaN(numberValue) ? defaultValue : numberValue;
  }
  if (typeName === 'boolean') return isTruthyEventValue_(value);
  if (typeName === 'date') return eventDateKey_(value);
  return value;
}

function getCurrentWeek_() {
  const appSettingWeek = getAppSetting_(APP_SETTING_KEYS.CURRENT_WEEK, null);
  return Number(appSettingWeek) || 1;
}

function setCurrentWeek_(week) {
  const cleanWeek = Number(week);
  if (!cleanWeek || cleanWeek < 1 || cleanWeek > 6) return { error: 'invalid_week' };
  setAppSetting_(
    APP_SETTING_KEYS.CURRENT_WEEK,
    cleanWeek,
    'number',
    '현재 진행 주차. AppSettings 기준값.'
  );
  clearConfigCaches_();
  return { ok: true, week: cleanWeek };
}

function getMissionDefinitionRowInfos_(week) {
  const ss = getSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAMES.MISSION_DEFINITIONS);
  if (!sheet || sheet.getLastRow() < SCHEMA.MISSION_DEFINITIONS.dataStartRow) return [];
  const col = getMissionDefinitionsColumns_(sheet);
  const rows = getMissionDefinitionsRows_(sheet);
  const weekKey = 'w' + week;
  return rows
    .map(function(row, index) {
      return {
        rowIndex: index + SCHEMA.MISSION_DEFINITIONS.dataStartRow,
        row: row,
      };
    })
    .filter(function(info) {
      return String(info.row[col.weekKey] || '').trim() === weekKey ||
        Number(info.row[col.weekOrder]) === Number(week);
    })
    .sort(function(a, b) {
      return (Number(a.row[col.itemNo]) || 0) - (Number(b.row[col.itemNo]) || 0);
    });
}

function getMissionConfigFromDefinitions_(week) {
  if (week < 1 || week > 6) return null;
  const infos = getMissionDefinitionRowInfos_(week);
  if (!infos.length) return null;
  const col = getMissionDefinitionsColumns_(getSpreadsheet().getSheetByName(SHEET_NAMES.MISSION_DEFINITIONS));
  const first = infos[0].row;
  const title = String(first[col.weekTitle] || (week + '주차')).trim();
  const threshold = Number(first[col.drawThreshold]) || 6;
  const byItemNo = {};
  infos.forEach(function(info) {
    const itemNo = Number(info.row[col.itemNo]) || 0;
    if (itemNo >= 1 && itemNo <= CONFIG_LAYOUT.missionRowsPerWeek && !byItemNo[itemNo]) byItemNo[itemNo] = info;
  });
  const items = [];
  for (let itemNo = 1; itemNo <= CONFIG_LAYOUT.missionRowsPerWeek; itemNo++) {
    const info = byItemNo[itemNo];
    if (!info) {
      items.push({ item: '', score: 1, cat: 'L', enabled: false });
      continue;
    }
    const row = info.row;
    const itemText = String(row[col.itemText] || '').trim();
    const enabledCell = row[col.enabled];
    const enabled = enabledCell === '' ? itemText !== '' : isTruthyEventValue_(enabledCell);
    items.push({
      item: itemText,
      score: Number(row[col.scoreWeight]) || 1,
      cat: String(row[col.category] || 'L').trim(),
      enabled: enabled,
    });
  }
  return { ok: true, week: week, title: title, threshold: threshold, items: items };
}

function getMissionConfigModel_(week) {
  return getMissionConfigFromDefinitions_(week);
}

function getAllWeekMeta_() {
  const weeks = [];
  for (let week = 1; week <= 6; week++) {
    const config = getMissionConfigModel_(week);
    weeks.push({
      week: week,
      weekKey: 'w' + week,
      title: config ? String(config.title || (week + '주차')).trim() : (week + '주차'),
      threshold: config ? (Number(config.threshold) || 6) : 6,
    });
  }
  return weeks;
}

function getMissionThresholdMap_() {
  const thresholdMap = {};
  getAllWeekMeta_().forEach(function(meta) {
    if (meta.title) thresholdMap[meta.title] = meta.threshold;
    thresholdMap[meta.weekKey] = meta.threshold;
  });
  return thresholdMap;
}

function ensureMissionDefinitionWeekRows_(sheet, week) {
  const col = getMissionDefinitionsColumns_(sheet);
  const existing = getMissionDefinitionRowInfos_(week);
  const byItemNo = {};
  existing.forEach(function(info) {
    const itemNo = Number(info.row[col.itemNo]) || 0;
    if (itemNo >= 1 && itemNo <= CONFIG_LAYOUT.missionRowsPerWeek && !byItemNo[itemNo]) byItemNo[itemNo] = info;
  });

  for (let itemNo = 1; itemNo <= CONFIG_LAYOUT.missionRowsPerWeek; itemNo++) {
    if (byItemNo[itemNo]) continue;
    const row = new Array(MISSION_DEFINITIONS_COL_COUNT).fill('');
    row[col.weekKey] = 'w' + week;
    row[col.weekOrder] = week;
    row[col.weekTitle] = week + '주차';
    row[col.drawThreshold] = 6;
    row[col.itemNo] = itemNo;
    row[col.enabled] = false;
    const rowIndex = Math.max(sheet.getLastRow() + 1, SCHEMA.MISSION_DEFINITIONS.dataStartRow);
    sheet.getRange(rowIndex, 1, 1, MISSION_DEFINITIONS_COL_COUNT).setValues([row]);
    byItemNo[itemNo] = { rowIndex: rowIndex, row: row };
  }

  return Object.keys(byItemNo)
    .map(function(itemNo) { return byItemNo[itemNo]; })
    .sort(function(a, b) {
      return (Number(a.row[col.itemNo]) || 0) - (Number(b.row[col.itemNo]) || 0);
    });
}

function setMissionConfigInDefinitions_(body) {
  const week = Number(body.week);
  const sheet = getOrCreateMissionDefinitionsSheet_();
  const col = getMissionDefinitionsColumns_(sheet);
  const infos = ensureMissionDefinitionWeekRows_(sheet, week);
  const title = String(body.title || '');
  const threshold = Number(body.threshold) || 6;
  const items = Array.isArray(body.items) ? body.items : [];

  infos.forEach(function(info, index) {
    const rowIndex = info.rowIndex;
    sheet.getRange(rowIndex, col.weekKey + 1).setValue('w' + week);
    sheet.getRange(rowIndex, col.weekOrder + 1).setValue(week);
    sheet.getRange(rowIndex, col.weekTitle + 1).setValue(title);
    sheet.getRange(rowIndex, col.drawThreshold + 1).setValue(threshold);
    sheet.getRange(rowIndex, col.itemNo + 1).setValue(index + 1);

    const item = items[index] || {};
    if (!String(item.item || '').trim()) return;
    sheet.getRange(rowIndex, col.itemText + 1).setValue(String(item.item));
    sheet.getRange(rowIndex, col.scoreWeight + 1).setValue(Number(item.score) || 1);
    sheet.getRange(rowIndex, col.category + 1).setValue(String(item.cat || 'L'));
    sheet.getRange(rowIndex, col.enabled + 1).setValue(true);
  });

  return { ok: true };
}

function migrate_step5_absorbToEvents(options) {
  const dryRun = options === true || !!(options && options.dryRun);
  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    const sheet = getOrCreateEventsSheet();
    const migration = buildEventsMigrationRows_();
    if (dryRun) {
      return logMigrationResult_('migrate_step5_absorbToEvents dryRun', {
        ok: true,
        dryRun: true,
        eventsPlanned: migration.rows.length,
        plannedByType: migration.byType,
        sourceRows: migration.sourceRows,
      });
    }

    const removedMigrationEvents = Events_clearMigrationEvents_();
    if (migration.rows.length) {
      sheet
        .getRange(Math.max(sheet.getLastRow() + 1, SCHEMA.EVENTS.dataStartRow), 1, migration.rows.length, EVENTS_COL_COUNT)
        .setValues(migration.rows);
    }
    sortEventsByTimestamp_(sheet);
    const verify = migrate_verify();
    return logMigrationResult_('migrate_step5_absorbToEvents result', {
      ok: verify.ok,
      dryRun: false,
      removedMigrationEvents: removedMigrationEvents,
      eventsWritten: migration.rows.length,
      plannedByType: migration.byType,
      sourceRows: migration.sourceRows,
      verify: verify,
    });
  } finally {
    lock.releaseLock();
  }
}

function migrate_step5_absorbToEvents_dryRun() {
  return migrate_step5_absorbToEvents({ dryRun: true });
}

function migrate_verify() {
  const expectedMigration = buildEventsMigrationRows_();
  const expected = expectedMigration.byType;
  const sheet = getOrCreateEventsSheet();
  const col = getEventsColumns_(sheet);
  const migrationRows = getEventsRows_(sheet).filter(function(row) {
    return String(row[col.source] || '') === EVENT_SOURCES.MIGRATION;
  });
  const actual = countEventRowsByType_(migrationRows);
  const issues = compareEventCounts_(expected, actual);
  const orphanUserIds = findOrphanEventUsers_(migrationRows);
  const invalidTradeRefs = findInvalidTradeEventRefs_(migrationRows);

  if (orphanUserIds.length) issues.push('orphan_event_users: ' + orphanUserIds.join(', '));
  if (invalidTradeRefs.length) issues.push('invalid_trade_refs: ' + invalidTradeRefs.join(', '));

  return logMigrationResult_('migrate_verify result', {
    ok: issues.length === 0,
    expected: expected,
    actual: actual,
    eventsChecked: migrationRows.length,
    sourceRows: expectedMigration.sourceRows,
    issues: issues,
    orphanUserIds: orphanUserIds,
    invalidTradeRefs: invalidTradeRefs,
  });
}

function buildEventsMigrationRows_() {
  const ss = getSpreadsheet();
  const rows = [];
  const sourceRows = {};

  collectRawCheckinEvents_(ss, rows, sourceRows);
  collectCardDrawEvents_(ss, rows, sourceRows);
  collectBonusDrawEvents_(ss, rows, sourceRows);
  collectTradeEvents_(ss, rows, sourceRows);
  collectHpGuessEvents_(ss, rows, sourceRows);
  collectCardReceivedEvents_(ss, rows, sourceRows);

  rows.sort(compareEventRows_);
  return {
    rows: rows,
    byType: countEventRowsByType_(rows),
    sourceRows: sourceRows,
  };
}

function getMigrationSheetContext_(ss, sheetName, columnFn, rowsFn, maxColumns) {
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return null;
  return {
    sheet: sheet,
    col: columnFn(sheet),
    rows: rowsFn(sheet, maxColumns),
  };
}

function collectRawCheckinEvents_(ss, eventRows, sourceRows) {
  const ctx = getMigrationSheetContext_(ss, SHEET_NAMES.RAW_CHECKINS, getRawColumns_, getRawRows_, 10);
  let converted = 0;
  if (ctx) {
    ctx.rows.forEach(function(row) {
      const userId = String(row[ctx.col.userId] || '').trim();
      if (!userId) return;
      converted++;
      const timestamp = row[ctx.col.timestamp];
      const weekKey = String(row[ctx.col.weekKey] || '').trim();
      pushMigrationEvent_(eventRows, EVENT_TYPES.MISSION_SUBMITTED, userId, {
        timestamp: timestamp,
        weekKey: weekKey,
        payload: {
          weekTitle: String(row[ctx.col.weekTitle] || ''),
          dateKey: eventDateKey_(row[ctx.col.dateKey]),
          score: Number(row[ctx.col.score]) || 0,
          weekCumScore: Number(row[ctx.col.weekCumScore]) || 0,
          items: parseJsonSafe_(row[ctx.col.itemsJson], []),
          indices: parseJsonSafe_(row[ctx.col.indicesJson], []),
        },
      });
      if (isTruthyEventValue_(row[ctx.col.ticketEarned])) {
        pushMigrationEvent_(eventRows, EVENT_TYPES.TICKET_GRANTED, userId, {
          timestamp: timestamp,
          timestampOffsetMs: 1,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'week_complete' },
        });
      }
    });
  }
  sourceRows[SHEET_NAMES.RAW_CHECKINS] = converted;
}

