// ── GET ──────────────────────────────────────────
function doGet(e) {
  const action = (e && e.parameter && e.parameter.action) || 'dashboard';

  if (action === 'dashboard') return jsonOutput(getDashboardData());
  if (action === 'userStatus') {
    const userId  = e.parameter.userId  || '';
    const weekKey = e.parameter.weekKey || '';
    return jsonOutput(getUserStatus(userId, weekKey));
  }
  if (action === 'getUsers') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getUsers());
  }
  if (action === 'getTabSettings') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getTabSettings());
  }
  if (action === 'getNotices') return jsonOutput(getNotices());
  if (action === 'getInquiries') return jsonOutput(getInquiries());
  if (action === 'getCurrentWeek') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
    return jsonOutput({ ok: true, week: Number(sheet.getRange('B1').getValue()) || 1 });
  }
  if (action === 'getMissionConfig') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getMissionConfig(Number(e.parameter.week) || 1));
  }
  if (action === 'getCardStats') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getCardStats());
  }

  return jsonOutput({ ok: false, message: 'Unknown action' });
}

// ── POST ─────────────────────────────────────────
function doPost(e) {
  try {
    const body   = JSON.parse(e.postData.contents || '{}');
    const action = body.action;

    if (action === 'submit') {
      saveCheckin(body.items || [], body.userId || '', body.weekKey || '', body.dateKey || '', body.score || 0);
      return jsonOutput({ ok: true });
    }
    if (action === 'drawCard') {
      return jsonOutput(drawCard(body.userId || '', body.weekKey || '', body.testMode || false));
    }
    if (action === 'adminLogin') {
      const ok = body.password === ADMIN_PASSWORD;
      return jsonOutput(ok ? { ok: true } : { error: 'wrong_password' });
    }
    if (action === 'adminResetPassword') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(adminResetPassword(body));
    }
    if (action === 'register') {
      return jsonOutput(registerUser(body));
    }
    if (action === 'login') {
      return jsonOutput(loginUser(body));
    }
    if (action === 'resetPassword') {
      return jsonOutput(resetPassword(body));
    }
    if (action === 'postInquiry')   return jsonOutput(postInquiry(body));
    if (action === 'editInquiry')   return jsonOutput(editInquiry(body));
    if (action === 'deleteInquiry') return jsonOutput(deleteInquiry(body));
    if (action === 'replyInquiry')  return jsonOutput(replyInquiry(body));
    if (action === 'setTabSettings') {
      return jsonOutput(setTabSettings(body));
    }
    if (action === 'setCurrentWeek') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      const week = Number(body.week);
      if (!week || week < 1 || week > 6) return jsonOutput({ error: 'invalid_week' });
      const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
      sheet.getRange('B1').setValue(week);
      return jsonOutput({ ok: true, week });
    }
    if (action === 'setMissionConfig') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(setMissionConfig(body));
    }
    if (action === 'postNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(postNotice(body));
    }
    if (action === 'deleteNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(deleteNotice(body));
    }
    if (action === 'editNotice') {
      if (body.adminPw !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
      return jsonOutput(editNotice(body));
    }

    return jsonOutput({ ok: false, message: 'Unknown action' });
  } catch (err) {
    return jsonOutput({ ok: false, message: err.message });
  }
}

// ── config 시트 구조 ──────────────────────────────
// B1: 현재 주차 번호 (1~6) ← 어드민에서 변경
// B2: prayer 탭 on/off
// B3: secret 탭 on/off
//
// 주차별 데이터 (8행 단위 블록):
// startRow = (week - 1) * 8 + 5
// startRow+0: B=주차 제목, C=drawThreshold
// startRow+1~6: A=항목 텍스트, B=점수, C=카테고리

function getSpreadsheet() {
  return SpreadsheetApp.openById(SPREADSHEET_ID);
}

function getConfig() {
  const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  if (!sheet) throw new Error('config 시트를 찾을 수 없습니다.');

  const currentWeek   = Number(sheet.getRange('B1').getValue()) || 1;
  const startRow      = (currentWeek - 1) * 8 + 5;
  const weekTitle     = sheet.getRange(startRow, 2).getValue();
  const drawThreshold = Number(sheet.getRange(startRow, 3).getValue()) || 6;

  const rawItems = sheet.getRange(startRow + 1, 1, 6, 3).getValues();
  const items  = [];
  const scores = {};
  const cats   = {};
  rawItems.forEach(([item, score, cat]) => {
    if (!item) return;
    const key = String(item);
    items.push(key);
    scores[key] = Number(score) || 1;
    cats[key]   = String(cat || 'L');
  });
  return { weekTitle, items, scores, cats, drawThreshold, currentWeek };
}

// ── raw_checkins 컬럼 구조 ────────────────────────
// [0] timestamp  [1] weekTitle  [2] items_json
// [3] userId     [4] weekKey    [5] dateKey  [6] score

function saveCheckin(items, userId, weekKey, dateKey, score) {
  const cleanItems = Array.isArray(items) ? items.filter(Boolean) : [];
  if (!cleanItems.length) throw new Error('No items selected');

  const ss       = getSpreadsheet();
  const rawSheet = ss.getSheetByName(RAW_SHEET_NAME);
  const config   = getConfig();
  if (!rawSheet) throw new Error('raw_checkins 시트를 찾을 수 없습니다');

  const today = dateKey || Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 서버사이드 중복 제출 방지: 오늘 이미 제출한 항목 수집
  const submittedToday = new Set();
  const lastRow = rawSheet.getLastRow();
  if (lastRow >= 2) {
    const rows = rawSheet.getRange(2, 1, lastRow - 1, 7).getValues();
    for (const row of rows) {
      const rowDate = row[5] instanceof Date ? Utilities.formatDate(row[5], 'Asia/Seoul', 'yyyy-MM-dd') : String(row[5]).trim();
      if (String(row[3]) === userId && rowDate === today) {
        try { JSON.parse(row[2] || '[]').forEach(item => submittedToday.add(item)); } catch(e) {}
      }
    }
  }

  const newItems = cleanItems.filter(item => !submittedToday.has(item));
  if (!newItems.length) return; // 모두 이미 제출됨

  // 점수 서버에서 재계산
  const newScore = newItems.reduce((s, item) => s + (config.scores[item] || 1), 0);

  rawSheet.appendRow([new Date(), config.weekTitle, JSON.stringify(newItems), userId, weekKey, today, newScore]);
}

function getDashboardData() {
  const ss       = getSpreadsheet();
  const rawSheet = ss.getSheetByName(RAW_SHEET_NAME);
  const config   = getConfig();
  if (!rawSheet) throw new Error('raw_checkins 시트를 찾을 수 없습니다.');

  const lastRow = rawSheet.getLastRow();
  const values  = lastRow >= 2 ? rawSheet.getRange(2, 1, lastRow - 1, 7).getValues() : [];

  const currentWeekRows = values.filter(row => row[1] === config.weekTitle);
  const counts = {};
  config.items.forEach(item => counts[item] = 0);

  currentWeekRows.forEach(row => {
    try {
      JSON.parse(row[2] || '[]').forEach(item => {
        if (counts[item] !== undefined) counts[item]++;
      });
    } catch(e) {}
  });

  return {
    ok: true,
    weekTitle:       config.weekTitle,
    items:           config.items,
    scores:          config.scores,
    cats:            config.cats,
    drawThreshold:   config.drawThreshold,
    counts,
    totalCount:      Object.values(counts).reduce((s,n) => s+n, 0),
    submissionCount: currentWeekRows.length,
    tabSettings:     getTabSettings()
  };
}

// ── 카드 시스템 ───────────────────────────────────
function getOrCreateDrawSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName('CardDraws');
  if (!sheet) {
    sheet = ss.insertSheet('CardDraws');
    sheet.appendRow(['userId','weekKey','cardId','cardName','drawnAt']);
  }
  return sheet;
}

function getUserStatus(userId, weekKey) {
  const ss     = getSpreadsheet();
  const config = getConfig();
  let weekScore = 0, drawnThisWeek = false, weekCard = null;
  const collection = [];
  const todayItems = [];

  const today = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 이번 주 누적 점수 + 오늘 체크한 항목 확인
  try {
    const raw     = ss.getSheetByName(RAW_SHEET_NAME);
    const lastRow = raw.getLastRow();
    if (lastRow >= 2) {
      const rows = raw.getRange(2, 1, lastRow - 1, 7).getValues();
      for (const row of rows) {
        if (String(row[3]) === userId && String(row[4]) === weekKey) {
          weekScore += Number(row[6]) || 0;
          const rowDate = row[5] instanceof Date ? Utilities.formatDate(row[5], 'Asia/Seoul', 'yyyy-MM-dd') : String(row[5]).trim();
          if (rowDate === today) {
            try {
              JSON.parse(row[2] || '[]').forEach(item => todayItems.push(item));
            } catch(e) {}
          }
        }
      }
    }
  } catch(e) {}

  const canDraw = weekScore >= config.drawThreshold;

  // 카드 뽑기 이력
  try {
    const draws = getOrCreateDrawSheet();
    const last  = draws.getLastRow();
    if (last >= 2) {
      const rows = draws.getRange(2, 1, last - 1, 5).getValues();
      for (const row of rows) {
        if (String(row[0]) !== userId) continue;
        const card = SPIRIT_CARDS.find(c => c.id === Number(row[2]));
        if (!card) continue;
        collection.push({...card, drawnAt: row[4]});
        if (String(row[1]) === weekKey) { drawnThisWeek = true; weekCard = card; }
      }
    }
  } catch(e) {}

  return {
    ok: true,
    weekScore,
    drawThreshold: config.drawThreshold,
    canDraw,
    drawnThisWeek,
    weekCard,
    collection,
    todayItems
  };
}

function drawCard(userId, weekKey, testMode) {
  if (!userId) return { ok: false, error: '닉네임이 없습니다.' };

  const config = getConfig();
  const ss     = getSpreadsheet();
  const raw    = ss.getSheetByName(RAW_SHEET_NAME);
  let weekScore = 0;

  try {
    const last = raw.getLastRow();
    if (last >= 2) {
      const rows = raw.getRange(2, 1, last - 1, 7).getValues();
      for (const row of rows) {
        if (String(row[3]) === userId && String(row[4]) === weekKey) {
          weekScore += Number(row[6]) || 0;
        }
      }
    }
  } catch(e) {}

  if (!testMode && weekScore < config.drawThreshold) {
    return { ok: false, error: `뽑기 기준(${config.drawThreshold}점)에 아직 도달하지 못했습니다.` };
  }

  const draws = getOrCreateDrawSheet();
  const last  = draws.getLastRow();
  if (!testMode && last >= 2) {
    const rows = draws.getRange(2, 1, last - 1, 2).getValues();
    for (const row of rows) {
      if (String(row[0]) === userId && String(row[1]) === weekKey) {
        return { ok: false, error: '이번 주에 이미 뽑았습니다.' };
      }
    }
  }

  const card = SPIRIT_CARDS[Math.floor(Math.random() * SPIRIT_CARDS.length)];
  draws.appendRow([userId, weekKey, card.id, card.name, new Date().toISOString()]);
  return { ok: true, card };
}

// ── 탭 설정 ──────────────────────────────────────
function getTabSettings() {
  const sheet  = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const prayer = sheet.getRange('B2').getValue();
  const secret = sheet.getRange('B3').getValue();
  return {
    ok:     true,
    prayer: prayer === '' ? true : Boolean(prayer),
    secret: secret === '' ? true : Boolean(secret)
  };
}

function setTabSettings(body) {
  if (body.adminPw !== ADMIN_PASSWORD) return { error: 'unauthorized' };
  const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  sheet.getRange('B2').setValue(body.prayer !== false);
  sheet.getRange('B3').setValue(body.secret !== false);
  return { ok: true };
}

// ── 유저 인증 ─────────────────────────────────────
function registerUser(body) {
  const sheet    = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const name     = String(body.name     || '').trim();
  const parish   = String(body.parish   || '').trim();

  if (!nickname || !password || !name || !parish) return { error: 'missing_fields' };

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname) return { error: 'duplicate' };
  }

  sheet.appendRow([nickname, '', name, parish, new Date()]);
  const pwCell = sheet.getRange(sheet.getLastRow(), 2);
  pwCell.setNumberFormat('@');
  pwCell.setValue(password);
  return { ok: true };
}

function loginUser(body) {
  const sheet    = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname) {
      if (String(data[i][1]).trim() === password) {
        return { ok: true, parish: data[i][3] };
      }
      return { error: 'wrong_password' };
    }
  }
  return { error: 'not_found' };
}

function resetPassword(body) {
  const sheet       = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const nickname    = String(body.nickname    || '').trim();
  const name        = String(body.name        || '').trim();
  const parish      = String(body.parish      || '').trim();
  const newPassword = String(body.newPassword || '').trim();

  if (!newPassword || newPassword.length < 4) return { error: 'invalid_password' };

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname &&
        String(data[i][2]).trim() === name &&
        String(data[i][3]).trim() === parish) {
      const cell = sheet.getRange(i + 1, 2);
      cell.setNumberFormat('@');
      cell.setValue(newPassword);
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

function getUsers() {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  const users = [];
  for (let i = 1; i < data.length; i++) {
    if (!data[i][0]) continue;
    users.push({ nickname: data[i][0], name: data[i][2], parish: data[i][3], createdAt: data[i][4] });
  }
  return { ok: true, users };
}

function adminResetPassword(body) {
  const sheet       = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const nickname    = String(body.nickname    || '').trim();
  const newPassword = String(body.newPassword || '').trim();
  if (!nickname || !newPassword) return { error: 'missing_fields' };

  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname) {
      const cell = sheet.getRange(i + 1, 2);
      cell.setNumberFormat('@');
      cell.setValue(newPassword);
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

// ── 공지사항 ──────────────────────────────────────
function getOrCreateNoticeSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName('Notices');
  if (!sheet) {
    sheet = ss.insertSheet('Notices');
    sheet.appendRow(['id','title','content','createdAt']);
  }
  return sheet;
}

function getNotices() {
  const sheet = getOrCreateNoticeSheet();
  const last = sheet.getLastRow();
  if (last < 2) return { ok: true, notices: [] };
  const rows = sheet.getRange(2, 1, last - 1, 4).getValues();
  const notices = rows
    .filter(r => r[0])
    .map((r, i) => ({ rowIndex: i + 2, id: String(r[0]), title: r[1], content: r[2], createdAt: r[3] }))
    .reverse();
  return { ok: true, notices };
}

function postNotice(body) {
  const title   = String(body.title   || '').trim();
  const content = String(body.content || '').trim();
  if (!title || !content) return { error: 'missing_fields' };
  const sheet = getOrCreateNoticeSheet();
  sheet.appendRow([new Date().getTime(), title, content, new Date().toISOString()]);
  return { ok: true };
}

function deleteNotice(body) {
  const rowIndex = Number(body.rowIndex);
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  getOrCreateNoticeSheet().deleteRow(rowIndex);
  return { ok: true };
}

function editNotice(body) {
  const rowIndex = Number(body.rowIndex);
  const title   = String(body.title   || '').trim();
  const content = String(body.content || '').trim();
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  if (!title || !content) return { error: 'missing_fields' };
  const sheet = getOrCreateNoticeSheet();
  sheet.getRange(rowIndex, 2).setValue(title);
  sheet.getRange(rowIndex, 3).setValue(content);
  return { ok: true };
}

// ── 카드 통계 ─────────────────────────────────────
function getCardStats() {
  const draws = getOrCreateDrawSheet();
  const last  = draws.getLastRow();
  if (last < 2) return { ok: true, cardCounts: {}, userStats: [], totalDraws: 0 };

  const rows = draws.getRange(2, 1, last - 1, 5).getValues();
  const cardCounts = {};
  SPIRIT_CARDS.forEach(c => { cardCounts[c.id] = 0; });

  const userMap = {};
  rows.forEach(row => {
    const userId = String(row[0]);
    const cardId = Number(row[2]);
    if (!userId) return;
    cardCounts[cardId] = (cardCounts[cardId] || 0) + 1;
    if (!userMap[userId]) userMap[userId] = { unique: new Set(), total: 0 };
    userMap[userId].unique.add(cardId);
    userMap[userId].total++;
  });

  const userStats = Object.entries(userMap).map(([nickname, s]) => ({
    nickname,
    unique: s.unique.size,
    total:  s.total
  })).sort((a, b) => b.unique - a.unique || b.total - a.total);

  return { ok: true, cardCounts, userStats, totalDraws: rows.length };
}

