  return { ok: true };
}

// ─ 어드민: 매칭 데이터 직접 입력
function adminWriteBBBRows(rows) {
  if (!Array.isArray(rows) || rows.length === 0) return { error: 'rows가 비어있어요.' };
  const bbbSheet = getOrCreateBBBSheet();
  if (bbbSheet.getLastRow() >= SCHEMA.BBB.dataStartRow) {
    bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, bbbSheet.getLastRow() - SCHEMA.BBB.dataStartRow + 1, 6).clearContent();
