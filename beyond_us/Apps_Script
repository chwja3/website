function getRaffleStatsFromRows_(userId, options) {
  const opts = options || {};
  const cleanUserId = String(userId || '').trim();
  const stats = getEmptyRaffleStats_();
  const collectionMap = getCollectionSnapshotMap_(opts.collectionRows || [], opts.collectionCol);
  const ticketSummary = getActiveRaffleTicketSummary_(opts.raffleRows || getRaffleTicketRows_());
  let foundCurrentUser = false;

  (opts.usersRows || []).forEach(function(row) {
    const nickname = String(row[opts.userCol.nickname] || '').trim();
    if (!nickname) return;
    const raffleExcluded = getUserRaffleExcludedFromRow_(row, opts.userCol);
    if (raffleExcluded) {
      if (nickname === cleanUserId) {
        const currentSnapshot = opts.currentSnapshot || collectionMap[nickname] || emptyCollectionSnapshot_(nickname, false);
        stats.eligible = false;
        stats.ineligibleReason = 'raffle_excluded';
        stats.uniqueCards = getRaffleTicketInfoFromCardCounts_(currentSnapshot.cardCounts, false, false).uniqueCards;
        foundCurrentUser = true;
      }
      return;
    }
    const snapshot = collectionMap[nickname] || emptyCollectionSnapshot_(nickname, false);
    const info = getRaffleTicketInfoFromCardCounts_(snapshot.cardCounts, false, true);
    const activeTickets = ticketSummary.byUser[nickname] || 0;
    stats.totalTickets += activeTickets;
    if (activeTickets > 0) stats.participantCount++;
    if (nickname === cleanUserId) {
      const byCondition = ticketSummary.byUserCondition[nickname] || {};
      stats.myTickets = activeTickets;
      stats.uniqueCards = info.uniqueCards;
      stats.breakdown = {
        tickets: activeTickets,
        uniqueCards: info.uniqueCards,
        signupTicket: byCondition.signup ? 1 : 0,
        card3Ticket: byCondition.card_3 ? 1 : 0,
        card5Ticket: byCondition.card_5 ? 1 : 0,
        card10Ticket: byCondition.card_10 ? 1 : 0,
        attendanceTicket: 0,
      };
      foundCurrentUser = true;
    }
  });

  if (!foundCurrentUser && cleanUserId) {
    if (isUserRaffleExcluded_(cleanUserId)) {
      stats.eligible = false;
      stats.ineligibleReason = 'raffle_excluded';
      stats.fillPercent = getRaffleFillPercent_(stats.totalTickets);
      return stats;
    }
    const snapshot = opts.currentSnapshot || collectionMap[cleanUserId] || emptyCollectionSnapshot_(cleanUserId, false);
    const info = getRaffleTicketInfoFromCardCounts_(snapshot.cardCounts, false, true);
    const byCondition = ticketSummary.byUserCondition[cleanUserId] || {};
    const activeTickets = ticketSummary.byUser[cleanUserId] || 0;
    stats.myTickets = activeTickets;
    stats.uniqueCards = info.uniqueCards;
    stats.breakdown = {
      tickets: activeTickets,
      uniqueCards: info.uniqueCards,
      signupTicket: byCondition.signup ? 1 : 0,
      card3Ticket: byCondition.card_3 ? 1 : 0,
      card5Ticket: byCondition.card_5 ? 1 : 0,
      card10Ticket: byCondition.card_10 ? 1 : 0,
      attendanceTicket: 0,
    };
  }

  stats.fillPercent = getRaffleFillPercent_(stats.totalTickets);
  return stats;
}

