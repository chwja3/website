const NOTICE_FOLDER_NAME = 'BeyondUs_Notices';

// BeyondUs_Notices 폴더만 접근 — 없으면 생성 후 공개 설정
function getNoticeFolder() {
  const iter = DriveApp.getFoldersByName(NOTICE_FOLDER_NAME);
  if (iter.hasNext()) return iter.next();
  const folder = DriveApp.createFolder(NOTICE_FOLDER_NAME);
  folder.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return folder;
}

// DriveApp 권한 승인 확인용 (GAS 에디터에서 직접 실행)
function testDriveAuth() {
  const folder = getNoticeFolder();
  Logger.log('Drive OK — 폴더: ' + folder.getName() + ' / ID: ' + folder.getId());
}

// 이미지 base64 → BeyondUs_Notices 폴더에 업로드 후 공개 URL 반환
function uploadNoticeToDrive(imageBase64, imageMime) {
  const ext = imageMime === 'image/png' ? 'png' : imageMime === 'image/gif' ? 'gif' : 'jpg';
  const filename = 'notice_' + new Date().getTime() + '.' + ext;
  const blob = Utilities.newBlob(Utilities.base64Decode(imageBase64), imageMime, filename);
  const file = getNoticeFolder().createFile(blob);
  return 'https://drive.google.com/thumbnail?id=' + file.getId() + '&sz=w1200';
}

// 여러 이미지 업로드 → URL 배열 반환
function uploadMultipleImages(imageFiles) {
  return imageFiles.map(f => uploadNoticeToDrive(f.base64, f.mime));
}

function getNotices() {
  const cacheKey = cacheKey_('notices_v1');
  const cached = cacheGetJson_(cacheKey);
  if (cached) return cached;

  const sheet = getOrCreateNoticeSheet();
  const last = sheet.getLastRow();
  if (last < SCHEMA.NOTICES.dataStartRow) {
    const emptyResult = { ok: true, notices: [] };
    cachePutJson_(cacheKey, emptyResult, 30);
    return emptyResult;
  }
  const col = getNoticeColumns_(sheet);
  const rows = getNoticeRows_(sheet);
  const notices = rows
    .filter(r => r[col.id])
    .map((r, i) => ({
      rowIndex: i + SCHEMA.NOTICES.dataStartRow,
      id: String(r[col.id]),
      title: r[col.title],
      content: r[col.content],
      createdAt: r[col.createdAt],
      imageUrl: r[col.imageUrl] || '',
      updatedAt: r[col.updatedAt] || r[col.createdAt]
    }))
    .reverse();
  const result = { ok: true, notices };
  cachePutJson_(cacheKey, result, 30);
  return result;
}

function postNotice(body) {
  const title   = String(body.title   || '').trim();
  const content = String(body.content || '').trim();
  if (!title || !content) return { error: 'missing_fields' };

  let imageUrl = String(body.imageUrl || '').trim();
  if (!imageUrl && body.imageFiles && body.imageFiles.length) {
    try {
      const urls = uploadMultipleImages(body.imageFiles);
      imageUrl = JSON.stringify(urls);
    } catch(e) {
      Logger.log('Drive upload error: ' + e);
      return { error: 'drive_upload_failed', detail: String(e) };
    }
  }

  const sheet = getOrCreateNoticeSheet();
  const now = new Date().toISOString();
  sheet.appendRow([new Date().getTime(), title, content, now, imageUrl, now]);
  clearNoticesCache_();
  return { ok: true };
}

function deleteNotice(body) {
  const rowIndex = Number(body.rowIndex);
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  const sheet = getOrCreateNoticeSheet();
  const col = getNoticeColumns_(sheet);
  const imageUrl = String(sheet.getRange(rowIndex, col.imageUrl + 1).getValue() || '');
  sheet.deleteRow(rowIndex);
  deleteDriveImages(imageUrl);
  clearNoticesCache_();
  return { ok: true };
}

function deleteDriveImages(imageUrl) {
  if (!imageUrl) return;
  let urls = [];
  try { const p = JSON.parse(imageUrl); if (Array.isArray(p)) urls = p; } catch(e) {}
  if (!urls.length && imageUrl) urls = [imageUrl];
  urls.forEach(url => {
    const m = url.match(/[?&]id=([a-zA-Z0-9_-]+)/) || url.match(/thumbnail\?id=([a-zA-Z0-9_-]+)/);
    if (!m) return;
    try { DriveApp.getFileById(m[1]).setTrashed(true); } catch(e) { Logger.log('Drive delete error: ' + e); }
  });
}

function editNotice(body) {
  const rowIndex = Number(body.rowIndex);
  const title    = String(body.title   || '').trim();
  const content  = String(body.content || '').trim();
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  if (!title || !content) return { error: 'missing_fields' };
  const sheet = getOrCreateNoticeSheet();
  const col = getNoticeColumns_(sheet);
  sheet.getRange(rowIndex, col.title + 1).setValue(title);
  sheet.getRange(rowIndex, col.content + 1).setValue(content);

  let imageUrl = body.imageUrl !== undefined ? String(body.imageUrl || '').trim() : null;
  if (!imageUrl && body.imageFiles && body.imageFiles.length) {
    try {
      const urls = uploadMultipleImages(body.imageFiles);
      imageUrl = JSON.stringify(urls);
    } catch(e) {
      Logger.log('Drive upload error: ' + e);
      return { error: 'drive_upload_failed', detail: String(e) };
    }
  }
  if (imageUrl !== null) sheet.getRange(rowIndex, col.imageUrl + 1).setValue(imageUrl);
  sheet.getRange(rowIndex, col.updatedAt + 1).setValue(new Date().toISOString());

  clearNoticesCache_();
  return { ok: true };
}

