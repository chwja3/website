function a1Column_(columnNumber) {
  let column = Number(columnNumber) || 1;
  let label = '';
  while (column > 0) {
    const mod = (column - 1) % 26;
    label = String.fromCharCode(65 + mod) + label;
    column = Math.floor((column - mod) / 26);
  }
  return label;
}

function quoteSheetNameForA1_(sheetName) {
  return "'" + String(sheetName || '').replace(/'/g, "''") + "'";
}

function buildA1Range_(sheet, row, column, numRows, numColumns) {
  const startColumn = a1Column_(column);
  const endColumn = a1Column_(column + numColumns - 1);
  return quoteSheetNameForA1_(sheet.getName()) + '!' +
    startColumn + row + ':' + endColumn + (row + numRows - 1);
}

function normalizeSheetValues_(values, width) {
  return (values || []).map(function(row) {
    const normalized = row ? row.slice() : [];
    while (normalized.length < width) normalized.push('');
    return normalized.slice(0, width);
  });
}

function getBatchSheetRows_(requests) {
  const prepared = [];
  const result = {};
  requests.forEach(function(request) {
    result[request.key] = [];
    if (!request.sheet) return;
    const schema = request.schemaOrHeaderRow || request.schema;
    const dataStartRow = typeof schema === 'number'
      ? schema
      : (schema && schema.dataStartRow) || 2;
    const lastRow = request.sheet.getLastRow();
    if (lastRow < dataStartRow) return;
    const width = request.maxColumns || request.sheet.getLastColumn();
    prepared.push({
      key: request.key,
      sheet: request.sheet,
      schema: schema,
      dataStartRow: dataStartRow,
      lastRow: lastRow,
      width: width,
      range: buildA1Range_(request.sheet, dataStartRow, 1, lastRow - dataStartRow + 1, width),
    });
  });

  if (prepared.length && isSheetsValuesApiAvailable_()) {
    try {
      const response = Sheets.Spreadsheets.Values.batchGet(getSpreadsheetId_(), {
        ranges: prepared.map(function(item) { return item.range; }),
        valueRenderOption: 'UNFORMATTED_VALUE',
        dateTimeRenderOption: 'FORMATTED_STRING',
      });
      const valueRanges = response.valueRanges || [];
      prepared.forEach(function(item, index) {
        result[item.key] = normalizeSheetValues_((valueRanges[index] && valueRanges[index].values) || [], item.width);
      });
      return result;
    } catch(e) {
      Logger.log('Sheets batchGet fallback: ' + e);
    }
  }

  prepared.forEach(function(item) {
    result[item.key] = getSheetRows(item.sheet, item.schema, item.width);
  });
  return result;
}

function setSheetValues_(sheet, row, column, values) {
  if (!values || !values.length) return { ok: true, rows: 0 };
  const width = values.reduce(function(max, valueRow) {
    return Math.max(max, valueRow ? valueRow.length : 0);
  }, 0);
  if (width <= 0) return { ok: true, rows: values.length };
  const normalized = normalizeSheetValues_(values, width);

  if (isSheetsValuesApiAvailable_()) {
    try {
      Sheets.Spreadsheets.Values.batchUpdate({
        valueInputOption: 'RAW',
        data: [{
          range: buildA1Range_(sheet, row, column, normalized.length, width),
          values: normalized,
        }],
      }, getSpreadsheetId_());
      return { ok: true, rows: normalized.length, api: 'sheets_v4' };
    } catch(e) {
      Logger.log('Sheets batchUpdate fallback: ' + e);
    }
  }

  sheet.getRange(row, column, normalized.length, width).setValues(normalized);
  return { ok: true, rows: normalized.length, api: 'spreadsheet_app' };
}

function clearSheetValues_(sheet, row, column, numRows, numColumns) {
  if (numRows <= 0 || numColumns <= 0) return { ok: true, rows: 0 };
  if (isSheetsValuesApiAvailable_()) {
    try {
      Sheets.Spreadsheets.Values.batchClear({
        ranges: [buildA1Range_(sheet, row, column, numRows, numColumns)],
      }, getSpreadsheetId_());
      return { ok: true, rows: numRows, api: 'sheets_v4' };
    } catch(e) {
      Logger.log('Sheets batchClear fallback: ' + e);
    }
  }
  sheet.getRange(row, column, numRows, numColumns).clearContent();
  return { ok: true, rows: numRows, api: 'spreadsheet_app' };
}

function ensureTwoHeaderSheet_(sheet, schema, labels, colCount) {
  if (sheet.getMaxColumns() < colCount) {
    sheet.insertColumnsAfter(sheet.getMaxColumns(), colCount - sheet.getMaxColumns());
  }
  if (sheet.getMaxRows() < schema.headerRow) {
    sheet.insertRowsAfter(sheet.getMaxRows(), schema.headerRow - sheet.getMaxRows());
  }
  sheet.getRange(1, 1, 1, colCount).setValues([labels.slice()]);
  sheet.getRange(schema.headerRow, 1, 1, colCount).setValues([getSchemaHeaders_(schema)]);
  sheet.setFrozenRows(2);
}

function clearSheetDataRows_(sheet, schema, colCount) {
  const lastRow = sheet.getLastRow();
  if (lastRow < schema.dataStartRow) return;
  sheet.getRange(schema.dataStartRow, 1, lastRow - schema.dataStartRow + 1, colCount).clearContent();
}

