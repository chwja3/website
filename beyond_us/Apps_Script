function getColumns(sheet, schemaOrHeaderRow) {
  const headerRow = typeof schemaOrHeaderRow === 'number'
    ? schemaOrHeaderRow
    : (schemaOrHeaderRow && schemaOrHeaderRow.headerRow) || 1;
  const headers = sheet.getRange(headerRow, 1, 1, Math.max(sheet.getLastColumn(), 1)).getValues()[0];
  const map = {};
  headers.forEach(function(header, index) {
    const key = String(header || '').trim();
    if (key) map[key] = index;
  });
  return map;
}

function getResolvedColumns_(sheet, schema, fallback) {
  const byHeader = getColumns(sheet, schema);
  const columns = {};
  Object.keys(schema.columns).forEach(function(key) {
    const header = schema.columns[key];
    columns[key] = Object.prototype.hasOwnProperty.call(byHeader, header) ? byHeader[header] : fallback[key];
  });
  return columns;
}

function getSchemaHeaders_(schema) {
  return Object.keys(schema.columns).map(function(key) {
    return schema.columns[key];
  });
}

