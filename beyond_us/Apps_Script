function revokeIneligibleRaffleTickets_(dryRun) {
  const sheet = getOrCreateRaffleTicketsSheet_();
  const last = sheet.getLastRow();
  if (last < 2) return { ok: true, dryRun: !!dryRun, planned: 0, revoked: 0, rows: [] };

  const range = sheet.getRange(2, 1, last - 1, RAFFLE_TICKET_COLUMNS.length);
  const values = range.getValues();
  const excludedMap = getRaffleExcludedUserMap_();
  const now = new Date().toISOString();
  const planned = [];
  const affectedUsers = {};

  values.forEach(function(row, idx) {
    if (!isActiveRaffleTicketRow_(row)) return;
    const userId = String(row[RAFFLE_TICKET_COL.userId] || '').trim();
    if (!userId) return;
    if (excludedMap[userId] !== true) return;

    planned.push({
      rowNumber: idx + 2,
      ticket_no: padTicketNo_(row[RAFFLE_TICKET_COL.ticketNo]),
      userId: userId,
      parish: String(row[RAFFLE_TICKET_COL.parish] || '').trim(),
      condition: String(row[RAFFLE_TICKET_COL.condition] || '').trim(),
    });
    if (!dryRun) {
      releaseRaffleTicketRow_(row, now);
      affectedUsers[userId] = true;
    }
  });

  if (!dryRun && planned.length) {
    range.setValues(values);
    Object.keys(affectedUsers).forEach(function(userId) {
      clearUserDerivedCaches_(userId);
    });
  }

  return {
    ok: true,
    dryRun: !!dryRun,
    planned: planned.length,
    revoked: dryRun ? 0 : planned.length,
    affectedUsers: Object.keys(affectedUsers),
    rows: planned,
  };
}

