    });
}

function getMissionConfigFromDefinitions_(week) {
  if (week < 1 || week > 6) return null;
  const infos = getMissionDefinitionRowInfos_(week);
  if (!infos.length) return null;
  const col = getMissionDefinitionsColumns_(getSpreadsheet().getSheetByName(SHEET_NAMES.MISSION_DEFINITIONS));
  const first = infos[0].row;
  const title = String(first[col.weekTitle] || (week + 'ņŻ╝ņ░©')).trim();
  const threshold = Number(first[col.drawThreshold]) || 6;
  const byItemNo = {};
  infos.forEach(function(info) {
    const itemNo = Number(info.row[col.itemNo]) || 0;
    if (itemNo >= 1 && itemNo <= CONFIG_LAYOUT.missionRowsPerWeek && !byItemNo[itemNo]) byItemNo[itemNo] = info;
  });
  const items = [];
  for (let itemNo = 1; itemNo <= CONFIG_LAYOUT.missionRowsPerWeek; itemNo++) {
    const info = byItemNo[itemNo];
    if (!info) {
      items.push({ item: '', score: 1, cat: 'L', enabled: false });
      continue;
    }
    const row = info.row;
    const itemText = String(row[col.itemText] || '').trim();
    const enabledCell = row[col.enabled];
    const enabled = enabledCell === '' ? itemText !== '' : isTruthyEventValue_(enabledCell);
    items.push({
      item: itemText,
      score: Number(row[col.scoreWeight]) || 1,
      cat: String(row[col.category] || 'L').trim(),
      enabled: enabled,
    });
  }
  return { ok: true, week: week, title: title, threshold: threshold, items: items };
}

