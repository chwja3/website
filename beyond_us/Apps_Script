function setupAllWeeks() {
  const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);

  // 헤더 세팅 (첫 실행 시)
  sheet.getRange('A1').setValue('current_week');
  if (!sheet.getRange('B1').getValue()) sheet.getRange('B1').setValue(1);
  // B2(prayer), B3(secret) 기존 값 유지 — 건드리지 않음

  // 기존 주차 데이터 영역 초기화
  sheet.getRange('A5:C200').clearContent();

  ALL_WEEK_DATA.forEach((w, i) => {
    const startRow = i * 8 + 5;
    sheet.getRange(startRow, 2).setValue(w.title);
    sheet.getRange(startRow, 3).setValue(w.threshold);
    w.items.forEach(([item, score, cat], j) => {
      sheet.getRange(startRow + 1 + j, 1).setValue(item);
      sheet.getRange(startRow + 1 + j, 2).setValue(score);
      sheet.getRange(startRow + 1 + j, 3).setValue(cat || 'L');
    });
  });

  Logger.log('전체 주차 세팅 완료');
}

// ── 미션 config 읽기/쓰기 ─────────────────────────
function getMissionConfig(week) {
  if (week < 1 || week > 6) return { error: 'invalid_week' };
  const sheet    = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const startRow = (week - 1) * 8 + 5;
  const title     = sheet.getRange(startRow, 2).getValue();
  const threshold = Number(sheet.getRange(startRow, 3).getValue()) || 6;
  const rawItems  = sheet.getRange(startRow + 1, 1, 6, 3).getValues();
  const items = rawItems.map(([item, score, cat]) => ({ item: String(item || ''), score: Number(score) || 1, cat: String(cat || 'L') }));
  return { ok: true, week, title, threshold, items };
}

function setMissionConfig(body) {
  const week = Number(body.week);
  if (!week || week < 1 || week > 6) return { error: 'invalid_week' };
  const sheet    = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const startRow = (week - 1) * 8 + 5;
  sheet.getRange(startRow, 2).setValue(String(body.title || ''));
  sheet.getRange(startRow, 3).setValue(Number(body.threshold) || 6);
  const items = Array.isArray(body.items) ? body.items : [];
  for (let i = 0; i < 6; i++) {
    const it = items[i] || {};
    if (!String(it.item || '').trim()) continue; // 빈 항목은 기존 값 유지
    sheet.getRange(startRow + 1 + i, 1).setValue(String(it.item));
    sheet.getRange(startRow + 1 + i, 2).setValue(Number(it.score) || 1);
    sheet.getRange(startRow + 1 + i, 3).setValue(String(it.cat || 'L'));
  }
  return { ok: true };
}

// ── 문의하기 ──────────────────────────────────────
function getOrCreateInquirySheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName('Inquiries');
  if (!sheet) {
    sheet = ss.insertSheet('Inquiries');
    sheet.appendRow(['id','nickname','content','createdAt','reply','repliedAt']);
  }
  return sheet;
}

function verifyUserPassword(nickname, password) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname && String(data[i][1]).trim() === password) return true;
  }
  return false;
}

function getInquiries() {
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { ok: true, inquiries: [] };
  const rows = sheet.getRange(2, 1, last - 1, 6).getValues();
  const inquiries = rows
    .filter(r => r[0])
    .map((r, i) => ({
      rowIndex:  i + 2,
      id:        String(r[0]),
      nickname:  String(r[1]),
      content:   String(r[2]),
      createdAt: r[3],
      reply:     String(r[4] || ''),
      repliedAt: r[5] || ''
    }))
    .reverse();
  return { ok: true, inquiries };
}

function postInquiry(body) {
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const content  = String(body.content  || '').trim();
  if (!nickname || !password || !content) return { error: 'missing_fields' };
  if (!verifyUserPassword(nickname, password)) return { error: 'wrong_password' };
  const sheet = getOrCreateInquirySheet();
  sheet.appendRow([new Date().getTime(), nickname, content, new Date().toISOString(), '', '']);
  return { ok: true };
}

function editInquiry(body) {
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const id       = String(body.id       || '');
  const content  = String(body.content  || '').trim();
  if (!nickname || !password || !id || !content) return { error: 'missing_fields' };
  if (!verifyUserPassword(nickname, password)) return { error: 'wrong_password' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 2).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === id && String(rows[i][1]).trim() === nickname) {
      sheet.getRange(i + 2, 3).setValue(content);
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

function deleteInquiry(body) {
  const id = String(body.id || '');
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 2).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) !== id) continue;
    if (body.adminPw === ADMIN_PASSWORD) {
      sheet.deleteRow(i + 2);
      return { ok: true };
    }
    const nickname = String(body.nickname || '').trim();
    const password = String(body.password || '').trim();
    if (String(rows[i][1]).trim() === nickname && verifyUserPassword(nickname, password)) {
      sheet.deleteRow(i + 2);
      return { ok: true };
    }
    return { error: 'unauthorized' };
  }
  return { error: 'not_found' };
}

function replyInquiry(body) {
  if (body.adminPw !== ADMIN_PASSWORD) return { error: 'unauthorized' };
  const id    = String(body.id    || '');
  const reply = String(body.reply || '').trim();
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 1).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === id) {
      sheet.getRange(i + 2, 5).setValue(reply);
      sheet.getRange(i + 2, 6).setValue(reply ? new Date().toISOString() : '');
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

