}

function editInquiry(body) {
  const nickname = String(body.nickname || '').trim();
  const id       = String(body.id       || '');
  const content  = String(body.content  || '').trim();
  if (!nickname || !id || !content) return { error: 'missing_fields' };
  if (!hasValidUserAuth_(body, nickname)) return { error: 'unauthorized', authRequired: true };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < SCHEMA.INQUIRIES.dataStartRow) return { error: 'not_found' };
  const col = getInquiryColumns_(sheet);
  const rows = getInquiryRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.id]) === id && String(rows[i][col.nickname]).trim() === nickname) {
      sheet.getRange(i + SCHEMA.INQUIRIES.dataStartRow, col.content + 1).setValue(content);
      return { ok: true };
    }
