      const collectionCol = getCollectionColumns_(collectionSheet);
      getCollectionRows_(collectionSheet).forEach(function(row) {
        const userId = String(row[collectionCol.userId] || '').trim();
        if (userId) ids[userId] = true;
      });
    }
  }

  events.forEach(function(event) {
    const userId = String(event.userId || '').trim();
    if (userId) ids[userId] = true;
    if (event.type === EVENT_TYPES.TRADE_REQUESTED) {
      const target = String((event.payload && event.payload.target) || '').trim();
      if (target) ids[target] = true;
    }
