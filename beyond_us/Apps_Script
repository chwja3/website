}

function setRequiredScriptProperties(properties) {
  const keys = REQUIRED_SCRIPT_PROPERTY_KEYS.slice();
  const clean = {};

  keys.forEach(function(key) {
    const value = properties && properties[key];
    if (value !== null && value !== undefined && String(value).trim() !== '') {
      clean[key] = String(value).trim();
    }
  });

  const missing = keys.filter(function(key) {
    return !clean[key];
  });
  if (missing.length) throw new Error('Missing script properties: ' + missing.join(', '));

  const allowTestDraws = properties && properties[SCRIPT_PROPERTY_KEYS.ALLOW_TEST_DRAWS];
  if (allowTestDraws !== null && allowTestDraws !== undefined && String(allowTestDraws).trim() !== '') {
    clean[SCRIPT_PROPERTY_KEYS.ALLOW_TEST_DRAWS] = String(allowTestDraws).trim();
  }
  const enableTestAdminTools = properties && properties[SCRIPT_PROPERTY_KEYS.ENABLE_TEST_ADMIN_TOOLS];
  if (enableTestAdminTools !== null && enableTestAdminTools !== undefined && String(enableTestAdminTools).trim() !== '') {
    clean[SCRIPT_PROPERTY_KEYS.ENABLE_TEST_ADMIN_TOOLS] = String(enableTestAdminTools).trim();
  }

  PropertiesService.getScriptProperties().setProperties(clean, false);
  return { ok: true, keys: keys };
}

function getScriptPropertiesStatus() {
  const props = PropertiesService.getScriptProperties();
