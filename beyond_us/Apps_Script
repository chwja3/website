function verifyUserPassword(nickname, password) {
  const sheet = getUsersSheet_();
  const col   = getUserColumns_(sheet);
  const data  = getUserRows_(sheet);
  for (let i = 0; i < data.length; i++) {
    if (String(data[i][col.nickname]).trim() === nickname) {
      return verifyStoredPassword_(String(data[i][col.password] || '').trim(), password);
    }
  }
  return false;
}

function auditUserPasswordStorage_() {
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  const result = {
    ok: true,
    totalUsers: 0,
    hashed: 0,
    plaintext: 0,
    empty: 0,
    plaintextUsers: [],
    passwordPepperExists: !!getOptionalScriptProperty_(SCRIPT_PROPERTY_KEYS.PASSWORD_PEPPER),
  };

  rows.forEach(function(row) {
    const nickname = String(row[col.nickname] || '').trim();
    if (!nickname) return;
    result.totalUsers++;
    const stored = String(row[col.password] || '').trim();
    if (!stored) {
      result.empty++;
    } else if (isPasswordHash_(stored)) {
      result.hashed++;
    } else {
      result.plaintext++;
      if (result.plaintextUsers.length < 20) result.plaintextUsers.push(nickname);
    }
  });
  result.ok = result.plaintext === 0 && result.empty === 0;
  return result;
}

function migrateUserPasswordsToHash_(dryRun) {
  const sheet = getUsersSheet_();
  const schema = SCHEMA.USERS;
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  const result = auditUserPasswordStorage_();
  result.dryRun = dryRun === true;
  result.migratedPlanned = 0;
  result.migratedWritten = 0;
  result.skipped = 0;

  rows.forEach(function(row, index) {
    const nickname = String(row[col.nickname] || '').trim();
    if (!nickname) return;
    const stored = String(row[col.password] || '').trim();
    if (!stored || isPasswordHash_(stored)) {
      result.skipped++;
      return;
    }
    result.migratedPlanned++;
    if (!dryRun) {
      const rowIndex = index + schema.dataStartRow;
      setUserPassword_(sheet, rowIndex, stored);
      result.migratedWritten++;
    }
  });

  if (!dryRun) {
    const after = auditUserPasswordStorage_();
    result.after = after;
    result.ok = after.ok;
  }
  return result;
}

