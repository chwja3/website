/**
 * Column HņØś sessionToken ņģĆņØä ĒåĀĒü░ ļ¼Ėņ×ÉņŚ┤ ļ░░ņŚ┤ļĪ£ Ēīīņŗ▒.
 * ņŗĀĻĘ£ ĒÅ¼ļ¦Ę: JSON ļ░░ņŚ┤ ["tokA","tokB",...]
 * ĻĄ¼ļ▓äņĀä ĒÅ¼ļ¦Ę: ļŗ©ņØ╝ ļ¼Ėņ×ÉņŚ┤ ŌåÆ [ļŗ©ņØ╝ļ¼Ėņ×ÉņŚ┤] ļĪ£ ņ×ÉļÅÖ wrap (backward compat)
 */
function parseTokenArray_(cellValue) {
  const raw = String(cellValue || '').trim();
  if (!raw) return [];
  if (raw.charAt(0) === '[') {
    try {
      const arr = JSON.parse(raw);
      if (Array.isArray(arr)) return arr.filter(function(t) { return typeof t === 'string' && t.length > 0; });
    } catch(e) { /* fall through to single-string handling */ }
  }
  return [raw]; // ĻĄ¼ļ▓äņĀä ļŗ©ņØ╝ ĒåĀĒü░ ĒśĖĒÖś
}

function serializeTokenArray_(arr) {
  if (!Array.isArray(arr) || arr.length === 0) return '';
  return JSON.stringify(arr);
}

const MAX_TOKENS_PER_USER = 10;

function issueSessionToken_(sheet, rowIndex) {
  ensureUserSessionColumns_(sheet);
  const col = getUserColumns_(sheet);
  const existing = sheet.getRange(rowIndex, col.sessionToken + 1).getValue();
  const tokens = parseTokenArray_(existing);
  const newToken = makeSessionToken_();
  tokens.push(newToken);
  // Ļ░Ćņ×ź ņśżļ×śļÉ£ Ļ▓āļČĆĒä░ evict, ņĄ£ņŗĀ MAX_TOKENS_PER_USER Ļ░£ ņ£Āņ¦Ć
  const trimmed = tokens.length > MAX_TOKENS_PER_USER
    ? tokens.slice(tokens.length - MAX_TOKENS_PER_USER)
    : tokens;
  sheet.getRange(rowIndex, col.sessionToken + 1).setValue(serializeTokenArray_(trimmed));
  sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).setValue(new Date().toISOString());
  return newToken;
}

