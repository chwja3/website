function collectTradeEvents_(ss, eventRows, sourceRows) {
  const ctx = getMigrationSheetContext_(ss, SHEET_NAMES.TRADES, getTradesColumns_, getTradesRows_, 12);
  let converted = 0;
  if (ctx) {
    ctx.rows.forEach(function(row) {
      const tradeId = String(row[ctx.col.id] || '').trim();
      if (!tradeId) return;
      converted++;
      const requester = String(row[ctx.col.requester] || '').trim();
      const target = String(row[ctx.col.target] || '').trim();
      const status = String(row[ctx.col.status] || '').trim();
      pushMigrationEvent_(eventRows, EVENT_TYPES.TRADE_REQUESTED, requester, {
        timestamp: row[ctx.col.createdAt],
        refId: tradeId,
        payload: {
          target: target,
          requesterCardId: Number(row[ctx.col.requesterCardId]) || '',
          requesterCardName: String(row[ctx.col.requesterCardName] || ''),
          targetCardId: Number(row[ctx.col.targetCardId]) || '',
          targetCardName: String(row[ctx.col.targetCardName] || ''),
        },
      });

      const terminalType = eventTradeTerminalType_(status);
      if (terminalType && nonEmptyValue_(row[ctx.col.resolvedAt])) {
        pushMigrationEvent_(eventRows, terminalType, requester, {
          timestamp: row[ctx.col.resolvedAt],
          refId: tradeId,
          payload: {
            target: target,
            status: status,
          },
        });
      }
      if (nonEmptyValue_(row[ctx.col.requesterPrayed])) {
        pushMigrationEvent_(eventRows, EVENT_TYPES.TRADE_PRAYED, requester, {
          timestamp: row[ctx.col.requesterPrayed],
          refId: tradeId,
          payload: { side: 'requester' },
        });
