// ── GET ──────────────────────────────────────────
function doGet(e) {
  _devMode = (e && e.parameter && e.parameter.devMode === 'true');
  const action = (e && e.parameter && e.parameter.action) || 'dashboard';

  if (action === 'dashboard') return jsonOutput(getDashboardData());
  if (action === 'userStatus') {
    const userId  = e.parameter.userId  || '';
    const weekKey = e.parameter.weekKey || '';
    return jsonOutput(getUserStatus(userId, weekKey));
  }
  if (action === 'getUsers') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getUsers());
  }
  if (action === 'getTabSettings') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getTabSettings());
  }
  if (action === 'getNotices') return jsonOutput(getNotices());
  if (action === 'getInquiries') return jsonOutput(getInquiries());
  if (action === 'findNickname') {
    const name   = e.parameter.name   || '';
    const parish = e.parameter.parish || '';
    return jsonOutput(findNickname(name, parish));
  }
  if (action === 'getHoldPray') return jsonOutput(getHoldPray(e.parameter.weekKey || '', e.parameter.nickname || ''));
  if (action === 'getCurrentWeek') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    const sheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
    return jsonOutput({ ok: true, week: Number(sheet.getRange('B1').getValue()) || 1 });
  }
  if (action === 'getMissionConfig') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getMissionConfig(Number(e.parameter.week) || 1));
  }
  if (action === 'getCardStats') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getCardStats());
  }
  if (action === 'getTicketStats') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getTicketStats());
  }
  if (action === 'getPublicCollection') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput({ ok: true, collection: getUserCollection(uid) });
  }
  if (action === 'getTrades') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getTrades(uid));
  }
  if (action === 'getAdminTrades') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(getAdminTrades());
  }
  if (action === 'migrateCardDrawsToCollection') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(migrateCardDrawsToCollection());
  }
  if (action === 'getBBB') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getBBB(uid));
  }
  if (action === 'getBBBMessages') {
    const uid = e.parameter.userId || '';
    if (!uid) return jsonOutput({ error: 'missing_userId' });
    return jsonOutput(getBBBMessages(uid));
  }
  if (action === 'adminGetBBB') {
    if ((e.parameter.adminPw || '') !== ADMIN_PASSWORD) return jsonOutput({ error: 'unauthorized' });
    return jsonOutput(adminGetBBB());
  }

  return jsonOutput({ ok: false, message: 'Unknown action' });
}

