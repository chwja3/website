function findCollectionRowIndex_(sheet, col, userId) {
  const last = sheet.getLastRow();
  if (last < SCHEMA.COLLECTION.dataStartRow) return -1;
  const ids = sheet.getRange(SCHEMA.COLLECTION.dataStartRow, col.userId + 1, last - SCHEMA.COLLECTION.dataStartRow + 1, 1).getValues();
  for (let i = 0; i < ids.length; i++) {
    if (String(ids[i][0] || '').trim() === userId) return i + SCHEMA.COLLECTION.dataStartRow;
  }
  return -1;
}

function collectionSnapshotToRow_(snapshot, col) {
  const row = new Array(COLLECTION_COL_COUNT).fill(0);
  row[col.userId] = snapshot.userId;
  row[col.totalEarned] = Number(snapshot.totalEarned) || 0;
  row[col.totalDrawn] = Number(snapshot.totalDrawn) || 0;
  row[col.remaining] = Number(snapshot.remaining) || 0;
  for (let cardId = 1; cardId <= 9; cardId++) {
    row[col['card' + cardId]] = Number(snapshot.cardCounts[cardId]) || 0;
  }
  row[col.totalCards] = Number(snapshot.totalCards) || 0;
  row[col.hidden] = Number(snapshot.cardCounts[10]) || 0;
  return row;
}

