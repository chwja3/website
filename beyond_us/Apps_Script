// 이미지 base64 → Google Drive 업로드 후 공개 URL 반환
function uploadNoticeToDrive(imageBase64, imageMime) {
  try {
    const ext = imageMime === 'image/png' ? 'png' : imageMime === 'image/gif' ? 'gif' : 'jpg';
    const filename = 'notice_' + new Date().getTime() + '.' + ext;
    const blob = Utilities.newBlob(Utilities.base64Decode(imageBase64), imageMime, filename);
    const file = DriveApp.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    return 'https://drive.google.com/thumbnail?id=' + file.getId() + '&sz=w1200';
  } catch(e) {
    Logger.log('Drive upload error: ' + e);
    return '';
  }
}

