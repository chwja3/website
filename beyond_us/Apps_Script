function getUserStatusCached_(userId, weekKey) {
  const cleanUserId = String(userId || '').trim();
  const config = getConfig();
  const cleanWeekKey = String(weekKey || ('w' + config.currentWeek)).trim();
  if (!cleanUserId) return getUserStatus(cleanUserId, cleanWeekKey, config);
  const key = cacheKey_('user_status_v1', cleanUserId + ':' + cleanWeekKey);
  const cached = cacheGetJson_(key);
  if (cached) return cached;
  const data = getUserStatus(cleanUserId, cleanWeekKey, config);
  cachePutJson_(key, data, 10);
  return data;
}

function getUserStatus(userId, weekKey, configOverride) {
  const config = configOverride || getConfig();
  weekKey = String(weekKey || ('w' + config.currentWeek)).trim();
  let weekScore = 0, drawnThisWeek = false, weekCard = null;
  const collection = [];
  const todayItems   = [];
  const todayIndices = [];
  const weekDates    = [];

  const today = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 이번 주 월~일 범위 계산 (KST)
  const nowKST = new Date(new Date().getTime() + 9 * 60 * 60 * 1000);
  const dow = nowKST.getUTCDay() || 7;
  const monday = new Date(nowKST);
  monday.setUTCDate(nowKST.getUTCDate() - (dow - 1));
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  const weekStart = monday.toISOString().slice(0, 10);
  const weekEnd   = sunday.toISOString().slice(0, 10);

  const userEvents = Events_readByUser(userId);
  const submittedEvents = getMissionSubmittedEventsForConfig_(userEvents, config, weekKey);
  let earnedTicketThisWeek = false;
  submittedEvents.forEach(function(event) {
    weekScore += getMissionEventScore_(event);
    const rowDate = getMissionEventDateKey_(event);
    if (rowDate >= weekStart && rowDate <= weekEnd && !weekDates.includes(rowDate)) {
      weekDates.push(rowDate);
    }
    if (rowDate === today) {
      getMissionEventItems_(event).forEach(function(item) {
        todayItems.push(item);
        // 인덱스 미저장 구 데이터: 현재 config 텍스트와 매칭해 인덱스 역추적
        const idx = config.items.indexOf(item);
        if (idx >= 0) todayIndices.push(idx);
      });
      getMissionEventIndices_(event).forEach(function(idx) {
        if (typeof idx === 'number') todayIndices.push(idx);
      });
    }
  });
  userEvents.forEach(function(event) {
    if (event.type !== EVENT_TYPES.TICKET_GRANTED) return;
    if (String(event.weekKey || '') !== String(weekKey || '')) return;
    if (String((event.payload && event.payload.reason) || '') === 'week_complete') {
      earnedTicketThisWeek = true;
    }
  });

  // 카드 뽑기 이력 (drawnThisWeek, weekCard)
  try {
    if (userEvents.length) {
      for (const event of userEvents) {
        if (event.type !== EVENT_TYPES.CARD_DRAWN) continue;
        if (String(event.weekKey) !== weekKey) continue;
        const card = SPIRIT_CARDS.find(c => c.id === Number(event.refId));
        if (!card) continue;
        drawnThisWeek = true;
        weekCard = card;
      }
    }
  } catch(e) {}

  let pendingDraws = 0;
  try {
    const snapshot = getCurrentCollectionSnapshot_(String(userId || '').trim());
    pendingDraws = Number(snapshot.remaining) || 0;
    SPIRIT_CARDS.forEach(card => {
      const cnt = Number(snapshot.cardCounts[card.id]) || 0;
      for (let j = 0; j < cnt; j++) collection.push({...card});
    });
  } catch(e) {}

  return {
    ok: true,
    weekScore,
    drawThreshold: config.drawThreshold,
    canDraw: pendingDraws > 0,
    pendingDraws,
    earnedTicketThisWeek,
    drawnThisWeek,
    weekCard,
    collection,
    todayItems,
    todayIndices,
    weekDates
  };
}

function drawCard(userId, weekKey, testMode, requestId) {
  if (!userId) return { ok: false, error: '닉네임이 없습니다.' };
  const cleanRequestId = String(requestId || '').replace(/[^A-Za-z0-9_-]/g, '').slice(0, 80);
  const requestCacheKey = cleanRequestId ? 'drawCard__' + hashStr(userId + '\x00' + weekKey + '\x00' + cleanRequestId) : '';

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    if (requestCacheKey) {
      const cached = CacheService.getScriptCache().get(requestCacheKey);
      if (cached) {
        try { return JSON.parse(cached); } catch(e) {}
      }
    }
    weekKey = String(weekKey || ('w' + getCurrentWeek_())).trim();

    const bypassTicketCheck = testMode === true && isTestDrawAllowed_();
    if (!bypassTicketCheck) {
      const pendingDraws = getCollectionTickets(userId).remaining;
      if (pendingDraws <= 0) {
        const noTicketResult = { ok: false, error: '사용 가능한 뽑기권이 없습니다.' };
        if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(noTicketResult), 600);
        return noTicketResult;
      }
    }

    const drawableCards = SPIRIT_CARDS.filter(function(c) { return c.id !== 10; });
    const card = drawableCards[Math.floor(Math.random() * drawableCards.length)];

    // 뽑기 전 기존 보유 여부 확인 (isNew 계산용)
    let isNew = true;
    try {
      const existingCounts = getUserCollection(userId);
      isNew = !(existingCounts[card.id] > 0);
    } catch(e) {}

    const drawnAt = new Date().toISOString();
    // ticket.consumed + card.drawn 두 이벤트를 setValues 1회로 묶음 (RPC 2 → 1)
    Events_appendBatch_([
      {
        type: EVENT_TYPES.TICKET_CONSUMED,
        userId: userId,
        options: {
          timestamp: drawnAt,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'card_draw', testMode: bypassTicketCheck },
          source: EVENT_SOURCES.WEB,
        },
      },
      {
        type: EVENT_TYPES.CARD_DRAWN,
        userId: userId,
        options: {
          timestamp: drawnAt,
          timestampOffsetMs: 1,
          amount: 1,
          weekKey: weekKey,
          refId: card.id,
          payload: { cardName: card.name, isNew: isNew },
          source: EVENT_SOURCES.WEB,
        },
      },
    ]);
    // rebuild 결과의 projection snapshot을 그대로 응답에 사용 — Collection 시트 재조회 2회 제거
    const rebuildResult = rebuildCollectionRow_(userId);
    const response = collectionResponseFromSnapshot_(rebuildResult && rebuildResult.projected);
    const result = {
      ok: true,
      card,
      isNew,
      collection: response.collection,
      tickets: response.tickets
    };
    if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(result), 600);
    return result;
  } finally {
    lock.releaseLock();
  }
}

