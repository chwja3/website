function phase2EStressTestDraws_(body) {
  const userId = String(body.userId || body.nickname || '').trim();
  const count = Math.min(Math.max(Number(body.count) || 3, 1), 10);
  const weekKey = String(body.weekKey || ('w' + getCurrentWeek_())).trim();
  if (!userId) return { ok: false, error: 'missing_userId' };
  if (!isTestAdminToolsEnabled_()) return { ok: false, error: 'test_admin_tools_disabled' };
  if (!isTestDrawAllowed_()) return { ok: false, error: 'test_draws_disabled' };

  const started = new Date().getTime();
  const results = [];
  for (let i = 0; i < count; i++) {
    const requestId = 'phase2e_stress_' + started + '_' + i;
    const drawStarted = new Date().getTime();
    const result = drawCard(userId, weekKey, true, requestId);
    results.push({
      index: i + 1,
      ok: result && result.ok === true,
      error: result && result.error,
      elapsedMs: new Date().getTime() - drawStarted,
      cardId: result && result.card && result.card.id,
    });
    if (!result || result.ok !== true) break;
  }

  const health = phase2EHealthCheck_({ userId: userId });
  return {
    ok: results.every(function(result) { return result.ok; }) && health.ok,
    userId: userId,
    weekKey: weekKey,
    requestedCount: count,
    completedCount: results.filter(function(result) { return result.ok; }).length,
    elapsedMs: new Date().getTime() - started,
    results: results,
    tickets: getCollectionTickets(userId),
    projectionMismatchCount: health.projection.mismatchCount,
  };
}

