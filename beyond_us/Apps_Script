// CardReceived 컬럼: nickname(A) | cardId(B) | receivedQty(C) | updatedAt(D)
function getOrCreateCardReceivedSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName('CardReceived');
  if (!sheet) {
    sheet = ss.insertSheet('CardReceived');
    sheet.appendRow(['nickname', 'cardId', 'receivedQty', 'updatedAt']);
    sheet.setFrozenRows(1);
  } else {
    // 구버전 헤더(2열) → 4열로 자동 수정
    const lastCol = sheet.getLastColumn();
    const headerRow = lastCol > 0 ? sheet.getRange(1, 1, 1, lastCol).getValues()[0] : [];
    if (lastCol < 4 || headerRow[1] !== 'cardId') {
      sheet.getRange(1, 1, 1, 4).setValues([['nickname', 'cardId', 'receivedQty', 'updatedAt']]);
    }
  }
  return sheet;
}

// 수령 수량 upsert (nickname + cardId 기준)
function setCardReceivedQty(body) {
  var nickname = String(body.nickname || '');
  var cardId   = Number(body.cardId);
  var qty      = Number(body.qty);
  if (!nickname || !cardId || isNaN(qty) || qty < 0) return { error: 'invalid_params' };
  var sheet = getOrCreateCardReceivedSheet();
  var last = sheet.getLastRow();
  if (last >= 2) {
    var rows = sheet.getRange(2, 1, last - 1, 2).getValues();
    for (var i = 0; i < rows.length; i++) {
      if (String(rows[i][0]) === nickname && Number(rows[i][1]) === cardId) {
        sheet.getRange(i + 2, 3, 1, 2).setValues([[qty, new Date()]]);
        return { ok: true };
      }
    }
  }
  sheet.appendRow([nickname, cardId, qty, new Date()]);
  return { ok: true };
}

function setDrawReceived(body) {
  var rowIndex = Number(body.rowIndex);
  var received = body.received !== false;
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  var sheet = getOrCreateDrawSheet();
  sheet.getRange(rowIndex, 6).setValue(received ? 'TRUE' : '');
  return { ok: true };
}

function getCardStats() {
  var ss = getSpreadsheet();
  var CARD_NAMES = ['사랑','희락','화평','오래참음','자비','양선','충성','온유','절제'];

  // 1. CardDraws → 카드별 총 뽑기 횟수(상단 그리드) + 유저별 뽑기 횟수
  var cardCounts = {};
  var totalDraws = 0;
  var userDrawMap = {}; // nickname → { cardId: count }
  SPIRIT_CARDS.forEach(function(c) { cardCounts[c.id] = 0; });
  try {
    var drawSheet = getOrCreateDrawSheet();
    var drawLast = drawSheet.getLastRow();
    if (drawLast >= 2) {
      var drawRows = drawSheet.getRange(2, 1, drawLast - 1, 3).getValues();
      drawRows.forEach(function(row) {
        var nick = String(row[0]);
        var cid  = Number(row[2]);
        if (!nick || !cid) return;
        cardCounts[cid] = (cardCounts[cid] || 0) + 1;
        totalDraws++;
        if (!userDrawMap[nick]) userDrawMap[nick] = {};
        userDrawMap[nick][cid] = (userDrawMap[nick][cid] || 0) + 1;
      });
    }
  } catch(e) {}

  // 2. CardReceived → 카드별 총 수령 수 + 유저별 수령 맵
  var receivedCounts = {};
  var userReceivedMap = {}; // nickname → { cardId: qty }
  SPIRIT_CARDS.forEach(function(c) { receivedCounts[c.id] = 0; });
  try {
    var rcvSheet = getOrCreateCardReceivedSheet();
    var rcvLast = rcvSheet.getLastRow();
    if (rcvLast >= 2) {
      var rcvRows = rcvSheet.getRange(2, 1, rcvLast - 1, 3).getValues();
      rcvRows.forEach(function(row) {
        var nick = String(row[0]);
        var cid  = Number(row[1]);
        var qty  = Number(row[2]) || 0;
        if (!nick || !cid) return;
        receivedCounts[cid] = (receivedCounts[cid] || 0) + qty;
        if (!userReceivedMap[nick]) userReceivedMap[nick] = {};
        userReceivedMap[nick][cid] = qty;
      });
    }
  } catch(e) {}

  // 3. Trades(accepted) → 유저별 교환 양도/취득 맵
  var tradeOutMap = {}; // nickname → { cardId: [counterpart, ...] }
  var tradeInMap  = {}; // nickname → { cardId: [counterpart, ...] }
  try {
    var tradeSheet = getOrCreateTradesSheet();
    var tradeLast = tradeSheet.getLastRow();
    if (tradeLast >= 2) {
      var tradeRows = tradeSheet.getRange(2, 1, tradeLast - 1, 8).getValues();
      // cols: id(0), requester(1), requesterCardId(2), requesterCardName(3),
      //       target(4), targetCardId(5), targetCardName(6), status(7)
      tradeRows.forEach(function(row) {
        if (String(row[7]) !== 'accepted') return;
        var req      = String(row[1]);
        var reqCard  = Number(row[2]);
        var tgt      = String(row[4]);
        var tgtCard  = Number(row[5]);
        // requester: 양도 reqCard → tgt, 취득 tgtCard ← tgt
        if (!tradeOutMap[req]) tradeOutMap[req] = {};
        if (!tradeOutMap[req][reqCard]) tradeOutMap[req][reqCard] = [];
        tradeOutMap[req][reqCard].push(tgt);
        if (!tradeInMap[req]) tradeInMap[req] = {};
        if (!tradeInMap[req][tgtCard]) tradeInMap[req][tgtCard] = [];
        tradeInMap[req][tgtCard].push(tgt);
        // target: 양도 tgtCard → req, 취득 reqCard ← req
        if (!tradeOutMap[tgt]) tradeOutMap[tgt] = {};
        if (!tradeOutMap[tgt][tgtCard]) tradeOutMap[tgt][tgtCard] = [];
        tradeOutMap[tgt][tgtCard].push(req);
        if (!tradeInMap[tgt]) tradeInMap[tgt] = {};
        if (!tradeInMap[tgt][reqCard]) tradeInMap[tgt][reqCard] = [];
        tradeInMap[tgt][reqCard].push(req);
      });
    }
  } catch(e) {}

  // 4. 닉네임 → 이름 맵
  var nameMap = {};
  try {
    var usersSheet = ss.getSheetByName('Users');
    if (usersSheet) {
      var uData = usersSheet.getDataRange().getValues();
      for (var i = 1; i < uData.length; i++) {
        if (uData[i][0]) nameMap[String(uData[i][0])] = String(uData[i][2] || '');
      }
    }
  } catch(e) {}

  // 5. 유저별 카드 통합 (뽑기 또는 교환이 있는 모든 유저)
  var allNicks = {};
  Object.keys(userDrawMap).forEach(function(n) { allNicks[n] = 1; });
  Object.keys(tradeInMap).forEach(function(n) { allNicks[n] = 1; });

  var userStats = Object.keys(allNicks).map(function(nickname) {
    var cards = [];
    for (var ci = 1; ci <= 9; ci++) {
      var drew      = (userDrawMap[nickname]    && userDrawMap[nickname][ci])    || 0;
      var received  = (userReceivedMap[nickname] && userReceivedMap[nickname][ci]) || 0;
      var outList   = (tradeOutMap[nickname]    && tradeOutMap[nickname][ci])    || [];
      var inList    = (tradeInMap[nickname]     && tradeInMap[nickname][ci])     || [];
      if (drew === 0 && inList.length === 0) continue;
      cards.push({
        cardId:    ci,
        cardName:  CARD_NAMES[ci - 1],
        drew:      drew,
        received:  Math.min(received, drew), // 수령은 뽑기 수 초과 불가
        needed:    Math.max(0, drew - received),
        tradeOut:  outList.length,
        tradeOutTo: outList,
        tradeIn:   inList.length,
        tradeInFrom: inList
      });
    }
    return { nickname: nickname, name: nameMap[nickname] || '', cards: cards };
  }).filter(function(u) { return u.cards.length > 0; })
    .sort(function(a, b) {
      var ta = a.cards.reduce(function(s, c) { return s + c.drew; }, 0);
      var tb = b.cards.reduce(function(s, c) { return s + c.drew; }, 0);
      return tb - ta;
    });

  return { ok: true, cardCounts: cardCounts, receivedCounts: receivedCounts, userStats: userStats, totalDraws: totalDraws };
}

