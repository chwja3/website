function verifyUserPassword(nickname, password) {
  const sheet = getSpreadsheet().getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]).trim() === nickname && String(data[i][1]).trim() === password) return true;
  }
  return false;
}

function postHpHint(body) {
  const nickname  = String(body.nickname  || '').trim();
  const weekKey   = String(body.weekKey   || '').trim();
  const cardIndex = Number(body.cardIndex) || 0;
  if (!nickname || !weekKey) return { error: 'missing_fields' };

  // getHoldPray와 동일한 로직으로 해당 카드의 실제 정답 확인
  const entries = getYouthHpEntries();
  const n = entries.length;
  const picked = [];
  const usedIdx = new Set();
  for (let i = 0; i < 3; i++) {
    const seed = weekKey + nickname + String(i);
    let idx = hashStr(seed) % n;
    let attempts = 0;
    while (usedIdx.has(idx) && attempts < n) { idx = (idx + 1) % n; attempts++; }
    usedIdx.add(idx);
    picked.push(entries[idx]);
  }
  if (picked.every(function(e) { return e.a; })) {
    for (let j = 0; j < n; j++) {
      if (!usedIdx.has(j) && !entries[j].a) { picked[2] = entries[j]; break; }
    }
  }
  const target = picked[cardIndex];
  const answerInfo = target
    ? (target.a ? '(익명)' : target.n + ' (' + target.p + ')')
    : '(확인불가)';

  const sheet = getOrCreateInquirySheet();
  const id = new Date().getTime();
  const content = '[H&P 힌트 요청] 주차: ' + weekKey + ', 카드: ' + (cardIndex + 1) + '번 | 정답: ' + answerInfo;
  sheet.appendRow([id, nickname, content, new Date().toISOString(), '', '']);
  return { ok: true, id: String(id) };
}

function getInquiries() {
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { ok: true, inquiries: [] };
  const rows = sheet.getRange(2, 1, last - 1, 6).getValues();
  const inquiries = rows
    .filter(r => r[0])
    .map((r, i) => ({
      rowIndex:  i + 2,
      id:        String(r[0]),
      nickname:  String(r[1]),
      content:   String(r[2]),
      createdAt: r[3],
      reply:     String(r[4] || ''),
      repliedAt: r[5] || ''
    }))
    .reverse();
  return { ok: true, inquiries };
}

function postInquiry(body) {
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const content  = String(body.content  || '').trim();
  if (!nickname || !password || !content) return { error: 'missing_fields' };
  if (!verifyUserPassword(nickname, password)) return { error: 'wrong_password' };
  const sheet = getOrCreateInquirySheet();
  sheet.appendRow([new Date().getTime(), nickname, content, new Date().toISOString(), '', '']);
  return { ok: true };
}

function editInquiry(body) {
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const id       = String(body.id       || '');
  const content  = String(body.content  || '').trim();
  if (!nickname || !password || !id || !content) return { error: 'missing_fields' };
  if (!verifyUserPassword(nickname, password)) return { error: 'wrong_password' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 2).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === id && String(rows[i][1]).trim() === nickname) {
      sheet.getRange(i + 2, 3).setValue(content);
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

function deleteInquiry(body) {
  const id = String(body.id || '');
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 2).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) !== id) continue;
    if (body.adminPw === ADMIN_PASSWORD) {
      sheet.deleteRow(i + 2);
      return { ok: true };
    }
    const nickname = String(body.nickname || '').trim();
    const password = String(body.password || '').trim();
    if (String(rows[i][1]).trim() === nickname && verifyUserPassword(nickname, password)) {
      sheet.deleteRow(i + 2);
      return { ok: true };
    }
    return { error: 'unauthorized' };
  }
  return { error: 'not_found' };
}

function replyInquiry(body) {
  if (body.adminPw !== ADMIN_PASSWORD) return { error: 'unauthorized' };
  const id    = String(body.id    || '');
  const reply = String(body.reply || '').trim();
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };
  const rows = sheet.getRange(2, 1, last - 1, 1).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === id) {
      sheet.getRange(i + 2, 5).setValue(reply);
      sheet.getRange(i + 2, 6).setValue(reply ? new Date().toISOString() : '');
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

