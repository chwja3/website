}

function getRaffleTicketInfoFromCardCounts_(cardCounts, attended, includeSignup) {
  let uniqueCards = 0;
  for (let cardId = 1; cardId <= 10; cardId++) {
    if (Number(cardCounts && cardCounts[cardId]) > 0) uniqueCards++;
  }
  const signupTicket = includeSignup === false ? 0 : 1;
  const card3Ticket = uniqueCards >= 3 ? 1 : 0;
  const card5Ticket = uniqueCards >= 5 ? 1 : 0;
  const card10Ticket = uniqueCards >= 10 ? 1 : 0;
  const attendanceTicket = 0;
  const tickets = signupTicket + card3Ticket + card5Ticket + card10Ticket + attendanceTicket;
  return {
    tickets: tickets,
    uniqueCards: uniqueCards,
    signupTicket: signupTicket,
    card3Ticket: card3Ticket,
    card5Ticket: card5Ticket,
    card10Ticket: card10Ticket,
    attendanceTicket: attendanceTicket,
  };
}

function getRaffleFillPercent_(totalTickets) {
  const total = Math.max(0, Number(totalTickets) || 0);
  if (total <= 0) return 0;
  return Math.min(
    RAFFLE_VISUAL_MAX_FILL_PERCENT,
    Math.max(4, Math.round((total / RAFFLE_VISUAL_CAP) * RAFFLE_VISUAL_MAX_FILL_PERCENT))
  );
}

// ŌöĆŌöĆ ņČöņ▓©ĻČī ļ▓łĒśĖ ļ░£ĻĖē ņŗ£ņŖżĒģ£ ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
const RAFFLE_TICKET_COLUMNS = Object.freeze([
  'ticket_no', 'active', 'userId', 'name', 'parish', 'issued_at', 'week_key',
  'condition', 'condition_label', 'deposit_status', 'deposited_at',
  'winner_rank', 'winner_marked_at', 'updated_at',
]);
