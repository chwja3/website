function getCardStats() {
  var CARD_NAMES = ['ņé¼ļ×æ','ĒØ¼ļØĮ','ĒÖöĒÅē','ņśżļ×śņ░ĖņØī','ņ×Éļ╣ä','ņ¢æņäĀ','ņČ®ņä▒','ņś©ņ£Ā','ņĀłņĀ£'];

  // 1. Events.card.drawn ŌåÆ ņ╣┤ļō£ļ│ä ņ┤Ø ļĮæĻĖ░ ĒÜ¤ņłś(ņāüļŗ© ĻĘĖļ”¼ļō£) + ņ£ĀņĀĆļ│ä ļĮæĻĖ░ ĒÜ¤ņłś
  var cardCounts = {};
  var totalDraws = 0;
  var userDrawMap = {}; // nickname ŌåÆ { cardId: count }
  SPIRIT_CARDS.forEach(function(c) { cardCounts[c.id] = 0; });
  try {
    Events_readAll_().forEach(function(event) {
      if (event.type !== EVENT_TYPES.CARD_DRAWN) return;
      var nick = String(event.userId || '').trim();
      var cid = Number(event.refId);
      var amount = eventAmount_(event, 1);
      if (!nick || !cid || amount <= 0) return;
      cardCounts[cid] = (cardCounts[cid] || 0) + amount;
      totalDraws += amount;
      if (!userDrawMap[nick]) userDrawMap[nick] = {};
      userDrawMap[nick][cid] = (userDrawMap[nick][cid] || 0) + amount;
    });
  } catch(e) {}

  // 2. CardReceived ŌåÆ ņ╣┤ļō£ļ│ä ņ┤Ø ņłśļĀ╣ ņłś + ņ£ĀņĀĆļ│ä ņłśļĀ╣ ļ¦Ą
  var receivedCounts = {};
  var userReceivedMap = {}; // nickname ŌåÆ { cardId: qty }
  SPIRIT_CARDS.forEach(function(c) { receivedCounts[c.id] = 0; });
  try {
    var rcvSheet = getOrCreateCardReceivedSheet();
    var rcvCol = getCardReceivedColumns_(rcvSheet);
    var rcvRows = getCardReceivedRows_(rcvSheet);
    if (rcvRows.length) {
      rcvRows.forEach(function(row) {
        var nick = String(row[rcvCol.nickname]);
        var cid  = Number(row[rcvCol.cardId]);
        var qty  = Number(row[rcvCol.receivedQty]) || 0;
        if (!nick || !cid) return;
        receivedCounts[cid] = (receivedCounts[cid] || 0) + qty;
        if (!userReceivedMap[nick]) userReceivedMap[nick] = {};
        userReceivedMap[nick][cid] = qty;
      });
    }
  } catch(e) {}

  // 3. Trades(accepted) ŌåÆ ņ£ĀņĀĆļ│ä ĻĄÉĒÖś ņ¢æļÅä/ņĘ©ļōØ ļ¦Ą
  var tradeOutMap = {}; // nickname ŌåÆ { cardId: [counterpart, ...] }
  var tradeInMap  = {}; // nickname ŌåÆ { cardId: [counterpart, ...] }
  try {
    var tradeSheet = getOrCreateTradesSheet();
    var tradeCol = getTradesColumns_(tradeSheet);
    var tradeRows = getTradesRows_(tradeSheet);
    if (tradeRows.length) {
      tradeRows.forEach(function(row) {
        if (String(row[tradeCol.status]) !== 'accepted') return;
        var req      = String(row[tradeCol.requester]);
        var reqCard  = Number(row[tradeCol.requesterCardId]);
        var tgt      = String(row[tradeCol.target]);
        var tgtCard  = Number(row[tradeCol.targetCardId]);
        // requester: ņ¢æļÅä reqCard ŌåÆ tgt, ņĘ©ļōØ tgtCard ŌåÉ tgt
        if (!tradeOutMap[req]) tradeOutMap[req] = {};
        if (!tradeOutMap[req][reqCard]) tradeOutMap[req][reqCard] = [];
        tradeOutMap[req][reqCard].push(tgt);
        if (!tradeInMap[req]) tradeInMap[req] = {};
        if (!tradeInMap[req][tgtCard]) tradeInMap[req][tgtCard] = [];
        tradeInMap[req][tgtCard].push(tgt);
        // target: ņ¢æļÅä tgtCard ŌåÆ req, ņĘ©ļōØ reqCard ŌåÉ req
        if (!tradeOutMap[tgt]) tradeOutMap[tgt] = {};
        if (!tradeOutMap[tgt][tgtCard]) tradeOutMap[tgt][tgtCard] = [];
        tradeOutMap[tgt][tgtCard].push(req);
        if (!tradeInMap[tgt]) tradeInMap[tgt] = {};
        if (!tradeInMap[tgt][reqCard]) tradeInMap[tgt][reqCard] = [];
        tradeInMap[tgt][reqCard].push(req);
      });
    }
  } catch(e) {}

  // 4. ļŗēļäżņ×ä ŌåÆ ņØ┤ļ”ä ļ¦Ą
  var nameMap = {};
  try {
    nameMap = getUserNameMap_();
  } catch(e) {}

  // 5. ņ£ĀņĀĆļ│ä ņ╣┤ļō£ ĒåĄĒĢ® (ļĮæĻĖ░ ļśÉļŖö ĻĄÉĒÖśņØ┤ ņ×łļŖö ļ¬©ļōĀ ņ£ĀņĀĆ)
  var allNicks = {};
  Object.keys(userDrawMap).forEach(function(n) { allNicks[n] = 1; });
  Object.keys(tradeInMap).forEach(function(n) { allNicks[n] = 1; });

  var userStats = Object.keys(allNicks).map(function(nickname) {
    var cards = [];
    for (var ci = 1; ci <= 9; ci++) {
      var drew      = (userDrawMap[nickname]    && userDrawMap[nickname][ci])    || 0;
      var received  = (userReceivedMap[nickname] && userReceivedMap[nickname][ci]) || 0;
      var outList   = (tradeOutMap[nickname]    && tradeOutMap[nickname][ci])    || [];
      var inList    = (tradeInMap[nickname]     && tradeInMap[nickname][ci])     || [];
      if (drew === 0 && inList.length === 0) continue;
      // ĻĄÉĒÖśņĘ©ļōØ ĒīīĒŖĖļäłļ│ä ņłśļĀ╣ ņŚ¼ļČĆ
      var inDetails = inList.map(function(partnerName) {
        var pRcv = (userReceivedMap[partnerName] && userReceivedMap[partnerName][ci]) || 0;
        return { from: partnerName, partnerReceived: pRcv > 0 };
      });
      // TFļ░░ļČĆ ĒĢäņÜö ņłśļ¤ē: (ļĮæĻĖ░ - ņ¢æļÅä) + ĒīīĒŖĖļäłļ»ĖņłśļĀ╣ ĻĄÉĒÖśņĘ©ļōØ
      var tfNeedFromTrade = inDetails.filter(function(d) { return !d.partnerReceived; }).length;
      var tfTarget = Math.max(0, drew - outList.length) + tfNeedFromTrade;
      var receivedCapped = Math.min(received, tfTarget);
      cards.push({
        cardId:    ci,
        cardName:  CARD_NAMES[ci - 1],
        drew:      drew,
        received:  receivedCapped,
        needed:    Math.max(0, tfTarget - receivedCapped),
        tradeOut:  outList.length,
        tradeOutTo: outList,
        tradeIn:   inList.length,
        tradeInFrom: inList,
        tradeInFromDetails: inDetails
      });
    }
    return { nickname: nickname, name: nameMap[nickname] || '', cards: cards };
  }).filter(function(u) { return u.cards.length > 0; })
    .sort(function(a, b) {
      var ta = a.cards.reduce(function(s, c) { return s + c.drew; }, 0);
      var tb = b.cards.reduce(function(s, c) { return s + c.drew; }, 0);
      return tb - ta;
    });

  return { ok: true, cardCounts: cardCounts, receivedCounts: receivedCounts, userStats: userStats, totalDraws: totalDraws };
}

