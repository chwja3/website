// ņ╗¼ļ¤╝ ĻĄ¼ņĪ░ (15ņŚ┤):
// 1:userId  2:ļłäņĀüļĮæĻĖ░ĻČī  3:ņŗżņĀ£ļĮæņØĆĻ░£ņłś  4:ļé©ņØĆĻ░£ņłś
// 5:ņé¼ļ×æ  6:ĒØ¼ļØĮ  7:ĒÖöĒÅē  8:ņśżļ×śņ░ĖņØī  9:ņ×Éļ╣ä  10:ņ¢æņäĀ  11:ņČ®ņä▒  12:ņś©ņ£Ā  13:ņĀłņĀ£  14:ņ┤Øņ╣┤ļō£ņłś  15:Ē×łļōĀ
function getOrCreateCollectionSheet() {
  const ss = getSpreadsheet();
