function compareEventRows_(a, b) {
  const col = EVENTS_COLUMN_FALLBACK;
  const timeCompare = String(a[col.timestamp] || '').localeCompare(String(b[col.timestamp] || ''));
  if (timeCompare !== 0) return timeCompare;
  return String(a[col.type] || '').localeCompare(String(b[col.type] || ''));
}

function compareEventCounts_(expected, actual) {
  const issues = [];
  const keys = {};
  Object.keys(expected).forEach(function(key) { keys[key] = true; });
  Object.keys(actual).forEach(function(key) { keys[key] = true; });
  Object.keys(keys).sort().forEach(function(key) {
    const expectedCount = expected[key] || 0;
    const actualCount = actual[key] || 0;
    if (expectedCount !== actualCount) {
      issues.push(key + ': expected ' + expectedCount + ', actual ' + actualCount);
    }
  });
  return issues;
}

function findOrphanEventUsers_(eventRows) {
  const userIds = getKnownUserIdSet_();
  const col = EVENTS_COLUMN_FALLBACK;
  const orphans = {};
  eventRows.forEach(function(row) {
    const userId = String(row[col.userId] || '').trim();
    if (userId && !userIds[userId]) orphans[userId] = true;
  });
  return Object.keys(orphans).sort();
}

function findInvalidTradeEventRefs_(eventRows) {
  const tradeIds = getTradeIdSet_();
  const col = EVENTS_COLUMN_FALLBACK;
  const invalid = {};
  eventRows.forEach(function(row) {
    const type = String(row[col.type] || '');
    const refId = String(row[col.refId] || '').trim();
    if (type.indexOf('trade.') === 0 && refId && !tradeIds[refId]) invalid[refId] = true;
  });
  return Object.keys(invalid).sort();
}

