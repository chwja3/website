      if (nonEmptyValue_(row[ctx.col.targetPrayed])) {
        pushMigrationEvent_(eventRows, EVENT_TYPES.TRADE_PRAYED, target, {
          timestamp: row[ctx.col.targetPrayed],
          refId: tradeId,
          payload: { side: 'target' },
        });
      }
    });
  }
  sourceRows[SHEET_NAMES.TRADES] = converted;
}

