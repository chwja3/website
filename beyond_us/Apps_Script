function deleteInquiry(body) {
  const id = String(body.id || '');
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < SCHEMA.INQUIRIES.dataStartRow) return { error: 'not_found' };
  const col = getInquiryColumns_(sheet);
  const rows = getInquiryRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    const rowIndex = i + SCHEMA.INQUIRIES.dataStartRow;
    if (String(rows[i][col.id]) !== id) continue;
    if (isAdminAuthorized_(body.adminPw)) {
      sheet.deleteRow(rowIndex);
      return { ok: true };
    }
    const nickname = String(body.nickname || '').trim();
    if (String(rows[i][col.nickname]).trim() === nickname && hasValidUserAuth_(body, nickname)) {
      sheet.deleteRow(rowIndex);
      return { ok: true };
    }
    return { error: 'unauthorized' };
  }
  return { error: 'not_found' };
}

function replyInquiry(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const id    = String(body.id    || '');
  const reply = String(body.reply || '').trim();
  if (!id) return { error: 'missing_fields' };
  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < SCHEMA.INQUIRIES.dataStartRow) return { error: 'not_found' };
  const col = getInquiryColumns_(sheet);
  const rows = getInquiryRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.id]) === id) {
      const rowIndex = i + SCHEMA.INQUIRIES.dataStartRow;
      sheet.getRange(rowIndex, col.reply + 1).setValue(reply);
      sheet.getRange(rowIndex, col.repliedAt + 1).setValue(reply ? new Date().toISOString() : '');
      return { ok: true };
    }
  }
  return { error: 'not_found' };
}

// ── Collection 시트 ───────────────────────────────
// 컬럼 구조 (15열):
// 1:userId  2:누적뽑기권  3:실제뽑은개수  4:남은개수
// 5:사랑  6:희락  7:화평  8:오래참음  9:자비  10:양선  11:충성  12:온유  13:절제  14:총카드수  15:히든
function getOrCreateCollectionSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.COLLECTION);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_NAMES.COLLECTION);
    sheet.appendRow(getSchemaHeaders_(SCHEMA.COLLECTION));
    sheet.setFrozenRows(1);
  } else {
    const col = getCollectionColumns_(sheet);
    if (sheet.getLastColumn() <= col.hidden) {
      sheet.getRange(SCHEMA.COLLECTION.headerRow, col.hidden + 1).setValue(SCHEMA.COLLECTION.columns.hidden);
    }
  }
  return sheet;
}

// { cardId: count } 형태로 반환 (카드 1~9: col 5~13 = idx 4~12, 히든(10): col 15 = idx 14)
function getUserCollection(userId) {
  const sheet = getOrCreateCollectionSheet();
  const col = getCollectionColumns_(sheet);
  const rows = getCollectionRows_(sheet);
  if (!rows.length) return {};
  for (const row of rows) {
    if (String(row[col.userId]) !== userId) continue;
    const counts = {};
    for (let i = 1; i <= 9; i++) {
      const cnt = Number(row[col['card' + i]]) || 0;
      if (cnt > 0) counts[i] = cnt;
    }
    const hidden = Number(row[col.hidden]) || 0;
    if (hidden > 0) counts[10] = hidden;
    return counts;
  }
  return {};
}

// Collection 시트에서 뽑기권 현황 읽기 (B=누적, C=뽑은, D=남은)
function getCollectionTickets(userId) {
  const sheet = getOrCreateCollectionSheet();
  const col = getCollectionColumns_(sheet);
  const rows = getCollectionRows_(sheet);
  if (!rows.length) return { totalEarned: 0, totalDrawn: 0, remaining: 0 };
  for (const row of rows) {
    if (String(row[col.userId]) === userId) {
      return {
        totalEarned: Number(row[col.totalEarned]) || 0,
        totalDrawn:  Number(row[col.totalDrawn]) || 0,
        remaining:   Number(row[col.remaining]) || 0
      };
    }
  }
  return { totalEarned: 0, totalDrawn: 0, remaining: 0 };
}

// delta: +1 추가, -1 제거
// cardId 1~9 → col 5~13(idx 4~12), 히든(10) → col 15(idx 14), 총카드수 = col 14(idx 13)
function getTicketStats() {
  const sheet = getOrCreateCollectionSheet();
  const col = getCollectionColumns_(sheet);
  const rows = getCollectionRows_(sheet);
  if (!rows.length) return { ok: true, users: [], totalRemaining: 0 };
  const users = rows
    .filter(function(r) { return String(r[col.userId]).trim(); })
    .map(function(r) {
      return {
        nickname:     String(r[col.userId]),
        totalEarned:  Number(r[col.totalEarned]) || 0,
        totalDrawn:   Number(r[col.totalDrawn]) || 0,
        remaining:    Number(r[col.remaining]) || 0
      };
    })
    .sort(function(a, b) { return b.remaining - a.remaining; });
  const totalRemaining = users.reduce(function(s, u) { return s + u.remaining; }, 0);
  return { ok: true, users: users, totalRemaining: totalRemaining };
}

function previewCollectionProjection(userId) {
  const cleanUserId = String(userId || '').trim();
  const inputs = getCollectionProjectionInputs_();
  const events = inputs.events;
  const userIds = cleanUserId ? [cleanUserId] : getCollectionProjectionCandidateUserIds_(events, inputs);
  const comparisons = userIds.map(function(id) {
    return compareCollectionProjectionForUser_(id, events, inputs);
  });
  const mismatches = comparisons.filter(function(item) { return item.diffs.length > 0; });
  return logJsonResult_('previewCollectionProjection result', {
    ok: true,
    checked: comparisons.length,
    mismatchCount: mismatches.length,
    mismatches: mismatches.slice(0, 30),
    samples: comparisons.slice(0, Math.min(5, comparisons.length)),
  });
}

function getCollectionProjectionInputs_() {
  const ss = getSpreadsheet();
  const eventsSheet = getOrCreateEventsSheet();
  const eventsCol = getEventsColumns_(eventsSheet);
  const usersSheet = ss.getSheetByName(SHEET_NAMES.USERS);
  const userCol = usersSheet ? getUserColumns_(usersSheet) : null;
  const collectionSheet = getOrCreateCollectionSheet();
  const collectionCol = getCollectionColumns_(collectionSheet);
  const rows = getBatchSheetRows_([
    { key: 'events', sheet: eventsSheet, schema: SCHEMA.EVENTS, maxColumns: EVENTS_COL_COUNT },
    { key: 'users', sheet: usersSheet, schema: SCHEMA.USERS },
    { key: 'collection', sheet: collectionSheet, schema: SCHEMA.COLLECTION, maxColumns: COLLECTION_COL_COUNT },
  ]);
  const events = (rows.events || [])
    .filter(function(row) {
      return String(row[eventsCol.userId] || '').trim() ||
        String(row[eventsCol.type] || '').trim() ||
        String(row[eventsCol.eventId] || '').trim();
    })
    .map(function(row) { return Events_rowToObject_(row, eventsCol); });
  return {
    events: events,
    usersRows: rows.users || [],
    userCol: userCol,
    collectionSheet: collectionSheet,
    collectionCol: collectionCol,
    collectionRows: rows.collection || [],
    sheetsApiV4Available: isSheetsValuesApiAvailable_(),
  };
}

function getCollectionProjectionCandidateUserIds_(events, inputs) {
  const ids = {};
  if (inputs && inputs.userCol) {
    const userCol = inputs.userCol;
    (inputs.usersRows || []).forEach(function(row) {
      const userId = String(row[userCol.nickname] || '').trim();
      if (userId) ids[userId] = true;
    });
  } else {
    const usersSheet = getSpreadsheet().getSheetByName(SHEET_NAMES.USERS);
    if (usersSheet) {
      const userCol = getUserColumns_(usersSheet);
      getUserRows_(usersSheet).forEach(function(row) {
        const userId = String(row[userCol.nickname] || '').trim();
        if (userId) ids[userId] = true;
      });
    }
  }

  if (inputs && inputs.collectionCol) {
    const collectionCol = inputs.collectionCol;
    (inputs.collectionRows || []).forEach(function(row) {
      const userId = String(row[collectionCol.userId] || '').trim();
      if (userId) ids[userId] = true;
    });
  } else {
    const collectionSheet = getSpreadsheet().getSheetByName(SHEET_NAMES.COLLECTION);
    if (collectionSheet) {
      const collectionCol = getCollectionColumns_(collectionSheet);
      getCollectionRows_(collectionSheet).forEach(function(row) {
        const userId = String(row[collectionCol.userId] || '').trim();
        if (userId) ids[userId] = true;
      });
    }
  }

  events.forEach(function(event) {
    const userId = String(event.userId || '').trim();
    if (userId) ids[userId] = true;
    if (event.type === EVENT_TYPES.TRADE_REQUESTED) {
      const target = String((event.payload && event.payload.target) || '').trim();
      if (target) ids[target] = true;
    }
  });

  return Object.keys(ids).sort();
}

function compareCollectionProjectionForUser_(userId, events, inputs) {
  const current = getCurrentCollectionSnapshot_(userId, inputs);
  const projected = buildCollectionProjectionFromEvents_(userId, events);
  const diffs = diffCollectionSnapshots_(current, projected);
  return {
    userId: userId,
    ok: diffs.length === 0,
    diffs: diffs,
    current: current,
    projected: projected,
  };
}

function getCurrentCollectionSnapshot_(userId, inputs) {
  let col;
  let rows;
  if (inputs && inputs.collectionCol && inputs.collectionRows) {
    col = inputs.collectionCol;
    rows = inputs.collectionRows;
  } else {
    const sheet = getOrCreateCollectionSheet();
    col = getCollectionColumns_(sheet);
    rows = getCollectionRows_(sheet);
  }
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (String(row[col.userId] || '').trim() !== userId) continue;
    return collectionRowToSnapshot_(row, col, true);
  }
  return emptyCollectionSnapshot_(userId, false);
}

function collectionRowToSnapshot_(row, col, rowExists) {
  const cardCounts = {};
  for (let cardId = 1; cardId <= 9; cardId++) {
    cardCounts[cardId] = Number(row[col['card' + cardId]]) || 0;
  }
  cardCounts[10] = Number(row[col.hidden]) || 0;
  return {
    rowExists: rowExists,
    userId: String(row[col.userId] || ''),
    totalEarned: Number(row[col.totalEarned]) || 0,
    totalDrawn: Number(row[col.totalDrawn]) || 0,
    remaining: Number(row[col.remaining]) || 0,
    cardCounts: cardCounts,
    totalCards: Number(row[col.totalCards]) || 0,
  };
}

function emptyCollectionSnapshot_(userId, rowExists) {
  const cardCounts = {};
  for (let cardId = 1; cardId <= 10; cardId++) cardCounts[cardId] = 0;
  return {
    rowExists: rowExists,
    userId: userId,
    totalEarned: 0,
    totalDrawn: 0,
    remaining: 0,
    cardCounts: cardCounts,
    totalCards: 0,
  };
}

// projection snapshot → drawCard/응답용 { collection: {cardId: count}, tickets: {...} } 변환
// rebuildCollectionRow_ 직후 Collection 시트 재조회를 생략하기 위해 사용
function collectionResponseFromSnapshot_(snapshot) {
  const collection = {};
  if (snapshot && snapshot.cardCounts) {
    for (let cardId = 1; cardId <= 10; cardId++) {
      const cnt = Number(snapshot.cardCounts[cardId]) || 0;
      if (cnt > 0) collection[cardId] = cnt;
    }
  }
  return {
    collection: collection,
    tickets: {
      totalEarned: snapshot ? (Number(snapshot.totalEarned) || 0) : 0,
      totalDrawn:  snapshot ? (Number(snapshot.totalDrawn)  || 0) : 0,
      remaining:   snapshot ? (Number(snapshot.remaining)   || 0) : 0,
    },
  };
}

function buildCollectionProjectionFromEvents_(userId, events) {
  const snapshot = emptyCollectionSnapshot_(userId, true);
  const tradeRequests = buildTradeRequestMapFromEvents_(events);
  const acceptedTradeIds = {};

  events.forEach(function(event) {
    if (String(event.userId || '').trim() !== userId) return;
    if (event.type === EVENT_TYPES.TICKET_GRANTED) {
      snapshot.totalEarned += eventAmount_(event, 1);
    } else if (event.type === EVENT_TYPES.TICKET_CONSUMED) {
      snapshot.remaining -= eventAmount_(event, 1);
    } else if (event.type === EVENT_TYPES.CARD_DRAWN) {
      const cardId = Number(event.refId);
      const amount = eventAmount_(event, 1);
      snapshot.totalDrawn += amount;
      if (cardId >= 1 && cardId <= 10) snapshot.cardCounts[cardId] += amount;
    } else if (event.type === EVENT_TYPES.CARD_GRANTED) {
      const cardId = Number(event.refId);
      const amount = eventAmount_(event, 1);
      if (cardId >= 1 && cardId <= 10) snapshot.cardCounts[cardId] += amount;
    } else if (event.type === EVENT_TYPES.CARD_REMOVED) {
      const cardId = Number(event.refId);
      const amount = eventAmount_(event, 1);
      adjustProjectedCardCount_(snapshot, cardId, -amount);
    }
  });

  events.forEach(function(event) {
    if (event.type !== EVENT_TYPES.TRADE_ACCEPTED) return;
    const tradeId = String(event.refId || '').trim();
    if (!tradeId || acceptedTradeIds[tradeId]) return;
    const trade = tradeRequests[tradeId];
    if (!trade) return;
    acceptedTradeIds[tradeId] = true;
    applyAcceptedTradeProjection_(snapshot, trade, userId);
  });

  snapshot.remaining = Math.max(0, snapshot.totalEarned + snapshot.remaining);
  snapshot.totalCards = 0;
  for (let cardId = 1; cardId <= 10; cardId++) {
    snapshot.cardCounts[cardId] = Math.max(0, Number(snapshot.cardCounts[cardId]) || 0);
    snapshot.totalCards += snapshot.cardCounts[cardId];
  }
  return snapshot;
}

function eventAmount_(event, defaultValue) {
  if (event.amount === '' || event.amount === null || event.amount === undefined) return defaultValue;
  const amount = Number(event.amount);
  return isNaN(amount) ? defaultValue : amount;
}

function buildTradeRequestMapFromEvents_(events) {
  const trades = {};
  events.forEach(function(event) {
    if (event.type !== EVENT_TYPES.TRADE_REQUESTED) return;
    const tradeId = String(event.refId || '').trim();
    if (!tradeId) return;
    const payload = event.payload || {};
    trades[tradeId] = {
      tradeId: tradeId,
      requester: String(event.userId || '').trim(),
      target: String(payload.target || '').trim(),
      requesterCardId: Number(payload.requesterCardId) || 0,
      targetCardId: Number(payload.targetCardId) || 0,
    };
  });
  return trades;
}

function applyAcceptedTradeProjection_(snapshot, trade, userId) {
  if (trade.requester === userId) {
    adjustProjectedCardCount_(snapshot, trade.requesterCardId, -1);
    adjustProjectedCardCount_(snapshot, trade.targetCardId, 1);
  } else if (trade.target === userId) {
    adjustProjectedCardCount_(snapshot, trade.targetCardId, -1);
    adjustProjectedCardCount_(snapshot, trade.requesterCardId, 1);
  }
}

function adjustProjectedCardCount_(snapshot, cardId, delta) {
  if (cardId < 1 || cardId > 10) return;
  snapshot.cardCounts[cardId] = Math.max(0, (Number(snapshot.cardCounts[cardId]) || 0) + delta);
}

function diffCollectionSnapshots_(current, projected) {
  const diffs = [];
  [
    'totalEarned',
    'totalDrawn',
    'remaining',
    'totalCards',
  ].forEach(function(key) {
    if (Number(current[key]) !== Number(projected[key])) {
      diffs.push({ field: key, current: current[key], projected: projected[key] });
    }
  });
  for (let cardId = 1; cardId <= 10; cardId++) {
    const currentCount = Number(current.cardCounts[cardId]) || 0;
    const projectedCount = Number(projected.cardCounts[cardId]) || 0;
    if (currentCount !== projectedCount) {
      diffs.push({ field: 'card_' + cardId, current: currentCount, projected: projectedCount });
    }
  }
  return diffs;
}

function rebuildCollectionRow(userId) {
  const cleanUserId = String(userId || '').trim();
  if (!cleanUserId) {
    return logJsonResult_('rebuildCollectionRow result', {
      ok: false,
      error: 'missing_userId',
    });
  }

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) {
    return logJsonResult_('rebuildCollectionRow result', {
      ok: false,
      error: '잠시 후 다시 시도해주세요.',
    });
  }

  try {
    return logJsonResult_('rebuildCollectionRow result', rebuildCollectionRow_(cleanUserId));
  } catch(e) {
    Logger.log('rebuildCollectionRow error: ' + e);
    return logJsonResult_('rebuildCollectionRow result', {
      ok: false,
      error: String(e),
    });
  } finally {
    lock.releaseLock();
  }
}

function rebuildCollectionRow_(userId, eventsOverride) {
  const events = eventsOverride || Events_readAll_();
  const projected = buildCollectionProjectionFromEvents_(userId, events);
  const sheet = getOrCreateCollectionSheet();
  const col = getCollectionColumns_(sheet);
  const rowIndex = findCollectionRowIndex_(sheet, col, userId);
  const current = rowIndex === -1
    ? emptyCollectionSnapshot_(userId, false)
    : collectionRowToSnapshot_(sheet.getRange(rowIndex, 1, 1, COLLECTION_COL_COUNT).getValues()[0], col, true);
  const diffsBeforeWrite = diffCollectionSnapshots_(current, projected);
  const row = collectionSnapshotToRow_(projected, col);

  if (rowIndex === -1) {
    sheet.appendRow(row);
  } else {
    setSheetValues_(sheet, rowIndex, 1, [row]);
  }
  clearUserDerivedCaches_(userId);

  return {
    ok: true,
    userId: userId,
    rowIndex: rowIndex === -1 ? sheet.getLastRow() : rowIndex,
    created: rowIndex === -1,
    diffCountBeforeWrite: diffsBeforeWrite.length,
    diffsBeforeWrite: diffsBeforeWrite,
    projected: projected,
  };
}

