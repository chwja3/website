// ŌöĆ ņŗ£Ēü¼ļ”┐ļ▓äļöö ņØ┤ļ”ä ļ¦×ņČöĻĖ░
function guessBBBSecret(body) {
  const userId = String(body.userId || '').trim();
  const guess  = String(body.guess  || '').trim();
  if (!userId || !guess) return { error: 'ĒĢäņłś ĒĢŁļ¬®ņØ┤ ļłäļØĮļÉÉņ¢┤ņÜö.' };

  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };

  const rows = getBbbRows_(bbbSheet);

  // ļé┤ row ņ░ŠĻĖ░
  let myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { myRowIdx = i; break; }
  }
  if (myRowIdx < 0) return { error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };
  if (rows[myRowIdx][bbbCol.secretRevealed] === true) return { ok: true, correct: true, alreadyRevealed: true };

  // ļéśļź╝ ņ╝Ćņ¢┤ļ▓äļööļĪ£ Ļ░¢ļŖö ņé¼ļ×ī = ļé┤ ņŗ£Ēü¼ļ”┐ļ▓äļöö
  let secretBuddy = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.careBuddyId]) === userId) { secretBuddy = rows[i]; break; }
  }
  if (!secretBuddy) return { error: 'ņŗ£Ēü¼ļ”┐ļ▓äļöö ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };

  // ļŗēļäżņ×ä ļśÉļŖö ņØ┤ļ”äņ£╝ļĪ£ ļ╣äĻĄÉ (ļīĆņåīļ¼Ėņ×É┬ĘĻ│Ąļ░▒ ļ¼┤ņŗ£)
  const normalize = s => String(s).replace(/\s/g, '').toLowerCase();
  const secretNickname = String(secretBuddy[bbbCol.userId]);

  // ņŗ£Ēü¼ļ”┐ļ▓äļööņØś ņØ┤ļ”ä(name)ņØä Users ņŗ£ĒŖĖņŚÉņä£ ņ░ŠĻĖ░
  const userNameMap = getUserNameMap_();
  let secretName  = secretNickname;
  if (userNameMap[secretNickname]) secretName = String(userNameMap[secretNickname]).trim();

  const correct = normalize(guess) === normalize(secretNickname) ||
                  normalize(guess) === normalize(secretName);

  if (correct) {
    // secretRevealed = TRUE ĻĖ░ļĪØ
    bbbSheet.getRange(myRowIdx + SCHEMA.BBB.dataStartRow, bbbCol.secretRevealed + 1).setValue(true);

    // ņ▓½ ņĀĢļŗĄņŚÉ ĒĢ£ĒĢ┤ ļ»Ėļ│┤ņ£Ā ņ╣┤ļō£ ņ¦ĆĻĖēĻČī(ĒŖ╣ļ│ä ņ╣┤ļō£Ēī® ļ®öņ╗żļŗłņ”ś) 1ņ×ź ļ░£ĻĖē
    let rewarded = false;
    if (!hasActiveBBBPhotoReward_(userId, 'bbb_secret_guess')) {
      grantBBBSpecialPack_(userId, 'bbb_secret_guess', 'secret_guess', {
        timestamp: new Date().toISOString(),
        reason: 'bbb_secret_guess_correct',
        source: EVENT_SOURCES.WEB,
      });
      rebuildCollectionRow_(userId);
      rewarded = true;
    }
    return { ok: true, correct: true, secretName, secretNickname, rewarded };
  }
  return { ok: true, correct: false };
}

// ŌöĆ ņ╝Ćņ¢┤ļ▓äļööņŚÉĻ▓ī ņØĄļ¬ģ ļ®öņŗ£ņ¦Ć ņĀäņåĪ
function sendBBBMessage(body) {
  const userId  = String(body.userId  || '').trim();
  const message = String(body.message || '').trim();
  if (!userId || !message) return { error: 'ĒĢäņłś ĒĢŁļ¬®ņØ┤ ļłäļØĮļÉÉņ¢┤ņÜö.' };
  if (message.length > 300) return { error: 'ļ®öņŗ£ņ¦ĆļŖö 300ņ×É ņØ┤ĒĢśļĪ£ ņ×æņä▒ĒĢ┤ņŻ╝ņäĖņÜö.' };

  // ļ®öņŗ£ņ¦Ć ņśżĒöł ņŚ¼ļČĆ ĒÖĢņØĖ
  if (!isBBBMessageOpen())
    return { error: 'ņ¦ĆĻĖłņØĆ ļ®öņŗ£ņ¦Ćļź╝ ļ│┤ļé╝ ņłś ņŚåņ¢┤ņÜö. Ļ┤Ćļ”¼ņ×ÉĻ░Ć ņśżĒöłĒĢĀ ļĢī ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' };

  // ņ╝Ćņ¢┤ļ▓äļöö ņ░ŠĻĖ░
  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };
  const rows = getBbbRows_(bbbSheet);
  let careBuddyId = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { careBuddyId = String(rows[i][bbbCol.careBuddyId]); break; }
  }
  if (!careBuddyId) return { error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };

  const msgSheet = getOrCreateBBBMessagesSheet();
  const msgCol = getBbbMessageColumns_(msgSheet);
  const msgLast = msgSheet.getLastRow();
  if (msgLast >= SCHEMA.BBB_MESSAGES.dataStartRow) {
    const recent = getBbbMessageRows_(msgSheet).slice(-10);
    const now = Date.now();
    for (const r of recent) {
      if (String(r[msgCol.fromUserId]) === userId && String(r[msgCol.message]) === message) {
        const sent = new Date(String(r[msgCol.createdAt])).getTime();
        if (!isNaN(sent) && now - sent < 15000) return { ok: true };
      }
    }
  }
  const msgId = 'bm_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
  msgSheet.appendRow([msgId, userId, careBuddyId, message, new Date().toISOString()]);
  return { ok: true };
}

// ŌöĆ ļé┤Ļ░Ć ļ░øņØĆ ņØĄļ¬ģ ļ®öņŗ£ņ¦Ć ņĪ░ĒÜī (ļ░£ņŗĀņ×É ņł©Ļ╣Ć)
function getBBBMessages(userId) {
  const msgSheet = getOrCreateBBBMessagesSheet();
  const msgCol = getBbbMessageColumns_(msgSheet);
  const last = msgSheet.getLastRow();
  if (last < SCHEMA.BBB_MESSAGES.dataStartRow) return { ok: true, messages: [], sent: [] };
  const rows = getBbbMessageRows_(msgSheet);
  // ļ░øņØĆ ļ®öņŗ£ņ¦Ć: to === userId (ņśżļ×śļÉ£ ņł£)
  const messages = rows
    .filter(r => r[msgCol.msgId] && String(r[msgCol.toUserId]) === userId)
    .map(r => ({ id: String(r[msgCol.msgId]), message: String(r[msgCol.message]), createdAt: String(r[msgCol.createdAt]) }))
    .sort((a, b) => a.createdAt.localeCompare(b.createdAt));
  // ļ│┤ļéĖ ļ®öņŗ£ņ¦Ć: from === userId (ņśżļ×śļÉ£ ņł£)
  const sent = rows
    .filter(r => r[msgCol.msgId] && String(r[msgCol.fromUserId]) === userId)
    .map(r => ({ id: String(r[msgCol.msgId]), message: String(r[msgCol.message]), createdAt: String(r[msgCol.createdAt]) }))
    .sort((a, b) => a.createdAt.localeCompare(b.createdAt));
  return { ok: true, messages, sent };
}

// ŌöĆ ņ¢┤ļō£ļ»╝: ņĀäņ▓┤ ļ¦żņ╣Ł + ļ®öņŗ£ņ¦Ć ļĪ£ĻĘĖ ņĪ░ĒÜī
function adminGetBBB() {
  const bbbSheet = getOrCreateBBBSheet();
  const msgSheet = getOrCreateBBBMessagesSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const msgCol = getBbbMessageColumns_(msgSheet);

  const lastB = bbbSheet.getLastRow();
  const matches = lastB < SCHEMA.BBB.dataStartRow ? [] :
    getBbbRows_(bbbSheet)
      .filter(r => r[bbbCol.userId])
      .map(r => ({
        userId: String(r[bbbCol.userId]),
        careBuddyId: String(r[bbbCol.careBuddyId]), careBuddyName: String(r[bbbCol.careBuddyName]),
        secretRevealed: r[bbbCol.secretRevealed] === true,
        secretBuddyId: String(r[bbbCol.secretBuddyId]), secretBuddyName: String(r[bbbCol.secretBuddyName])
      }));

  const lastM = msgSheet.getLastRow();
  const messages = lastM < SCHEMA.BBB_MESSAGES.dataStartRow ? [] :
    getBbbMessageRows_(msgSheet)
      .filter(r => r[msgCol.msgId])
      .map(r => ({
        id: String(r[msgCol.msgId]),
        from: String(r[msgCol.fromUserId]),
        to: String(r[msgCol.toUserId]),
        message: String(r[msgCol.message]),
        createdAt: String(r[msgCol.createdAt])
      }))
      .sort((a, b) => b.createdAt.localeCompare(a.createdAt));

  const messageOpen = isBBBMessageOpen();
  return { ok: true, matches, messages, messageOpen };
}

// ŌöĆ ņ¢┤ļō£ļ»╝: ļ®öņŗ£ņ¦Ć ņśżĒöł/Ēü┤ļĪ£ņ”ł ĒåĀĻĖĆ
function adminSetBBBMessageOpen(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const open = body.open === true;
  const bbbSheet = getOrCreateBBBSettingsSheet();
  const bbbCol = getBbbSettingsColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  var updated = false;
  if (last >= SCHEMA.BBB_SETTINGS.dataStartRow) {
    const rows = getBbbSettingsRows_(bbbSheet);
    rows.forEach(function(r, i) {
      if (String(r[bbbCol.key]).trim() === 'msgOpen') {
        bbbSheet.getRange(i + SCHEMA.BBB_SETTINGS.dataStartRow, bbbCol.open + 1).setValue(open);
        updated = true;
      }
    });
  }
  if (!updated) bbbSheet.appendRow(['msgOpen', open, '']);
  clearConfigCaches_();
  return { ok: true, messageOpen: open };
}

