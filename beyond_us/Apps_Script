  bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, values.length, 6).setValues(values);
  return { ok: true, written: values.length };
}

// ─ TF(isStaff=TRUE) 원형 순환 매칭 후 BBB 시트에 기록
// GAS 에디터에서 한 번만 실행
function setupBBBMatching() {
  const userSheet = getSpreadsheet().getSheetByName(SHEET_NAMES.USERS);
  const col       = getUserColumns_(userSheet);
  const data      = getUserRows_(userSheet);

  // isTFRetreat=TRUE 인 유저 추출
  const staff = [];
  for (let i = 0; i < data.length; i++) {
    if (data[i][col.isDev] === true && data[i][col.nickname]) {
      staff.push({ nickname: String(data[i][col.nickname]).trim(), name: String(data[i][col.name]).trim() });
    }
  }
  if (staff.length < 2) return { error: 'isTFRetreat=TRUE 인원이 2명 이상이어야 합니다.' };

  // 원형 순환 매칭: 셔플 후 i → (i+1)%n 방식 → 자기 자신 배정 불가
  _shuffle(staff);
  const n = staff.length;

  const bbbSheet = getOrCreateBBBSheet();
  // 기존 데이터 초기화 (헤더 제외)
  if (bbbSheet.getLastRow() >= SCHEMA.BBB.dataStartRow) {
    bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, bbbSheet.getLastRow() - SCHEMA.BBB.dataStartRow + 1, 6).clearContent();
  }

  // i의 케어버디 = (i+1)%n, i의 시크릿버디 = (i-1+n)%n
  const rows = staff.map((person, i) => {
    const careBuddy   = staff[(i + 1) % n];
    const secretBuddy = staff[(i - 1 + n) % n];
    return [person.nickname, careBuddy.nickname, careBuddy.name, false, secretBuddy.nickname, secretBuddy.name];
  });
  bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, rows.length, 6).setValues(rows);

  Logger.log('BBB 매칭 완료: ' + rows.map(function(r) {
    const [userId, , careBuddyName, , , secretBuddyName] = r;
    return userId + ' → 케어:' + careBuddyName + ' / 시크릿:' + secretBuddyName;
  }).join(', '));
  return {
    ok: true,
    matched: rows.length,
    pairs: rows.map(function(r) {
      const [userId, , careBuddyName] = r;
      return { from: userId, careBuddy: careBuddyName };
    })
  };
}

// ─ 내 BBB 정보 조회
function getBBB(userId) {
  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { ok: false, error: '매칭 정보가 없어요.' };

  const rows = getBbbRows_(bbbSheet);

  // 내 row 찾기 (E=secretBuddyId, F=secretBuddyName 포함)
  let myRow = null, myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { myRow = rows[i]; myRowIdx = i; break; }
  }
  if (!myRow) return { ok: false, error: '매칭 정보가 없어요.' };

  const revealed        = true; // 임시 전체 공개
  const secretBuddyId   = String(myRow[bbbCol.secretBuddyId] || '');
  const secretBuddyName = String(myRow[bbbCol.secretBuddyName] || '');

  // 내 케어버디가 나를 시크릿버디로 맞혔는지 (= 내가 들켰는지)
  // 케어버디 row에서 secretBuddyId === userId 이고 secretRevealed === true 인지 확인
  const careBuddyId = String(myRow[bbbCol.careBuddyId]);
  let caughtByBuddy = false;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === careBuddyId) {
      caughtByBuddy = rows[i][bbbCol.secretRevealed] === true;
      break;
    }
  }

  // BBB 메시지 오픈 여부
  const msgOpen = isBBBMessageOpen();

  // 내 사진 (M1 / M2 / M3 스팟 5개)
  let myPhoto = null, myPhotoM2 = null;
  const myPhotoM3 = [null, null, null, null, null, null, null];
  try {
    const photoSheet = getOrCreateBBBPhotosSheet();
    const pLast = photoSheet.getLastRow();
    if (pLast >= SCHEMA.BBB_PHOTOS.dataStartRow) {
      const photoCol = getBbbPhotoColumns_(photoSheet);
      const pRows = getBbbPhotoRows_(photoSheet);
      pRows.forEach(function(r) {
        if (String(r[photoCol.userId]) !== userId) return;
        const mt = String(r[photoCol.missionType] || 'm1');
        const src = String(r[photoCol.photoBase64]);
        if (mt === 'm1') myPhoto = src;
        else if (mt === 'm2') myPhotoM2 = src;
        else if (mt.startsWith('m3_')) {
          const idx = Number(mt.split('_')[1]);
          if (idx >= 0 && idx < 7) myPhotoM3[idx] = src;
        }
      });
    }
  } catch(e) {}

  // M2/M3 뽑기권 수령 여부
  let m2Rewarded = false, m3Rewarded = false;
  try {
    const userEvents = Events_readByUser(userId);
    m2Rewarded = hasBonusTicketGrant_(userId, 'bbb_m2', '', userEvents);
    m3Rewarded = hasBonusTicketGrant_(userId, 'bbb_m3', '', userEvents);
  } catch(e) {}

  return {
    ok: true,
    myPhoto,
    myPhotoM2,
    myPhotoM3,
    m2Rewarded,
    m3Rewarded,
    careBuddy: {
      nickname: careBuddyId,
      name:     String(myRow[bbbCol.careBuddyName])
    },
    secretBuddy: secretBuddyId ? {
      revealed,
      name:     revealed ? secretBuddyName : null,
      nickname: revealed ? secretBuddyId   : null
    } : null,
    caughtByBuddy,
    messageOpen: msgOpen
  };
}

// ─ 시크릿버디 이름 맞추기
function guessBBBSecret(body) {
  const userId = String(body.userId || '').trim();
  const guess  = String(body.guess  || '').trim();
  if (!userId || !guess) return { error: '필수 항목이 누락됐어요.' };

  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { error: '매칭 정보가 없어요.' };

  const rows = getBbbRows_(bbbSheet);

  // 내 row 찾기
  let myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { myRowIdx = i; break; }
  }
  if (myRowIdx < 0) return { error: '매칭 정보가 없어요.' };
  if (rows[myRowIdx][bbbCol.secretRevealed] === true) return { ok: true, correct: true, alreadyRevealed: true };

  // 나를 케어버디로 갖는 사람 = 내 시크릿버디
  let secretBuddy = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.careBuddyId]) === userId) { secretBuddy = rows[i]; break; }
  }
  if (!secretBuddy) return { error: '시크릿버디 정보가 없어요.' };

  // 닉네임 또는 이름으로 비교 (대소문자·공백 무시)
  const normalize = s => String(s).replace(/\s/g, '').toLowerCase();
  const secretNickname = String(secretBuddy[bbbCol.userId]);

  // 시크릿버디의 이름(name)을 Users 시트에서 찾기
  const userNameMap = getUserNameMap_();
  let secretName  = secretNickname;
  if (userNameMap[secretNickname]) secretName = String(userNameMap[secretNickname]).trim();

  const correct = normalize(guess) === normalize(secretNickname) ||
                  normalize(guess) === normalize(secretName);

  if (correct) {
    // secretRevealed = TRUE 기록
    bbbSheet.getRange(myRowIdx + SCHEMA.BBB.dataStartRow, bbbCol.secretRevealed + 1).setValue(true);
    return { ok: true, correct: true, secretName, secretNickname };
  }
  return { ok: true, correct: false };
}

// ─ 케어버디에게 익명 메시지 전송
function sendBBBMessage(body) {
  const userId  = String(body.userId  || '').trim();
  const message = String(body.message || '').trim();
  if (!userId || !message) return { error: '필수 항목이 누락됐어요.' };
  if (message.length > 300) return { error: '메시지는 300자 이하로 작성해주세요.' };

  // 메시지 오픈 여부 확인
  if (!isBBBMessageOpen())
    return { error: '지금은 메시지를 보낼 수 없어요. 관리자가 오픈할 때 다시 시도해주세요.' };

  // 케어버디 찾기
  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { error: '매칭 정보가 없어요.' };
  const rows = getBbbRows_(bbbSheet);
  let careBuddyId = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { careBuddyId = String(rows[i][bbbCol.careBuddyId]); break; }
  }
  if (!careBuddyId) return { error: '매칭 정보가 없어요.' };

  const msgSheet = getOrCreateBBBMessagesSheet();
  const msgCol = getBbbMessageColumns_(msgSheet);
  const msgLast = msgSheet.getLastRow();
  if (msgLast >= SCHEMA.BBB_MESSAGES.dataStartRow) {
    const recent = getBbbMessageRows_(msgSheet).slice(-10);
    const now = Date.now();
    for (const r of recent) {
      if (String(r[msgCol.fromUserId]) === userId && String(r[msgCol.message]) === message) {
        const sent = new Date(String(r[msgCol.createdAt])).getTime();
        if (!isNaN(sent) && now - sent < 15000) return { ok: true };
      }
    }
  }
  const msgId = 'bm_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
  msgSheet.appendRow([msgId, userId, careBuddyId, message, new Date().toISOString()]);
  return { ok: true };
}

// ─ 내가 받은 익명 메시지 조회 (발신자 숨김)
function getBBBMessages(userId) {
  const msgSheet = getOrCreateBBBMessagesSheet();
  const msgCol = getBbbMessageColumns_(msgSheet);
  const last = msgSheet.getLastRow();
  if (last < SCHEMA.BBB_MESSAGES.dataStartRow) return { ok: true, messages: [], sent: [] };
  const rows = getBbbMessageRows_(msgSheet);
  // 받은 메시지: to === userId (오래된 순)
  const messages = rows
    .filter(r => r[msgCol.msgId] && String(r[msgCol.toUserId]) === userId)
    .map(r => ({ id: String(r[msgCol.msgId]), message: String(r[msgCol.message]), createdAt: String(r[msgCol.createdAt]) }))
    .sort((a, b) => a.createdAt.localeCompare(b.createdAt));
  // 보낸 메시지: from === userId (오래된 순)
  const sent = rows
    .filter(r => r[msgCol.msgId] && String(r[msgCol.fromUserId]) === userId)
    .map(r => ({ id: String(r[msgCol.msgId]), message: String(r[msgCol.message]), createdAt: String(r[msgCol.createdAt]) }))
    .sort((a, b) => a.createdAt.localeCompare(b.createdAt));
  return { ok: true, messages, sent };
}

// ─ 어드민: 전체 매칭 + 메시지 로그 조회
function adminGetBBB() {
  const bbbSheet = getOrCreateBBBSheet();
  const msgSheet = getOrCreateBBBMessagesSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const msgCol = getBbbMessageColumns_(msgSheet);

  const lastB = bbbSheet.getLastRow();
  const matches = lastB < SCHEMA.BBB.dataStartRow ? [] :
    getBbbRows_(bbbSheet)
      .filter(r => r[bbbCol.userId])
      .map(r => ({
        userId: String(r[bbbCol.userId]),
        careBuddyId: String(r[bbbCol.careBuddyId]), careBuddyName: String(r[bbbCol.careBuddyName]),
        secretRevealed: r[bbbCol.secretRevealed] === true,
        secretBuddyId: String(r[bbbCol.secretBuddyId]), secretBuddyName: String(r[bbbCol.secretBuddyName])
      }));

  const lastM = msgSheet.getLastRow();
  const messages = lastM < SCHEMA.BBB_MESSAGES.dataStartRow ? [] :
    getBbbMessageRows_(msgSheet)
      .filter(r => r[msgCol.msgId])
      .map(r => ({
        id: String(r[msgCol.msgId]),
        from: String(r[msgCol.fromUserId]),
        to: String(r[msgCol.toUserId]),
        message: String(r[msgCol.message]),
        createdAt: String(r[msgCol.createdAt])
      }))
      .sort((a, b) => b.createdAt.localeCompare(a.createdAt));

  const messageOpen = isBBBMessageOpen();
  return { ok: true, matches, messages, messageOpen };
}

// ─ 어드민: 메시지 오픈/클로즈 토글
function adminSetBBBMessageOpen(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const open = body.open === true;
  const bbbSheet = getOrCreateBBBSettingsSheet();
  const bbbCol = getBbbSettingsColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  var updated = false;
  if (last >= SCHEMA.BBB_SETTINGS.dataStartRow) {
    const rows = getBbbSettingsRows_(bbbSheet);
    rows.forEach(function(r, i) {
      if (String(r[bbbCol.key]).trim() === 'msgOpen') {
        bbbSheet.getRange(i + SCHEMA.BBB_SETTINGS.dataStartRow, bbbCol.open + 1).setValue(open);
        updated = true;
      }
    });
  }
  if (!updated) bbbSheet.appendRow(['msgOpen', open, '']);
  clearConfigCaches_();
  return { ok: true, messageOpen: open };
}

