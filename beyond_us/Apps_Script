function syncDefaultRaffleExcludedUsers_() {
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  if (!rows.length) return { ok: true, changed: 0, released: 0 };

  const values = rows.map(function(row) {
    const current = row[col.raffleExcluded];
    const text = String(current === null || current === undefined ? '' : current).trim();
    if (text) return [current];
    return [getDefaultRaffleExcludedByParish_(row[col.parish])];
  });

  const range = sheet.getRange(SCHEMA.USERS.dataStartRow, col.raffleExcluded + 1, rows.length, 1);
  range.setValues(values);

  let released = 0;
  rows.forEach(function(row, index) {
    const nickname = String(row[col.nickname] || '').trim();
    if (!nickname) return;
    const excluded = parseRaffleExcludedValue_(values[index][0], false);
    if (!excluded) return;
    const result = revokeUserRaffleTickets_(nickname, 'available', 'raffle_excluded');
    released += Number(result.revoked) || 0;
  });

  return { ok: true, changed: rows.length, released: released };
}

