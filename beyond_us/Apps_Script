function Events_clearMigrationEvents_() {
  const sheet = getOrCreateEventsSheet();
  const col = getEventsColumns_(sheet);
  const rows = getEventsRows_(sheet);
  let removed = 0;
  for (let i = rows.length - 1; i >= 0; i--) {
    if (String(rows[i][col.source] || '') === EVENT_SOURCES.MIGRATION) {
      sheet.deleteRow(i + SCHEMA.EVENTS.dataStartRow);
      removed++;
    }
  }
  return removed;
}

function eventTimestampIso_(value, offsetMs) {
  let date;
  if (value instanceof Date) {
    date = value;
  } else {
    const text = String(value || '').trim();
    date = text ? new Date(text) : new Date();
  }
  if (!date || isNaN(date.getTime())) date = new Date();
  if (offsetMs) date = new Date(date.getTime() + offsetMs);
  return date.toISOString();
}

function eventPayloadJson_(payload) {
  if (payload === null || payload === undefined || payload === '') return '{}';
  if (typeof payload === 'string') return payload;
  return JSON.stringify(payload);
}

function parseEventPayload_(payload) {
  const text = String(payload || '').trim();
  if (!text) return {};
  try { return JSON.parse(text); } catch(e) { return { raw: text }; }
}

function parseJsonSafe_(value, fallback) {
  const text = String(value || '').trim();
  if (!text) return fallback;
  try { return JSON.parse(text); } catch(e) { return fallback; }
}

function isTruthyEventValue_(value) {
  const text = String(value || '').trim().toLowerCase();
  return value === true || Number(value) === 1 || text === 'true' || text === 'yes' || text === 'y';
}

function nonEmptyValue_(value) {
  return String(value === null || value === undefined ? '' : value).trim() !== '';
}

function countEventRowsByType_(rows) {
  const counts = {};
  const typeIndex = EVENTS_COLUMN_FALLBACK.type;
  rows.forEach(function(row) {
    const type = String(row[typeIndex] || '');
    if (!type) return;
    counts[type] = (counts[type] || 0) + 1;
  });
  return counts;
}

function sortEventsByTimestamp_(sheet) {
  const last = sheet.getLastRow();
  if (last < SCHEMA.EVENTS.dataStartRow) return;
  const col = getEventsColumns_(sheet);
  sheet
    .getRange(SCHEMA.EVENTS.dataStartRow, 1, last - SCHEMA.EVENTS.dataStartRow + 1, EVENTS_COL_COUNT)
    .sort([
      { column: col.timestamp + 1, ascending: true },
      { column: col.type + 1, ascending: true },
    ]);
}

function pushMigrationEvent_(rows, type, userId, options) {
  const opts = options || {};
  opts.source = EVENT_SOURCES.MIGRATION;
  rows.push(Events_buildRow_(type, userId, opts));
}

