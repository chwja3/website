  userId: 2,
  name: 3,
  parish: 4,
  issuedAt: 5,
  weekKey: 6,
  condition: 7,
  conditionLabel: 8,
  status: 9,
  depositedAt: 10,
  winnerRank: 11,
  winnerMarkedAt: 12,
  updatedAt: 13,
});

function getRaffleConditionLabel_(condition) {
  const key = String(condition || '').trim();
  const labels = {
    signup: 'ņĢ▒ Ļ░Ćņ×ģ',
    card_3: 'ņ╣┤ļō£ 3ņóģ ļ│┤ņ£Ā',
    card_5: 'ņ╣┤ļō£ 5ņóģ ļ│┤ņ£Ā',
    card_10: 'ņ╣┤ļō£ 10ņóģ ļ│┤ņ£Ā',
  };
  return labels[key] || key;
}

function getOrCreateRaffleTicketsSheet_() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.RAFFLE_TICKETS);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_NAMES.RAFFLE_TICKETS);
    sheet.getRange(1, 1, 1, RAFFLE_TICKET_COLUMNS.length).setValues([RAFFLE_TICKET_COLUMNS]);
    sheet.setFrozenRows(1);
  }
  ensureRaffleTicketsSheetSchema_(sheet);
  // ticket_no ņ╗¼ļ¤╝ņØĆ ĒĢŁņāü ĒģŹņŖżĒŖĖ ĒÅ¼ļ¦Ęņ£╝ļĪ£ Ļ░ĢņĀ£ (0001 Ļ░ÖņØĆ ņĢ×ņ×Éļ”¼ 0 ļ│┤ņĪ┤)
  sheet.getRange('A:A').setNumberFormat('@');
  return sheet;
}

function ensureRaffleTicketsSheetSchema_(sheet) {
  const width = Math.max(sheet.getLastColumn(), RAFFLE_TICKET_COLUMNS.length);
  const headers = sheet.getRange(1, 1, 1, width).getValues()[0];
  const alreadyCurrent = RAFFLE_TICKET_COLUMNS.every(function(header, index) {
    return String(headers[index] || '').trim() === header;
  });
  if (alreadyCurrent) return;

  const last = sheet.getLastRow();
  const rows = last >= 2 ? sheet.getRange(2, 1, last - 1, width).getValues() : [];
  const userNameMap = getUserNameMap_();
  const parishMap = getUserParishMap_();
  const converted = [];

  rows.forEach(function(row) {
    const ticketNo = padTicketNo_(row[0]);
    if (ticketNo === '0000') return;
    const oldStatus = String(row[6] || '').trim();
    const oldActive = oldStatus.toLowerCase().indexOf('revoked') !== 0;
    const userId = oldActive ? String(row[1] || '').trim() : '';
    const parish = oldActive ? (parishMap[userId] || String(row[2] || '').trim()) : '';
    const condition = oldActive ? String(row[5] || '').trim() : '';
    converted.push([
      ticketNo,
      oldActive ? 1 : 0,
      userId,
      oldActive ? (userNameMap[userId] || '') : '',
      parish,
      oldActive ? row[3] : '',
      oldActive ? String(row[4] || '').trim() : '',
      condition,
      oldActive ? getRaffleConditionLabel_(condition) : '',
      oldActive ? (oldStatus || 'pending') : 'available',
      oldActive ? row[7] : '',
      oldActive ? row[8] : '',
      oldActive ? row[9] : '',
      new Date().toISOString(),
    ]);
  });

  sheet.clearContents();
  sheet.getRange(1, 1, 1, RAFFLE_TICKET_COLUMNS.length).setValues([RAFFLE_TICKET_COLUMNS]);
  if (converted.length) {
    sheet.getRange(2, 1, converted.length, RAFFLE_TICKET_COLUMNS.length).setValues(converted);
  }
  sheet.setFrozenRows(1);
}

function getRaffleTicketRows_() {
  const sheet = getOrCreateRaffleTicketsSheet_();
  const last = sheet.getLastRow();
  if (last < 2) return [];
  return sheet.getRange(2, 1, last - 1, RAFFLE_TICKET_COLUMNS.length).getValues();
}

function padTicketNo_(n) {
  return String(Math.max(0, Math.floor(Number(n) || 0))).padStart(4, '0');
}

function getLastTicketNumber_() {
  const rows = getRaffleTicketRows_();
  let max = 0;
  rows.forEach(function(r) {
    const n = Number(String(r[RAFFLE_TICKET_COL.ticketNo] || '').replace(/^0+/, '') || '0');
    if (n > max) max = n;
  });
  return max;
}

function findAvailableRaffleTicket_(rows) {
  let best = null;
  for (let i = 0; i < rows.length; i++) {
    if (isActiveRaffleTicketRow_(rows[i])) continue;
    const ticketNo = padTicketNo_(rows[i][RAFFLE_TICKET_COL.ticketNo]);
    if (ticketNo === '0000') continue;
    if (!best || Number(ticketNo) < Number(best.ticketNo)) {
      best = { row: rows[i], index: i, ticketNo: ticketNo };
    }
  }
  return best;
}

function findUserRaffleTicket_(rows, userId, condition) {
  const cleanUser = String(userId || '').trim();
  const cleanCond = String(condition || '').trim();
  for (let i = 0; i < rows.length; i++) {
    if (!isActiveRaffleTicketRow_(rows[i])) continue;
    if (String(rows[i][RAFFLE_TICKET_COL.userId]).trim() === cleanUser &&
        String(rows[i][RAFFLE_TICKET_COL.condition]).trim() === cleanCond) {
      return { row: rows[i], index: i };
    }
  }
  return null;
}

function isRaffleEligibleParish_(parish) {
  const clean = String(parish || '').replace(/\s+/g, '').trim();
  if (!clean) return false;
  if (clean === 'VIP') return true;
  return /^([1-4]ņ▓Ł)/.test(clean);
}

function getRaffleEligibilityFromParish_(parish) {
  const clean = String(parish || '').trim();
  const eligible = isRaffleEligibleParish_(clean);
  return {
    eligible: eligible,
    parish: clean,
    reason: eligible ? '' : 'ineligible_parish',
  };
}

function getDefaultRaffleExcludedByParish_(parish) {
  return !isRaffleEligibleParish_(parish);
}

function parseRaffleExcludedValue_(value, defaultValue) {
  const text = String(value === null || value === undefined ? '' : value).trim().toLowerCase();
  if (!text) return defaultValue === true;
  if (value === true || Number(value) === 1 || text === 'true' || text === 'yes' || text === 'y') return true;
  if (value === false || Number(value) === 0 || text === 'false' || text === 'no' || text === 'n') return false;
  return defaultValue === true;
}

function getUserRaffleExcludedFromRow_(row, col) {
  const parish = String(row[col.parish] || '').trim();
  return parseRaffleExcludedValue_(row[col.raffleExcluded], getDefaultRaffleExcludedByParish_(parish));
}

function isUserRaffleExcluded_(userId) {
  const target = String(userId || '').trim();
  if (!target) return true;
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.nickname] || '').trim() === target) {
      return getUserRaffleExcludedFromRow_(rows[i], col);
    }
  }
  return true;
}

function isActiveRaffleTicketRow_(row) {
  const active = (row || [])[RAFFLE_TICKET_COL.active];
  const text = String(active === null || active === undefined ? '' : active).trim().toLowerCase();
  return active === true || Number(active) === 1 || text === 'true' || text === 'yes' || text === 'y';
}

function getActiveRaffleTicketSummary_(rows) {
  const byUser = {};
  const byUserCondition = {};
  (rows || []).forEach(function(row) {
    if (!isActiveRaffleTicketRow_(row)) return;
    const userId = String(row[RAFFLE_TICKET_COL.userId] || '').trim();
    const condition = String(row[RAFFLE_TICKET_COL.condition] || '').trim();
    if (!userId || !condition) return;
    byUser[userId] = (byUser[userId] || 0) + 1;
    if (!byUserCondition[userId]) byUserCondition[userId] = {};
    byUserCondition[userId][condition] = padTicketNo_(row[RAFFLE_TICKET_COL.ticketNo]);
  });
  return { byUser: byUser, byUserCondition: byUserCondition };
}

function getUserParishMap_() {
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  const map = {};
  rows.forEach(function(row) {
    const nickname = String(row[col.nickname] || '').trim();
    if (nickname) map[nickname] = String(row[col.parish] || '').trim();
  });
  return map;
}

function getUserParishFromUsers_(userId) {
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  const target = String(userId || '').trim();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.nickname] || '').trim() === target) {
      return String(rows[i][col.parish] || '').trim();
    }
  }
  return '';
}

// ĒĢĄņŗ¼: ĒĢ£ ļ▓łņŚÉ ĒĢ£ condition ļ░£ĻĖē. ņżæļ│Ą ļ░£ĻĖē ņ░©ļŗ©. LockServiceļĪ£ ļÅÖņŗ£ņä▒ ļ│┤ņ×ź.
function issueRaffleTicket_(userId, condition, weekKey) {
  const cleanUser = String(userId || '').trim();
  const cleanCond = String(condition || '').trim();
  if (!cleanUser || !cleanCond) return { ok: false, error: 'missing_fields' };
  if (isUserRaffleExcluded_(cleanUser)) {
    return { ok: false, error: 'raffle_excluded' };
  }
  const parish = getUserParishFromUsers_(cleanUser);

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'lock_timeout' }; }

  try {
    const sheet = getOrCreateRaffleTicketsSheet_();
    const rows = getRaffleTicketRows_();
    const existing = findUserRaffleTicket_(rows, cleanUser, cleanCond);
    if (existing) {
      return {
        ok: true,
        ticket_no: padTicketNo_(existing.row[RAFFLE_TICKET_COL.ticketNo]),
        dup: true,
      };
    }
    const available = findAvailableRaffleTicket_(rows);
    const nextNo = available ? available.ticketNo : padTicketNo_(getLastTicketNumber_() + 1);
    const now = new Date().toISOString();
    const week = String(weekKey || ('w' + getCurrentWeek_())).trim();
    const name = getUserNameMap_()[cleanUser] || '';
    const nextRow = [
      nextNo,
      1,
      cleanUser,
      name,
      parish,
      now,
      week,
      cleanCond,
      getRaffleConditionLabel_(cleanCond),
      'issued',
      '',
      '',
      '',
      now,
    ];
    if (available) {
      sheet.getRange(available.index + 2, 1, 1, RAFFLE_TICKET_COLUMNS.length).setValues([nextRow]);
    } else {
      const newRow = sheet.getLastRow() + 1;
      sheet.getRange(newRow, 1).setNumberFormat('@').setValue(nextNo);
      sheet.getRange(newRow, 2, 1, RAFFLE_TICKET_COLUMNS.length - 1).setValues([nextRow.slice(1)]);
    }
    return { ok: true, ticket_no: nextNo, dup: false, week_key: week };
  } finally {
    lock.releaseLock();
  }
}

// ņé¼ņÜ®ņ×ÉņØś Ēśäņ×¼ ņāüĒā£(ļ│┤ņ£Ā ņ╣┤ļō£/Ļ░Ćņ×ģ ņŚ¼ļČĆ) ĻĖ░ņżĆņ£╝ļĪ£ ĒĢäņÜöĒĢ£ ļ¬©ļōĀ Ēŗ░ņ╝ōņØä backfill ļ░£ĻĖē
function ensureUserRaffleTickets_(userId, options) {
  const opts = options || {};
  const cleanUser = String(userId || '').trim();
  if (!cleanUser) return { ok: false, issued: [] };
  if (isUserRaffleExcluded_(cleanUser)) return { ok: true, eligible: false, issued: [], excluded: true };

  const sheet = getOrCreateCollectionSheet();
  const col = getCollectionColumns_(sheet);
  const rows = getCollectionRows_(sheet);
  const snapshot = getCurrentCollectionSnapshotFromRows_(cleanUser, rows, col);
  let uniqueCount = 0;
  for (let cardId = 1; cardId <= 10; cardId++) {
    if (Number(snapshot.cardCounts && snapshot.cardCounts[cardId]) > 0) uniqueCount++;
  }

  const triggers = [
    { cond: 'signup', met: opts.includeSignup === true },
    { cond: 'card_3',  met: uniqueCount >= 3 },
    { cond: 'card_5',  met: uniqueCount >= 5 },
    { cond: 'card_10', met: uniqueCount >= 10 },
  ];

  const issued = [];
  triggers.forEach(function(t) {
    if (!t.met) return;
    const res = issueRaffleTicket_(cleanUser, t.cond);
    if (res.ok && !res.dup) issued.push(res.ticket_no);
  });
  return { ok: true, issued: issued };
}

function getUserRaffleTicketNumbers_(userId) {
  const cleanUser = String(userId || '').trim();
  if (!cleanUser) return [];
  if (isUserRaffleExcluded_(cleanUser)) return [];
  const rows = getRaffleTicketRows_();
  const map = {};
  rows.forEach(function(r) {
    if (!isActiveRaffleTicketRow_(r)) return;
    if (String(r[RAFFLE_TICKET_COL.userId]).trim() !== cleanUser) return;
    map[String(r[RAFFLE_TICKET_COL.condition]).trim()] = padTicketNo_(r[RAFFLE_TICKET_COL.ticketNo]);
  });
  return ['signup', 'card_3', 'card_5', 'card_10']
    .filter(function(c) { return map[c]; })
    .map(function(c) { return { condition: c, ticket_no: map[c] }; });
}

// ĻĖ░ņĪ┤ RaffleTickets ņŗ£ĒŖĖņØś ticket_no ņ╗¼ļ¤╝ņØä 4ņ×Éļ”¼ zero-pad ĒģŹņŖżĒŖĖļĪ£ ņØ╝Ļ┤ä ņĀĢĻĘ£ĒÖö
