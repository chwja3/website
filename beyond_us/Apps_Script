// ŌöĆ BBB ņé¼ņ¦ä ņŚģļĪ£ļō£ (m1/m2ļŖö ņÜ┤ņśüņ¦ä ņŖ╣ņØĖ Ēøä ņ¦ĆĻĖē, m3ļŖö 7Ļ░£ ņŖżĒī¤ ņÖäļŻī ņŗ£ ņ¦ĆĻĖē)
function uploadBBBPhoto(body) {
  const userId      = String(body.userId      || '').trim();
  const photo       = String(body.photo       || '').trim();
  const missionType = String(body.missionType || 'm1').trim();
  if (!userId || !photo) return { error: 'ĒĢäņłś ĒĢŁļ¬® ļłäļØĮ.' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    const validation = validateBBBPhotoUpload_(userId, missionType);
    if (!validation.ok) return validation;

    const photoSheet = getOrCreateBBBPhotosSheet();
    const photoCol = getBbbPhotoColumns_(photoSheet);
    const last = photoSheet.getLastRow();
    let existingRow = -1;
    if (last >= SCHEMA.BBB_PHOTOS.dataStartRow) {
      const rows = getBbbPhotoRows_(photoSheet);
      for (let i = 0; i < rows.length; i++) {
        const mt = String(rows[i][photoCol.missionType] || 'm1');
        if (String(rows[i][photoCol.userId]) === userId && mt === missionType) { existingRow = i + SCHEMA.BBB_PHOTOS.dataStartRow; break; }
      }
    }

    const now = new Date().toISOString();
    const bonusSource = validation.bonusSource;
    const approvalRequired = isBBBPhotoApprovalRequired_(validation.missionType);
    const alreadyRewarded = hasActiveBBBPhotoReward_(userId, bonusSource);

    if (approvalRequired && alreadyRewarded && existingRow !== -1) {
      return { ok: false, error: 'already_approved', approvalStatus: 'approved' };
    }

    if (existingRow === -1) {
      const status = approvalRequired ? (alreadyRewarded ? 'approved' : 'pending') : '';
      photoSheet.appendRow([userId, photo, now, missionType, status, alreadyRewarded ? now : '', alreadyRewarded ? 'legacy' : '', '']);
    } else {
      photoSheet.getRange(existingRow, photoCol.photoBase64 + 1).setValue(photo);
      photoSheet.getRange(existingRow, photoCol.uploadedAt + 1).setValue(now);
      if (approvalRequired) {
        setBBBPhotoApproval_(photoSheet, existingRow, photoCol, alreadyRewarded ? 'approved' : 'pending', alreadyRewarded ? now : '', alreadyRewarded ? 'legacy' : '', '');
      }
    }

    if (approvalRequired) {
      return {
        ok: true,
        rewarded: false,
        pendingApproval: !alreadyRewarded,
        approvalStatus: alreadyRewarded ? 'approved' : 'pending',
      };
    }

    let rewarded = false;
    if (!alreadyRewarded) {
      // m3ļŖö 7Ļ░£ ņŖżĒī¤ ļ¬©ļæÉ ņ▒äņøīņĢ╝ ņ¦ĆĻĖē
      if (missionType.startsWith('m3_')) {
        const pSheet = getOrCreateBBBPhotosSheet();
        const pLast = pSheet.getLastRow();
        let filledSpots = 0;
        if (pLast >= SCHEMA.BBB_PHOTOS.dataStartRow) {
          const pCol = getBbbPhotoColumns_(pSheet);
          const pRows = getBbbPhotoRows_(pSheet);
          for (let s = 0; s < 7; s++) {
            const found = pRows.some(function(r) {
              return String(r[pCol.userId]) === userId && String(r[pCol.missionType]) === 'm3_' + s && String(r[pCol.photoBase64]);
            });
            if (found) filledSpots++;
          }
        }
        if (filledSpots >= 7) {
          grantBBBRareCard_(userId, missionType, {
            timestamp: now,
            reason: 'bbb_m3_complete',
            source: EVENT_SOURCES.WEB,
          });
          rebuildCollectionRow_(userId);
          try { ensureUserRaffleTickets_(userId); } catch(e) {}
          rewarded = true;
        }
      } else {
        grantBBBSpecialPack_(userId, bonusSource, missionType, {
          timestamp: now,
          reason: bonusSource === 'bbb_photo' ? 'bbb_photo' : 'bbb_mission',
          source: EVENT_SOURCES.WEB,
        });
        rebuildCollectionRow_(userId);
        rewarded = true;
      }
    }

    return { ok: true, rewarded };
  } finally {
    lock.releaseLock();
  }
}

function deleteBBBPhoto(body) {
