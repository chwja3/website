function revokeUserRaffleTickets_(userId, status, reason) {
  const cleanUser = String(userId || '').trim();
  if (!cleanUser) return { error: 'missing_userId' };
  const sheet = getOrCreateRaffleTicketsSheet_();
  const last = sheet.getLastRow();
  if (last < 2) {
    return { ok: true, nickname: cleanUser, revoked: 0, rows: [] };
  }

  const range = sheet.getRange(2, 1, last - 1, RAFFLE_TICKET_COLUMNS.length);
  const values = range.getValues();
  const now = new Date().toISOString();
  const revokedRows = [];

  values.forEach(function(row, idx) {
    if (!isActiveRaffleTicketRow_(row)) return;
    if (String(row[RAFFLE_TICKET_COL.userId] || '').trim() !== cleanUser) return;
    revokedRows.push({
      rowNumber: idx + 2,
      ticket_no: padTicketNo_(row[RAFFLE_TICKET_COL.ticketNo]),
      condition: String(row[RAFFLE_TICKET_COL.condition] || '').trim(),
    });
    releaseRaffleTicketRow_(row, now);
  });

  if (revokedRows.length) {
    range.setValues(values);
    clearUserDerivedCaches_(cleanUser);
  }

  return {
    ok: true,
    nickname: cleanUser,
    revoked: revokedRows.length,
    rows: revokedRows,
  };
}

