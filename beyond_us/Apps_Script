function requestTrade(body) {
  const requester       = String(body.nickname       || '').trim();
  const requesterCardId = Number(body.requesterCardId);
  const target          = String(body.targetNickname  || '').trim();
  const targetCardId    = Number(body.targetCardId);

  if (!requester || !target || !requesterCardId || !targetCardId)
    return { error: '필수 항목이 누락됐어요.' };
  if (requester === target)
    return { error: '자기 자신과 교환할 수 없어요.' };

  const reqCard = SPIRIT_CARDS.find(c => c.id === requesterCardId);
  const tgtCard = SPIRIT_CARDS.find(c => c.id === targetCardId);
  if (!reqCard || !tgtCard) return { error: '유효하지 않은 카드예요.' };

  // 보유 확인
  const reqColl = getUserCollection(requester);
  if (!(reqColl[requesterCardId] > 0)) return { error: '내가 해당 카드를 보유하고 있지 않아요.' };
  const tgtColl = getUserCollection(target);
  if (!(tgtColl[targetCardId] > 0)) return { error: '상대방이 해당 카드를 보유하고 있지 않아요.' };

  const id = String(new Date().getTime());
  getOrCreateTradesSheet().appendRow([
    id, requester, requesterCardId, reqCard.name,
    target, targetCardId, tgtCard.name,
    'pending', new Date().toISOString(), ''
  ]);
  return { ok: true, tradeId: id };
}

function acceptTrade(body) {
  const tradeId  = String(body.tradeId   || '');
  const nickname = String(body.nickname  || '').trim();
  if (!tradeId || !nickname) return { error: '필수 항목이 누락됐어요.' };

  const sheet = getOrCreateTradesSheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { error: 'not_found' };

  _expireOldTrades(sheet);
  const rows = sheet.getRange(2, 1, last - 1, 10).getValues();
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) !== tradeId) continue;
    if (String(rows[i][4]) !== nickname) return { error: 'unauthorized' };
    if (String(rows[i][7]) !== 'pending') return { error: '이미 처리된 요청이에요.' };

    const requester       = String(rows[i][1]);
    const requesterCardId = Number(rows[i][2]);
    const targetCardId    = Number(rows[i][5]);

    // 카드 보유 재확인
    if (!(getUserCollection(requester)[requesterCardId] > 0)) {
      sheet.getRange(i + 2, 8).setValue('실패 (카드 없음)');
      sheet.getRange(i + 2, 10).setValue(new Date().toISOString());
      return { error: '상대방이 더 이상 해당 카드를 보유하지 않아요.' };
    }
    if (!(getUserCollection(nickname)[targetCardId] > 0)) {
      sheet.getRange(i + 2, 8).setValue('실패 (카드 없음)');
      sheet.getRange(i + 2, 10).setValue(new Date().toISOString());
      return { error: '내가 더 이상 해당 카드를 보유하지 않아요.' };
    }

    // 양쪽 컬렉션 업데이트
    updateCollectionSheet(requester, requesterCardId, -1);
    updateCollectionSheet(requester, targetCardId,    +1);
    updateCollectionSheet(nickname,  targetCardId,    -1);
    updateCollectionSheet(nickname,  requesterCardId, +1);

    sheet.getRange(i + 2, 8).setValue('accepted');
    sheet.getRange(i + 2, 10).setValue(new Date().toISOString());
    return { ok: true };
  }
  return { error: 'not_found' };
}

function rejectTrade(body) {
