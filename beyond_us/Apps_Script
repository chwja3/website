function getDashboardData() {
  const config   = getConfig();
  const counts = {};
  config.items.forEach(item => counts[item] = 0);
  const currentWeekEvents = getMissionSubmittedEventsForConfig_(Events_readAll_(), config, 'w' + config.currentWeek);

  currentWeekEvents.forEach(event => {
    const counted = new Set();
    // ĒģŹņŖżĒŖĖ ĻĖ░ļ░ś ņ╣┤ņÜ┤ĒŖĖ
    getMissionEventItems_(event).forEach(item => {
      if (counts[item] !== undefined) counted.add(item);
    });
    // ņØĖļŹ▒ņŖż ĻĖ░ļ░ś ĒÅ┤ļ░▒ (ĒģŹņŖżĒŖĖ ļ│ĆĻ▓ĮļÉ£ ĻĄ¼ ļŹ░ņØ┤Ēä░ ļ│┤ņÖä)
    getMissionEventIndices_(event).forEach(idx => {
      if (typeof idx === 'number' && config.items[idx] !== undefined) counted.add(config.items[idx]);
    });
    counted.forEach(item => { counts[item]++; });
  });

  return {
    ok: true,
    weekTitle:       config.weekTitle,
    items:           config.items,
    scores:          config.scores,
    cats:            config.cats,
    drawThreshold:   config.drawThreshold,
    counts,
    totalCount:      Object.values(counts).reduce((s,n) => s+n, 0),
    submissionCount: currentWeekEvents.length,
    tabSettings:     getTabSettings()
  };
}

