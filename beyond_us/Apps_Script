function adminGetBBBPhotoApprovals() {
  const photoSheet = getOrCreateBBBPhotosSheet();
  const photoCol = getBbbPhotoColumns_(photoSheet);
  const rows = getBbbPhotoRows_(photoSheet);
  const rewardMap = getBBBPhotoRewardEventMap_();
  const userNameMap = getUserNameMap_();
  const missionLabels = { m1: 'MISSION 1', m2: 'MISSION 2' };
  const photos = [];

  rows.forEach(function(row, index) {
    const userId = String(row[photoCol.userId] || '').trim();
    const missionType = String(row[photoCol.missionType] || 'm1').trim();
    if (!userId || !isBBBPhotoApprovalRequired_(missionType)) return;
    const photoBase64 = String(row[photoCol.photoBase64] || '').trim();
    if (!photoBase64) return;
    const normalized = normalizeBBBPhotoMissionType_(missionType);
    if (!normalized.ok) return;
    const rewardEvent = rewardMap[getBBBPhotoRewardEventKey_(userId, normalized.bonusSource)];
    const status = getBBBPhotoApprovalStatus_(row, photoCol, rewardEvent);
    photos.push({
      rowIndex: index + SCHEMA.BBB_PHOTOS.dataStartRow,
      userId: userId,
      name: userNameMap[userId] || '',
      missionType: missionType,
      missionLabel: missionLabels[missionType] || missionType,
      photoBase64: photoBase64,
      uploadedAt: String(row[photoCol.uploadedAt] || ''),
      approvalStatus: status,
      approvedAt: rewardEvent ? String(rewardEvent.timestamp || '') : String(getBBBPhotoApprovalValue_(row, photoCol, 'approvedAt') || ''),
      approvedBy: String(getBBBPhotoApprovalValue_(row, photoCol, 'approvedBy') || ''),
      rewardEventId: rewardEvent ? String(rewardEvent.eventId || '') : String(getBBBPhotoApprovalValue_(row, photoCol, 'rewardEventId') || ''),
    });
  });

  photos.sort(function(a, b) {
    const order = { pending: 0, rejected: 1, approved: 2 };
    if (a.approvalStatus !== b.approvalStatus) {
      return (order[a.approvalStatus] || 9) - (order[b.approvalStatus] || 9);
    }
    return String(b.uploadedAt || '').localeCompare(String(a.uploadedAt || ''));
  });

  return {
    ok: true,
    photos: photos,
    pendingCount: photos.filter(function(item) { return item.approvalStatus === 'pending'; }).length,
    approvedCount: photos.filter(function(item) { return item.approvalStatus === 'approved'; }).length,
    rejectedCount: photos.filter(function(item) { return item.approvalStatus === 'rejected'; }).length,
  };
}

function adminApproveBBBPhoto(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const userId = String(body.userId || '').trim();
  const missionType = String(body.missionType || '').trim();
  if (!userId || !missionType) return { error: 'missing_fields' };
  if (!isBBBPhotoApprovalRequired_(missionType)) return { error: 'approval_not_required' };

  const validation = validateBBBPhotoUpload_(userId, missionType);
  if (!validation.ok) return validation;

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    const photoSheet = getOrCreateBBBPhotosSheet();
    const photoCol = getBbbPhotoColumns_(photoSheet);
    const rows = getBbbPhotoRows_(photoSheet);
    let target = null;
    for (let i = 0; i < rows.length; i++) {
      const row = rows[i];
      if (String(row[photoCol.userId] || '').trim() !== userId) continue;
      if (String(row[photoCol.missionType] || 'm1').trim() !== missionType) continue;
      target = { row: row, rowIndex: i + SCHEMA.BBB_PHOTOS.dataStartRow };
      break;
    }
    if (!target || !String(target.row[photoCol.photoBase64] || '').trim()) return { error: 'photo_not_found' };

    const now = new Date().toISOString();
    const alreadyRewarded = hasActiveBBBPhotoReward_(userId, validation.bonusSource);
    if (alreadyRewarded) {
      const rewardEvent = getBBBPhotoRewardEventMap_()[getBBBPhotoRewardEventKey_(userId, validation.bonusSource)];
      setBBBPhotoApproval_(
        photoSheet,
        target.rowIndex,
        photoCol,
        'approved',
        String((rewardEvent && rewardEvent.timestamp) || now),
        String(body.adminId || 'admin'),
        String((rewardEvent && rewardEvent.eventId) || '')
      );
      return { ok: true, rewarded: false, alreadyRewarded: true };
    }

    const appended = grantBBBSpecialPack_(userId, validation.bonusSource, missionType, {
      timestamp: now,
      reason: 'bbb_photo_approved',
      approvedBy: String(body.adminId || 'admin'),
      source: EVENT_SOURCES.ADMIN,
    });
    const rewardEventId = appended && appended.event ? appended.event.eventId : '';
    setBBBPhotoApproval_(photoSheet, target.rowIndex, photoCol, 'approved', now, String(body.adminId || 'admin'), rewardEventId);
    rebuildCollectionRow_(userId);
    return { ok: true, rewarded: true, rewardEventId: rewardEventId };
  } finally {
    lock.releaseLock();
  }
}

function adminRejectBBBPhoto(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };
  const userId = String(body.userId || '').trim();
  const missionType = String(body.missionType || '').trim();
  if (!userId || !missionType) return { error: 'missing_fields' };
  if (!isBBBPhotoApprovalRequired_(missionType)) return { error: 'approval_not_required' };

  const normalized = normalizeBBBPhotoMissionType_(missionType);
  if (!normalized.ok) return normalized;
  if (hasActiveBBBPhotoReward_(userId, normalized.bonusSource)) return { error: 'already_approved' };

  const photoSheet = getOrCreateBBBPhotosSheet();
  const photoCol = getBbbPhotoColumns_(photoSheet);
  const rows = getBbbPhotoRows_(photoSheet);
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (String(row[photoCol.userId] || '').trim() !== userId) continue;
    if (String(row[photoCol.missionType] || 'm1').trim() !== missionType) continue;
    if (!String(row[photoCol.photoBase64] || '').trim()) return { error: 'photo_not_found' };
    setBBBPhotoApproval_(
      photoSheet,
      i + SCHEMA.BBB_PHOTOS.dataStartRow,
      photoCol,
      'rejected',
      new Date().toISOString(),
      String(body.adminId || 'admin'),
      ''
    );
    return { ok: true, rejected: true };
