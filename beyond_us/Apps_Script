function hasBonusTicketGrant_(userId, legacySource, weekKey, userEvents) {
  const cleanUserId = String(userId || '').trim();
  const cleanSource = String(legacySource || '').trim();
  const cleanWeekKey = String(weekKey || '').trim();
  if (!cleanUserId || !cleanSource) return false;

  try {
    const events = userEvents || Events_readByUser(cleanUserId);
    const matchedEvent = events.some(function(event) {
      if (event.type !== EVENT_TYPES.TICKET_GRANTED) return false;
      if (cleanWeekKey && String(event.weekKey || '') !== cleanWeekKey) return false;
      return String((event.payload && event.payload.legacySource) || '') === cleanSource;
    });
    if (matchedEvent) return true;
  } catch(e) {}

  return false;
}

// ŌöĆŌöĆ ņ╣┤ļō£ ņŗ£ņŖżĒģ£ ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
function getUserStatusCached_(userId, weekKey) {
  const cleanUserId = String(userId || '').trim();
  const config = getConfig();
  const cleanWeekKey = String(weekKey || ('w' + config.currentWeek)).trim();
  if (!cleanUserId) return getUserStatus(cleanUserId, cleanWeekKey, config);
  const key = cacheKey_('user_status_v3', cleanUserId + ':' + cleanWeekKey);
  const cached = cacheGetJson_(key);
  if (cached) return cached;
  const data = getUserStatus(cleanUserId, cleanWeekKey, config);
  cachePutJson_(key, data, 10);
  return data;
}

function getUserStatus(userId, weekKey, configOverride) {
  const config = configOverride || getConfig();
  weekKey = String(weekKey || ('w' + config.currentWeek)).trim();
  let weekScore = 0, drawnThisWeek = false, weekCard = null;
  const collection = [];
  const todayItems   = [];
  const todayIndices = [];
  const weekDates    = [];

  const today = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // ņØ┤ļ▓ł ņŻ╝ ņøö~ņØ╝ ļ▓öņ£ä Ļ│äņé░ (KST)
  const nowKST = new Date(new Date().getTime() + 9 * 60 * 60 * 1000);
  const dow = nowKST.getUTCDay() || 7;
  const monday = new Date(nowKST);
  monday.setUTCDate(nowKST.getUTCDate() - (dow - 1));
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  const weekStart = monday.toISOString().slice(0, 10);
  const weekEnd   = sunday.toISOString().slice(0, 10);

  const userEvents = Events_readByUser(userId);
  const submittedEvents = getMissionSubmittedEventsForConfig_(userEvents, config, weekKey);
  let earnedTicketThisWeek = false;
  submittedEvents.forEach(function(event) {
    weekScore += getMissionEventScore_(event);
    const rowDate = getMissionEventDateKey_(event);
    if (rowDate >= weekStart && rowDate <= weekEnd && !weekDates.includes(rowDate)) {
      weekDates.push(rowDate);
    }
    if (rowDate === today) {
      getMissionEventItems_(event).forEach(function(item) {
        todayItems.push(item);
        // ņØĖļŹ▒ņŖż ļ»ĖņĀĆņ×ź ĻĄ¼ ļŹ░ņØ┤Ēä░: Ēśäņ×¼ config ĒģŹņŖżĒŖĖņÖĆ ļ¦żņ╣ŁĒĢ┤ ņØĖļŹ▒ņŖż ņŚŁņČöņĀü
        const idx = config.items.indexOf(item);
        if (idx >= 0) todayIndices.push(idx);
      });
      getMissionEventIndices_(event).forEach(function(idx) {
        if (typeof idx === 'number') todayIndices.push(idx);
      });
    }
  });
  userEvents.forEach(function(event) {
    if (event.type !== EVENT_TYPES.TICKET_GRANTED) return;
    if (String(event.weekKey || '') !== String(weekKey || '')) return;
    if (String((event.payload && event.payload.reason) || '') === 'week_complete') {
      earnedTicketThisWeek = true;
    }
  });
  const specialPackStats = getSpecialPackStatsFromEvents_(userEvents, userId);
  let raffle = getEmptyRaffleStats_();

  // ņ╣┤ļō£ ļĮæĻĖ░ ņØ┤ļĀź (drawnThisWeek, weekCard)
  try {
    if (userEvents.length) {
      for (const event of userEvents) {
        if (event.type !== EVENT_TYPES.CARD_DRAWN) continue;
        if (String(event.weekKey) !== weekKey) continue;
        const card = SPIRIT_CARDS.find(c => c.id === Number(event.refId));
        if (!card) continue;
        drawnThisWeek = true;
        weekCard = card;
      }
    }
  } catch(e) {}

  let pendingDraws = 0;
  try {
    const cleanUserId = String(userId || '').trim();
    const collectionSheet = getOrCreateCollectionSheet();
    const collectionCol = getCollectionColumns_(collectionSheet);
    const collectionRows = getCollectionRows_(collectionSheet);
    const usersSheet = getUsersSheet_();
    const userCol = getUserColumns_(usersSheet);
    const usersRows = getUserRows_(usersSheet);
    const attendanceSheet = getOrCreateRetreatAttendanceSheet();
    const attendanceCol = getRetreatAttendanceColumns_(attendanceSheet);
    const attendanceRows = getRetreatAttendanceRows_(attendanceSheet);
    const snapshot = getCurrentCollectionSnapshotFromRows_(cleanUserId, collectionRows, collectionCol);
    pendingDraws = Number(snapshot.remaining) || 0;
    SPIRIT_CARDS.forEach(card => {
      const cnt = Number(snapshot.cardCounts[card.id]) || 0;
      for (let j = 0; j < cnt; j++) collection.push({...card});
    });
    // ņČöņ▓©ĻČī ĒåĄĻ│äļŖö ņŗżņĀ£ RaffleTickets Ē¢ē ĻĖ░ņżĆņØ┤ļ»ĆļĪ£, Ēśäņ×¼ ņĪ░Ļ▒┤ņØä ļ©╝ņĀĆ backfillĒĢ£ļŗż.
    try { ensureUserRaffleTickets_(cleanUserId); } catch(e) {}
    raffle = getRaffleStatsFromRows_(cleanUserId, {
      collectionRows: collectionRows,
      collectionCol: collectionCol,
      usersRows: usersRows,
      userCol: userCol,
      attendanceRows: attendanceRows,
      attendanceCol: attendanceCol,
      currentSnapshot: snapshot,
    });
    raffle.myTicketNumbers = getUserRaffleTicketNumbers_(cleanUserId);
  } catch(e) {}

  return {
    ok: true,
    weekScore,
    drawThreshold: config.drawThreshold,
    canDraw: pendingDraws > 0,
    pendingDraws,
    pendingSpecialPacks: specialPackStats.remaining,
    earnedTicketThisWeek,
    drawnThisWeek,
    weekCard,
    collection,
    raffle,
    todayItems,
    todayIndices,
    weekDates
  };
}

function getSpecialPackStatsFromEvents_(events, userId) {
  const cleanUserId = String(userId || '').trim();
  const stats = { totalEarned: 0, totalConsumed: 0, remaining: 0 };
  (events || []).forEach(function(event) {
    if (String(event.userId || '').trim() !== cleanUserId) return;
    if (event.type === EVENT_TYPES.SPECIAL_PACK_GRANTED) {
      stats.totalEarned += eventAmount_(event, 1);
    } else if (event.type === EVENT_TYPES.SPECIAL_PACK_CONSUMED) {
      stats.totalConsumed += eventAmount_(event, 1);
    }
  });
  stats.remaining = Math.max(0, stats.totalEarned - stats.totalConsumed);
  return stats;
}

function getMissingRegularCardsFromSnapshot_(snapshot) {
  const cardCounts = (snapshot && snapshot.cardCounts) || {};
  return SPIRIT_CARDS.filter(function(card) {
    if (card.id < 1 || card.id > 9) return false;
    return !(Number(cardCounts[card.id]) > 0);
  });
}

function getRegularDrawableCards_() {
  return SPIRIT_CARDS.filter(function(card) {
    return card.id >= 1 && card.id <= 9;
  });
}

function isDeveloperUser_(userId) {
  const cleanUserId = String(userId || '').trim();
  if (!cleanUserId) return false;
  const sheet = getUsersSheet_();
  const col = getUserColumns_(sheet);
  const rows = getUserRows_(sheet);
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][col.nickname] || '').trim() === cleanUserId) {
      return isTruthyEventValue_(rows[i][col.isDev]);
    }
  }
  return false;
}

function isDevAutoDrawAllowed_(userId, testMode) {
  const requested = testMode === true || String(testMode || '').toLowerCase() === 'true';
  return requested && isTestDrawAllowed_() && isDeveloperUser_(userId);
}

function drawCard(userId, weekKey, testMode, requestId) {
  if (!userId) return { ok: false, error: 'ļŗēļäżņ×äņØ┤ ņŚåņŖĄļŗłļŗż.' };
  const cleanRequestId = String(requestId || '').replace(/[^A-Za-z0-9_-]/g, '').slice(0, 80);
  const requestCacheKey = cleanRequestId ? 'drawCard__' + hashStr(userId + '\x00' + weekKey + '\x00' + cleanRequestId) : '';

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    if (requestCacheKey) {
      const cached = CacheService.getScriptCache().get(requestCacheKey);
      if (cached) {
        try { return JSON.parse(cached); } catch(e) {}
      }
    }
    weekKey = String(weekKey || ('w' + getCurrentWeek_())).trim();

    const shouldAutoGrantDevTicket = isDevAutoDrawAllowed_(userId, testMode);
    const bypassTicketCheck = shouldAutoGrantDevTicket;
    if (!bypassTicketCheck) {
      const pendingDraws = getCollectionTickets(userId).remaining;
      if (pendingDraws <= 0) {
        const noTicketResult = { ok: false, error: 'ņé¼ņÜ® Ļ░ĆļŖźĒĢ£ ļĮæĻĖ░ĻČīņØ┤ ņŚåņŖĄļŗłļŗż.' };
        if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(noTicketResult), 600);
        return noTicketResult;
      }
    }

    const drawableCards = getRegularDrawableCards_();
    const card = drawableCards[Math.floor(Math.random() * drawableCards.length)];

    // ļĮæĻĖ░ ņĀä ĻĖ░ņĪ┤ ļ│┤ņ£Ā ņŚ¼ļČĆ ĒÖĢņØĖ (isNew Ļ│äņé░ņÜ®)
    let isNew = true;
    try {
      const existingCounts = getUserCollection(userId);
      isNew = !(existingCounts[card.id] > 0);
    } catch(e) {}

    const drawnAt = new Date().toISOString();
    const eventItems = [];
    let timestampOffsetMs = 0;
    if (shouldAutoGrantDevTicket) {
      eventItems.push({
        type: EVENT_TYPES.TICKET_GRANTED,
        userId: userId,
        options: {
          timestamp: drawnAt,
          timestampOffsetMs: timestampOffsetMs++,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'dev_auto_draw', testMode: true },
          source: EVENT_SOURCES.SERVER,
        },
      });
    }
    // ticket.consumed + card.drawn ļæÉ ņØ┤ļ▓żĒŖĖļź╝ setValues 1ĒÜīļĪ£ ļ¼ČņØī (RPC 2 ŌåÆ 1)
    eventItems.push(
      {
        type: EVENT_TYPES.TICKET_CONSUMED,
        userId: userId,
        options: {
          timestamp: drawnAt,
          timestampOffsetMs: timestampOffsetMs++,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'card_draw', testMode: shouldAutoGrantDevTicket },
          source: EVENT_SOURCES.WEB,
        },
      },
      {
        type: EVENT_TYPES.CARD_DRAWN,
        userId: userId,
        options: {
          timestamp: drawnAt,
          timestampOffsetMs: timestampOffsetMs++,
          amount: 1,
          weekKey: weekKey,
          refId: card.id,
          payload: { cardName: card.name, isNew: isNew },
          source: EVENT_SOURCES.WEB,
        },
      },
    );
    Events_appendBatch_(eventItems);
    // rebuild Ļ▓░Ļ│╝ņØś projection snapshotņØä ĻĘĖļīĆļĪ£ ņØæļŗĄņŚÉ ņé¼ņÜ® ŌĆö Collection ņŗ£ĒŖĖ ņ×¼ņĪ░ĒÜī 2ĒÜī ņĀ£Ļ▒░
    const rebuildResult = rebuildCollectionRow_(userId);
    // ņ╣┤ļō£ ņČöĻ░ĆļĪ£ ņ×äĻ│äĻ░Æ(3/5/10ņóģ) ļŗ¼ņä▒ ņŗ£ ņČöņ▓©ĻČī ņ×ÉļÅÖ ļ░£ĻĖē
    try { ensureUserRaffleTickets_(userId); } catch(e) {}
    const response = collectionResponseFromSnapshot_(rebuildResult && rebuildResult.projected);
    const result = {
      ok: true,
      card,
      isNew,
      collection: response.collection,
      tickets: response.tickets
    };
    if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(result), 600);
    return result;
  } finally {
    lock.releaseLock();
  }
}

function drawSpecialCard(userId, weekKey, requestId) {
  const cleanUserId = String(userId || '').trim();
  if (!cleanUserId) return { ok: false, error: 'ļŗēļäżņ×äņØ┤ ņŚåņŖĄļŗłļŗż.' };
  const cleanRequestId = String(requestId || '').replace(/[^A-Za-z0-9_-]/g, '').slice(0, 80);
  const requestCacheKey = cleanRequestId ? 'drawSpecialCard__' + hashStr(cleanUserId + '\x00' + weekKey + '\x00' + cleanRequestId) : '';

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    if (requestCacheKey) {
      const cached = CacheService.getScriptCache().get(requestCacheKey);
      if (cached) {
        try { return JSON.parse(cached); } catch(e) {}
      }
    }
    weekKey = String(weekKey || ('w' + getCurrentWeek_())).trim();

    const events = Events_readAll_();
    const specialPackStats = getSpecialPackStatsFromEvents_(events, cleanUserId);
    if (specialPackStats.remaining <= 0) {
      const noPackResult = { ok: false, error: 'ņé¼ņÜ® Ļ░ĆļŖźĒĢ£ ļ»Ėļ│┤ņ£Ā ņ╣┤ļō£ ņ¦ĆĻĖēĻČīņØ┤ ņŚåņŖĄļŗłļŗż.', specialPacks: specialPackStats, specialPacksRemaining: specialPackStats.remaining };
      if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(noPackResult), 600);
      return noPackResult;
    }

    const snapshot = buildCollectionProjectionFromEvents_(cleanUserId, events);
    const missingRegularCards = getMissingRegularCardsFromSnapshot_(snapshot);
    const guaranteesMissingCard = missingRegularCards.length > 0;
    const drawableCards = guaranteesMissingCard ? missingRegularCards : getRegularDrawableCards_();

    const card = drawableCards[Math.floor(Math.random() * drawableCards.length)];
    const isNew = guaranteesMissingCard ? true : !(Number((snapshot.cardCounts || {})[card.id]) > 0);
    const drawMode = guaranteesMissingCard ? 'missing_regular_card' : 'regular_random_fallback';
    const drawnAt = new Date().toISOString();
    Events_appendBatch_([
      {
        type: EVENT_TYPES.SPECIAL_PACK_CONSUMED,
        userId: cleanUserId,
        options: {
          timestamp: drawnAt,
          amount: 1,
          weekKey: weekKey,
          payload: { reason: 'special_card_draw', mode: drawMode },
          source: EVENT_SOURCES.WEB,
        },
      },
      {
        type: EVENT_TYPES.CARD_DRAWN,
        userId: cleanUserId,
        options: {
          timestamp: drawnAt,
          timestampOffsetMs: 1,
          amount: 1,
          weekKey: weekKey,
          refId: card.id,
          payload: { cardName: card.name, isNew: isNew, packType: 'special', mode: drawMode },
          source: EVENT_SOURCES.WEB,
        },
      },
    ]);
    const rebuildResult = rebuildCollectionRow_(cleanUserId);
    try { ensureUserRaffleTickets_(cleanUserId); } catch(e) {}
    const response = collectionResponseFromSnapshot_(rebuildResult && rebuildResult.projected);
    const nextSpecialPackStats = {
      totalEarned: specialPackStats.totalEarned,
      totalConsumed: specialPackStats.totalConsumed + 1,
      remaining: Math.max(0, specialPackStats.remaining - 1),
    };
    const result = {
      ok: true,
      card: card,
      isNew: isNew,
      collection: response.collection,
      tickets: response.tickets,
      specialPacks: nextSpecialPackStats,
      specialPacksRemaining: nextSpecialPackStats.remaining,
    };
    if (requestCacheKey) CacheService.getScriptCache().put(requestCacheKey, JSON.stringify(result), 600);
    return result;
  } finally {
    lock.releaseLock();
  }
}

// ŌöĆŌöĆ DEV ņĀäņÜ®: isDev ņé¼ņÜ®ņ×ÉņØś ņ╣┤ļō£/ļĮæĻĖ░ĻČī ņ┤łĻĖ░ĒÖö ŌöĆŌöĆ
function devResetCards(userId) {
  if (!userId) return { ok: false, error: 'ļŗēļäżņ×äņØ┤ ņŚåņŖĄļŗłļŗż.' };
  if (!isUserDev_(userId)) return { ok: false, error: 'ĻČīĒĢ£ņØ┤ ņŚåņŖĄļŗłļŗż.' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
    const sheet = getOrCreateEventsSheet();
    const col = getEventsColumns_(sheet);
    const rows = getEventsRows_(sheet);
    const target = String(userId).trim().toLowerCase();
    const RESET_TYPES = {};
    RESET_TYPES[EVENT_TYPES.CARD_DRAWN]      = true;
    RESET_TYPES[EVENT_TYPES.CARD_GRANTED]    = true;
    RESET_TYPES[EVENT_TYPES.CARD_REMOVED]    = true;
    RESET_TYPES[EVENT_TYPES.TICKET_GRANTED]  = true;
    RESET_TYPES[EVENT_TYPES.TICKET_CONSUMED] = true;

    let removed = 0;
    for (let i = rows.length - 1; i >= 0; i--) {
      const rowUserId = String(rows[i][col.userId] || '').trim().toLowerCase();
      const rowType = String(rows[i][col.type] || '');
      if (rowUserId === target && RESET_TYPES[rowType]) {
        sheet.deleteRow(i + SCHEMA.EVENTS.dataStartRow);
        removed++;
      }
    }

    const raffleRelease = revokeUserRaffleTickets_(userId, 'available', 'dev_reset');
    const rebuildResult = rebuildCollectionRow_(userId);
    const response = collectionResponseFromSnapshot_(rebuildResult && rebuildResult.projected);
    return {
      ok: true,
      removed: removed,
      raffleReleased: Number(raffleRelease && raffleRelease.revoked) || 0,
      collection: response.collection,
      tickets: response.tickets,
    };
  } finally {
    lock.releaseLock();
  }
