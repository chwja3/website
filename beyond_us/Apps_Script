// ─ 셔플 헬퍼 (Fisher-Yates)
function _shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

// ─ TF(isStaff=TRUE) 원형 순환 매칭 후 BBB 시트에 기록
// GAS 에디터에서 한 번만 실행
function setupBBBMatching() {
  const userSheet = getSpreadsheet().getSheetByName('Users');
  const data      = userSheet.getDataRange().getValues();

  // isTFRetreat=TRUE 인 유저 추출 (A=nickname, C=name, G=isTFRetreat)
  const staff = [];
  for (let i = 1; i < data.length; i++) {
    if (data[i][6] === true && data[i][0]) {
      staff.push({ nickname: String(data[i][0]).trim(), name: String(data[i][2]).trim() });
    }
  }
  if (staff.length < 2) return { error: 'isTFRetreat=TRUE 인원이 2명 이상이어야 합니다.' };

  // 원형 순환 매칭: 셔플 후 i → (i+1)%n 방식 → 자기 자신 배정 불가
  _shuffle(staff);
  const n = staff.length;

  const bbbSheet = getOrCreateBBBSheet();
  // 기존 데이터 초기화 (헤더 제외)
  if (bbbSheet.getLastRow() > 1) {
    bbbSheet.getRange(2, 1, bbbSheet.getLastRow() - 1, 6).clearContent();
  }

  // i의 케어버디 = (i+1)%n, i의 시크릿버디 = (i-1+n)%n
  const rows = staff.map((person, i) => {
    const careBuddy   = staff[(i + 1) % n];
    const secretBuddy = staff[(i - 1 + n) % n];
    return [person.nickname, careBuddy.nickname, careBuddy.name, false, secretBuddy.nickname, secretBuddy.name];
  });
  bbbSheet.getRange(2, 1, rows.length, 6).setValues(rows);

  Logger.log('BBB 매칭 완료: ' + rows.map(r => r[0] + ' → 케어:' + r[2] + ' / 시크릿:' + r[5]).join(', '));
  return { ok: true, matched: rows.length, pairs: rows.map(r => ({ from: r[0], careBuddy: r[2] })) };
}

// ─ 내 BBB 정보 조회
function getBBB(userId) {
  const bbbSheet = getOrCreateBBBSheet();
  const last = bbbSheet.getLastRow();
  if (last < 2) return { ok: false, error: '매칭 정보가 없어요.' };

  const rows = bbbSheet.getRange(2, 1, last - 1, 6).getValues();

  // 내 row 찾기 (E=secretBuddyId, F=secretBuddyName 포함)
  let myRow = null, myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === userId) { myRow = rows[i]; myRowIdx = i; break; }
  }
  if (!myRow) return { ok: false, error: '매칭 정보가 없어요.' };

  const revealed        = myRow[3] === true;
  const secretBuddyId   = String(myRow[4] || '');
  const secretBuddyName = String(myRow[5] || '');

  // 내 케어버디가 나를 시크릿버디로 맞혔는지 (= 내가 들켰는지)
  // 케어버디 row에서 secretBuddyId === userId 이고 secretRevealed === true 인지 확인
  const careBuddyId = String(myRow[1]);
  let caughtByBuddy = false;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === careBuddyId) {
      caughtByBuddy = rows[i][3] === true;
      break;
    }
  }

  // BBB 메시지 오픈 여부
  const configSheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const msgOpen = configSheet.getRange('C1').getValue() === true;

  return {
    ok: true,
    careBuddy: {
      nickname: careBuddyId,
      name:     String(myRow[2])
    },
    secretBuddy: secretBuddyId ? {
      revealed,
      name:     revealed ? secretBuddyName : null,
      nickname: revealed ? secretBuddyId   : null
    } : null,
    caughtByBuddy,
    messageOpen: msgOpen
  };
}

// ─ 시크릿버디 이름 맞추기
function guessBBBSecret(body) {
  const userId = String(body.userId || '').trim();
  const guess  = String(body.guess  || '').trim();
  if (!userId || !guess) return { error: '필수 항목이 누락됐어요.' };

  const bbbSheet = getOrCreateBBBSheet();
  const last = bbbSheet.getLastRow();
  if (last < 2) return { error: '매칭 정보가 없어요.' };

  const rows = bbbSheet.getRange(2, 1, last - 1, 4).getValues();

  // 내 row 찾기
  let myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === userId) { myRowIdx = i; break; }
  }
  if (myRowIdx < 0) return { error: '매칭 정보가 없어요.' };
  if (rows[myRowIdx][3] === true) return { ok: true, correct: true, alreadyRevealed: true };

  // 나를 케어버디로 갖는 사람 = 내 시크릿버디
  let secretBuddy = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][1]) === userId) { secretBuddy = rows[i]; break; }
  }
  if (!secretBuddy) return { error: '시크릿버디 정보가 없어요.' };

  // 닉네임 또는 이름으로 비교 (대소문자·공백 무시)
  const normalize = s => String(s).replace(/\s/g, '').toLowerCase();
  const secretNickname = String(secretBuddy[0]);

  // 시크릿버디의 이름(name)을 Users 시트에서 찾기
  const userSheet = getSpreadsheet().getSheetByName('Users');
  const userData  = userSheet.getDataRange().getValues();
  let secretName  = secretNickname;
  for (let i = 1; i < userData.length; i++) {
    if (String(userData[i][0]).trim() === secretNickname) {
      secretName = String(userData[i][2]).trim(); break;
    }
  }

  const correct = normalize(guess) === normalize(secretNickname) ||
                  normalize(guess) === normalize(secretName);

  if (correct) {
    // secretRevealed = TRUE 기록
    bbbSheet.getRange(myRowIdx + 2, 4).setValue(true);
    return { ok: true, correct: true, secretName, secretNickname };
  }
  return { ok: true, correct: false };
}

// ─ 케어버디에게 익명 메시지 전송
function sendBBBMessage(body) {
  const userId  = String(body.userId  || '').trim();
  const message = String(body.message || '').trim();
  if (!userId || !message) return { error: '필수 항목이 누락됐어요.' };
  if (message.length > 300) return { error: '메시지는 300자 이하로 작성해주세요.' };

  // 메시지 오픈 여부 확인
  const configSheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  if (configSheet.getRange('C1').getValue() !== true)
    return { error: '지금은 메시지를 보낼 수 없어요. 관리자가 오픈할 때 다시 시도해주세요.' };

  // 케어버디 찾기
  const bbbSheet = getOrCreateBBBSheet();
  const last = bbbSheet.getLastRow();
  if (last < 2) return { error: '매칭 정보가 없어요.' };
  const rows = bbbSheet.getRange(2, 1, last - 1, 2).getValues();
  let careBuddyId = null;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) === userId) { careBuddyId = String(rows[i][1]); break; }
  }
  if (!careBuddyId) return { error: '매칭 정보가 없어요.' };

  const msgSheet = getOrCreateBBBMessagesSheet();
  const msgId = 'bm_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
  msgSheet.appendRow([msgId, userId, careBuddyId, message, new Date().toISOString()]);
  return { ok: true };
}

// ─ 내가 받은 익명 메시지 조회 (발신자 숨김)
function getBBBMessages(userId) {
  const msgSheet = getOrCreateBBBMessagesSheet();
  const last = msgSheet.getLastRow();
  if (last < 2) return { ok: true, messages: [] };
  const rows = msgSheet.getRange(2, 1, last - 1, 5).getValues();
  const messages = rows
    .filter(r => r[0] && String(r[2]) === userId)
    .map(r => ({ id: String(r[0]), message: String(r[3]), createdAt: String(r[4]) }))
    .sort((a, b) => b.createdAt.localeCompare(a.createdAt));
  return { ok: true, messages };
}

// ─ 어드민: 전체 매칭 + 메시지 로그 조회
function adminGetBBB() {
  const bbbSheet = getOrCreateBBBSheet();
  const msgSheet = getOrCreateBBBMessagesSheet();
  const configSheet = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);

  const lastB = bbbSheet.getLastRow();
  const matches = lastB < 2 ? [] :
    bbbSheet.getRange(2, 1, lastB - 1, 6).getValues()
      .filter(r => r[0])
      .map(r => ({
        userId: String(r[0]),
        careBuddyId: String(r[1]), careBuddyName: String(r[2]),
        secretRevealed: r[3] === true,
        secretBuddyId: String(r[4]), secretBuddyName: String(r[5])
      }));

  const lastM = msgSheet.getLastRow();
  const messages = lastM < 2 ? [] :
    msgSheet.getRange(2, 1, lastM - 1, 5).getValues()
      .filter(r => r[0])
      .map(r => ({ id: String(r[0]), from: String(r[1]), to: String(r[2]), message: String(r[3]), createdAt: String(r[4]) }))
      .sort((a, b) => b.createdAt.localeCompare(a.createdAt));

  const messageOpen = configSheet.getRange('C1').getValue() === true;
  return { ok: true, matches, messages, messageOpen };
}

