function getCutoverSheetStatus_() {
  const ss = getSpreadsheet();
  const visible = [];
  const hidden = [];
  const missingVisible = [];
  const missingHidden = [];
  const visibleLegacySheets = [];

  FINAL_VISIBLE_SHEET_NAMES.forEach(function(name) {
    const sheet = ss.getSheetByName(name);
    if (!sheet) {
      missingVisible.push(name);
    } else {
      visible.push({ name: name, hidden: sheet.isSheetHidden(), lastRow: sheet.getLastRow() });
    }
  });

  FINAL_HIDDEN_SHEET_NAMES.forEach(function(name) {
    const sheet = ss.getSheetByName(name);
    if (!sheet) {
      missingHidden.push(name);
      return;
    }
    const item = { name: name, hidden: sheet.isSheetHidden(), lastRow: sheet.getLastRow() };
    hidden.push(item);
    if (!item.hidden) visibleLegacySheets.push(name);
  });

  return {
    visible: visible,
    hidden: hidden,
    missingVisible: missingVisible,
    missingHidden: missingHidden,
    visibleLegacySheets: visibleLegacySheets,
  };
}

