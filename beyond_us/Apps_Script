function normalizeBBBPhotoMissionType_(missionType) {
  const clean = String(missionType || '').trim();
  if (clean === 'm1') return { ok: true, missionType: clean, sectionKey: 'm1', bonusSource: 'bbb_photo' };
  if (clean === 'm2') return { ok: true, missionType: clean, sectionKey: 'm2', bonusSource: 'bbb_m2' };
  const m3Match = clean.match(/^m3_([0-6])$/);
  if (m3Match) {
    return {
      ok: true,
      missionType: clean,
      sectionKey: 'm3',
      bonusSource: 'bbb_m3',
      spotIndex: Number(m3Match[1]),
    };
  }
  return { ok: false, error: 'invalid_mission_type', missionType: clean };
}

function getBBBMatchForUser_(userId) {
  const cleanUserId = String(userId || '').trim();
  if (!cleanUserId) return { ok: false, error: 'missing_userId' };

  const bbbSheet = getOrCreateBBBSheet();
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { ok: false, error: 'no_match' };

  const bbbCol = getBbbColumns_(bbbSheet);
  const rows = getBbbRows_(bbbSheet);
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (String(row[bbbCol.userId]).trim() !== cleanUserId) continue;
    const careBuddyId = String(row[bbbCol.careBuddyId] || '').trim();
    if (!careBuddyId) return { ok: false, error: 'no_match' };
    return {
      ok: true,
      rowIndex: i + SCHEMA.BBB.dataStartRow,
      careBuddyId: careBuddyId,
      careBuddyName: String(row[bbbCol.careBuddyName] || '').trim(),
    };
  }
  return { ok: false, error: 'no_match' };
}

function validateBBBPhotoUpload_(userId, missionType) {
  const normalized = normalizeBBBPhotoMissionType_(missionType);
  if (!normalized.ok) return normalized;

  const sections = getBBBSectionSettingsMap_();
  const section = sections[normalized.sectionKey];
  if (!section || section.open !== true) {
    return {
      ok: false,
      error: 'not_open',
      missionType: normalized.missionType,
      sectionKey: normalized.sectionKey,
    };
  }

  const match = getBBBMatchForUser_(userId);
  if (!match.ok) {
    return {
      ok: false,
      error: match.error || 'no_match',
      missionType: normalized.missionType,
      sectionKey: normalized.sectionKey,
    };
  }

  normalized.match = match;
  return normalized;
}

function isBBBPhotoRewardEvent_(event) {
  if (!event || event.type !== EVENT_TYPES.TICKET_GRANTED) return false;
  const legacySource = String((event.payload && event.payload.legacySource) || '').trim();
  return BBB_PHOTO_REWARD_SOURCES.indexOf(legacySource) !== -1 && eventAmount_(event, 1) > 0;
}

function getBBBRewardMissionTypeFromEvent_(event) {
  const payload = (event && event.payload) || {};
  const missionType = String(payload.missionType || '').trim();
  if (missionType) return missionType;
  const legacySource = String(payload.legacySource || '').trim();
  if (legacySource === 'bbb_photo') return 'm1';
  if (legacySource === 'bbb_m2') return 'm2';
  if (legacySource === 'bbb_m3') return 'm3_0';
  return '';
}

function hasBBBRewardRevokeEvent_(eventId, events) {
  const cleanEventId = String(eventId || '').trim();
  if (!cleanEventId) return false;
  return (events || []).some(function(event) {
    if (event.type !== EVENT_TYPES.TICKET_GRANTED) return false;
    if (eventAmount_(event, 1) >= 0) return false;
    return String((event.payload && event.payload.revokedEventId) || '').trim() === cleanEventId;
  });
}

function auditBBBPhotoRewardSecurity_() {
  const events = Events_readAll_();
  const invalidRewards = [];
  let checked = 0;
  events.forEach(function(event) {
    if (!isBBBPhotoRewardEvent_(event)) return;
    checked++;
    const eventId = String(event.eventId || '').trim();
    if (hasBBBRewardRevokeEvent_(eventId, events)) return;
    const missionType = getBBBRewardMissionTypeFromEvent_(event);
    const validation = validateBBBPhotoUpload_(event.userId, missionType);
    if (validation.ok) return;
    invalidRewards.push({
      eventId: eventId,
      timestamp: event.timestamp,
      userId: event.userId,
      amount: eventAmount_(event, 1),
      legacySource: String((event.payload && event.payload.legacySource) || '').trim(),
      missionType: missionType,
      error: validation.error,
      sectionKey: validation.sectionKey || '',
    });
  });
  return {
    ok: true,
    checked: checked,
    invalidCount: invalidRewards.length,
    invalidRewards: invalidRewards,
  };
}

function auditBBBPhotoRewardSecurity() {
  return logJsonResult_('auditBBBPhotoRewardSecurity result', auditBBBPhotoRewardSecurity_());
}

function revokeInvalidBBBPhotoRewardsDryRun() {
  const audit = auditBBBPhotoRewardSecurity_();
  return logJsonResult_('revokeInvalidBBBPhotoRewardsDryRun result', Object.assign({ dryRun: true }, audit));
}

function revokeInvalidBBBPhotoRewardsApply() {
  const audit = auditBBBPhotoRewardSecurity_();
  const invalidRewards = audit.invalidRewards || [];
  if (!invalidRewards.length) {
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', {
      ok: true,
      dryRun: false,
      revoked: 0,
      invalidCount: 0,
      affectedUsers: [],
    });
  }

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) {
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', { ok: false, error: '잠시 후 다시 시도해주세요.' });
  }

  try {
    const now = new Date().toISOString();
    const affectedUsers = {};
    const revoked = [];
    invalidRewards.forEach(function(item) {
      const amount = Math.max(1, Math.abs(Number(item.amount) || 1));
      const event = Events_append_(EVENT_TYPES.TICKET_GRANTED, item.userId, {
        timestamp: now,
        amount: -amount,
        weekKey: '',
        payload: {
          reason: 'bbb_security_revoke',
          revokedEventId: item.eventId,
          revokedLegacySource: item.legacySource,
          missionType: item.missionType,
          validationError: item.error,
        },
        source: EVENT_SOURCES.ADMIN,
      });
      affectedUsers[item.userId] = true;
      revoked.push({ revokedEventId: item.eventId, revokeEventId: event.event.eventId, userId: item.userId, amount: amount });
    });
    Object.keys(affectedUsers).forEach(function(userId) {
      rebuildCollectionRow_(userId);
    });
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', {
      ok: true,
      dryRun: false,
      revoked: revoked.length,
      affectedUsers: Object.keys(affectedUsers),
      revokedEvents: revoked,
    });
  } finally {
    lock.releaseLock();
  }
}

// ─ BBB 사진 업로드 (missionType: 'm1'|'m2'|'m3_0'~'m3_6', 최초 1회만 뽑기권 지급)
function uploadBBBPhoto(body) {
  const userId      = String(body.userId      || '').trim();
  const photo       = String(body.photo       || '').trim();
  const missionType = String(body.missionType || 'm1').trim();
  if (!userId || !photo) return { error: '필수 항목 누락.' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
    const validation = validateBBBPhotoUpload_(userId, missionType);
    if (!validation.ok) return validation;

    const photoSheet = getOrCreateBBBPhotosSheet();
    const photoCol = getBbbPhotoColumns_(photoSheet);
    const last = photoSheet.getLastRow();
    let existingRow = -1;
    if (last >= SCHEMA.BBB_PHOTOS.dataStartRow) {
      const rows = getBbbPhotoRows_(photoSheet);
      for (let i = 0; i < rows.length; i++) {
        const mt = String(rows[i][photoCol.missionType] || 'm1');
        if (String(rows[i][photoCol.userId]) === userId && mt === missionType) { existingRow = i + SCHEMA.BBB_PHOTOS.dataStartRow; break; }
      }
    }

    const now = new Date().toISOString();
    if (existingRow === -1) {
      photoSheet.appendRow([userId, photo, now, missionType]);
    } else {
      photoSheet.getRange(existingRow, photoCol.photoBase64 + 1).setValue(photo);
      photoSheet.getRange(existingRow, photoCol.uploadedAt + 1).setValue(now);
    }

    // Events 기준 중복 지급 방지
    const bonusSource = validation.bonusSource;
    const alreadyRewarded = hasBonusTicketGrant_(userId, bonusSource, '');

    let rewarded = false;
    if (!alreadyRewarded) {
      // m3는 7개 스팟 모두 채워야 지급
      if (missionType.startsWith('m3_')) {
        const pSheet = getOrCreateBBBPhotosSheet();
        const pLast = pSheet.getLastRow();
        let filledSpots = 0;
        if (pLast >= SCHEMA.BBB_PHOTOS.dataStartRow) {
          const pCol = getBbbPhotoColumns_(pSheet);
          const pRows = getBbbPhotoRows_(pSheet);
          for (let s = 0; s < 7; s++) {
            const found = pRows.some(function(r) {
              return String(r[pCol.userId]) === userId && String(r[pCol.missionType]) === 'm3_' + s && String(r[pCol.photoBase64]);
            });
            if (found) filledSpots++;
          }
        }
        if (filledSpots >= 7) {
          Events_append_(EVENT_TYPES.TICKET_GRANTED, userId, {
            timestamp: now,
            amount: 1,
            weekKey: '',
            payload: {
              reason: 'bbb_mission',
              legacySource: bonusSource,
              missionType: missionType,
            },
            source: EVENT_SOURCES.WEB,
          });
          rebuildCollectionRow_(userId);
          rewarded = true;
        }
      } else {
        Events_append_(EVENT_TYPES.TICKET_GRANTED, userId, {
          timestamp: now,
          amount: 1,
          weekKey: '',
          payload: {
            reason: bonusSource === 'bbb_photo' ? 'bbb_photo' : 'bbb_mission',
            legacySource: bonusSource,
            missionType: missionType,
          },
          source: EVENT_SOURCES.WEB,
        });
        rebuildCollectionRow_(userId);
        rewarded = true;
      }
    }

    return { ok: true, rewarded };
  } finally {
    lock.releaseLock();
  }
}

function deleteBBBPhoto(body) {
  const userId      = String(body.userId      || '').trim();
  const missionType = String(body.missionType || 'm1').trim();
  if (!userId) return { error: '필수 항목 누락.' };
  const photoSheet = getOrCreateBBBPhotosSheet();
  const photoCol = getBbbPhotoColumns_(photoSheet);
  const last = photoSheet.getLastRow();
