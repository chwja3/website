function getBonusDrawCount(userId) {
  return Events_readByUser(userId).filter(function(event) {
    return event.type === EVENT_TYPES.TICKET_GRANTED &&
      !!String((event.payload && event.payload.legacySource) || '').trim();
  }).length;
}

function hasBonusTicketGrant_(userId, legacySource, weekKey, userEvents) {
  const cleanUserId = String(userId || '').trim();
  const cleanSource = String(legacySource || '').trim();
  const cleanWeekKey = String(weekKey || '').trim();
  if (!cleanUserId || !cleanSource) return false;

  try {
    const events = userEvents || Events_readByUser(cleanUserId);
    const matchedEvent = events.some(function(event) {
      if (event.type !== EVENT_TYPES.TICKET_GRANTED) return false;
      if (cleanWeekKey && String(event.weekKey || '') !== cleanWeekKey) return false;
      return String((event.payload && event.payload.legacySource) || '') === cleanSource;
    });
    if (matchedEvent) return true;
  } catch(e) {}

  return false;
}

