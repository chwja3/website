function isBBBPhotoApprovalRequired_(missionType) {
  const clean = String(missionType || '').trim();
  return clean === 'm1' || clean === 'm2';
}

function normalizeBBBPhotoMissionType_(missionType) {
  const clean = String(missionType || '').trim();
  if (clean === 'm1') return { ok: true, missionType: clean, sectionKey: 'm1', bonusSource: 'bbb_photo' };
  if (clean === 'm2') return { ok: true, missionType: clean, sectionKey: 'm2', bonusSource: 'bbb_m2' };
  const m3Match = clean.match(/^m3_([0-6])$/);
  if (m3Match) {
    return {
      ok: true,
      missionType: clean,
      sectionKey: 'm3',
      bonusSource: 'bbb_m3',
      spotIndex: Number(m3Match[1]),
    };
  }
  return { ok: false, error: 'invalid_mission_type', missionType: clean };
}

function getBBBMatchForUser_(userId) {
  const cleanUserId = String(userId || '').trim();
  if (!cleanUserId) return { ok: false, error: 'missing_userId' };

  const bbbSheet = getOrCreateBBBSheet();
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { ok: false, error: 'no_match' };

  const bbbCol = getBbbColumns_(bbbSheet);
  const rows = getBbbRows_(bbbSheet);
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (String(row[bbbCol.userId]).trim() !== cleanUserId) continue;
    const careBuddyId = String(row[bbbCol.careBuddyId] || '').trim();
    if (!careBuddyId) return { ok: false, error: 'no_match' };
    return {
      ok: true,
      rowIndex: i + SCHEMA.BBB.dataStartRow,
      careBuddyId: careBuddyId,
      careBuddyName: String(row[bbbCol.careBuddyName] || '').trim(),
    };
  }
  return { ok: false, error: 'no_match' };
}

function validateBBBPhotoUpload_(userId, missionType) {
  const normalized = normalizeBBBPhotoMissionType_(missionType);
  if (!normalized.ok) return normalized;

  const sections = getBBBSectionSettingsMap_();
  const section = sections[normalized.sectionKey];
  if (!section || section.open !== true) {
    return {
      ok: false,
      error: 'not_open',
      missionType: normalized.missionType,
      sectionKey: normalized.sectionKey,
    };
  }

  const match = getBBBMatchForUser_(userId);
  if (!match.ok) {
    return {
      ok: false,
      error: match.error || 'no_match',
      missionType: normalized.missionType,
      sectionKey: normalized.sectionKey,
    };
  }

  normalized.match = match;
  return normalized;
}

function isBBBMissionRewardEventType_(type) {
  return type === EVENT_TYPES.TICKET_GRANTED
      || type === EVENT_TYPES.SPECIAL_PACK_GRANTED
      || type === EVENT_TYPES.CARD_GRANTED;
}

function isBBBPhotoRewardEvent_(event) {
  if (!event || !isBBBMissionRewardEventType_(event.type)) return false;
  const legacySource = String((event.payload && event.payload.legacySource) || '').trim();
  return BBB_PHOTO_REWARD_SOURCES.indexOf(legacySource) !== -1 && eventAmount_(event, 1) > 0;
}

function getBBBRewardMissionTypeFromEvent_(event) {
  const payload = (event && event.payload) || {};
  const missionType = String(payload.missionType || '').trim();
  if (missionType) return missionType;
  const legacySource = String(payload.legacySource || '').trim();
  if (legacySource === 'bbb_photo') return 'm1';
  if (legacySource === 'bbb_m2') return 'm2';
  if (legacySource === 'bbb_m3') return 'm3_0';
  return '';
}

function hasBBBRewardRevokeEvent_(eventId, events) {
  const cleanEventId = String(eventId || '').trim();
  if (!cleanEventId) return false;
  return (events || []).some(function(event) {
    if (!isBBBMissionRewardEventType_(event.type)) return false;
    if (eventAmount_(event, 1) >= 0) return false;
    return String((event.payload && event.payload.revokedEventId) || '').trim() === cleanEventId;
  });
}

function auditBBBPhotoRewardSecurity_() {
  const events = Events_readAll_();
  const invalidRewards = [];
  let checked = 0;
  events.forEach(function(event) {
    if (!isBBBPhotoRewardEvent_(event)) return;
    checked++;
    const eventId = String(event.eventId || '').trim();
    if (hasBBBRewardRevokeEvent_(eventId, events)) return;
    const missionType = getBBBRewardMissionTypeFromEvent_(event);
    const validation = validateBBBPhotoUpload_(event.userId, missionType);
    if (validation.ok) return;
    invalidRewards.push({
      eventId: eventId,
      timestamp: event.timestamp,
      userId: event.userId,
      amount: eventAmount_(event, 1),
      rewardType: event.type,
      legacySource: String((event.payload && event.payload.legacySource) || '').trim(),
      missionType: missionType,
      error: validation.error,
      sectionKey: validation.sectionKey || '',
    });
  });
  return {
    ok: true,
    checked: checked,
    invalidCount: invalidRewards.length,
    invalidRewards: invalidRewards,
  };
}

function auditBBBPhotoRewardSecurity() {
  return logJsonResult_('auditBBBPhotoRewardSecurity result', auditBBBPhotoRewardSecurity_());
}

function revokeInvalidBBBPhotoRewardsDryRun() {
  const audit = auditBBBPhotoRewardSecurity_();
  return logJsonResult_('revokeInvalidBBBPhotoRewardsDryRun result', Object.assign({ dryRun: true }, audit));
