function prodCutoverDryRun_(options) {
  const started = new Date().getTime();
  const rowLimit = Math.max(Number(options && options.rowLimit) || USER_DASHBOARD_DEFAULT_ROWS, 1);
  const steps = {};
  steps.scriptProperties = runCutoverStep_('scriptProperties', getScriptPropertiesStatus);
  steps.splitConfig = runCutoverStep_('splitConfigDryRun', function() {
    return migrate_step4_splitConfig({ dryRun: true });
  });
  steps.absorbToEvents = runCutoverStep_('absorbToEventsDryRun', function() {
    return migrate_step5_absorbToEvents({ dryRun: true });
  });
  steps.sheetStatus = runCutoverStep_('sheetStatusReadOnly', getCutoverSheetStatus_);
  return {
    ok: areCutoverStepsOk_(steps),
    dryRun: true,
    confirmRequiredForApply: PROD_CUTOVER_CONFIRM,
    rowLimit: rowLimit,
    steps: steps,
    elapsedMs: new Date().getTime() - started,
  };
}

function prodCutoverApply_(options) {
  const opts = options || {};
  if (String(opts.confirm || '').trim() !== PROD_CUTOVER_CONFIRM) {
    return {
      ok: false,
      error: 'missing_confirmation',
      requiredConfirm: PROD_CUTOVER_CONFIRM,
    };
  }

  const started = new Date().getTime();
  const rowLimit = Math.max(Number(opts.rowLimit) || USER_DASHBOARD_DEFAULT_ROWS, 1);
  const steps = {};

  steps.backup = runCutoverStep_('backupSpreadsheet', backupSpreadsheet);
  if (!steps.backup.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.splitConfig = runCutoverStep_('splitConfigApply', function() {
    return migrate_step4_splitConfig({ dryRun: false });
  });
  if (!steps.splitConfig.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.absorbToEvents = runCutoverStep_('absorbToEventsApply', function() {
    return migrate_step5_absorbToEvents({ dryRun: false });
  });
  if (!steps.absorbToEvents.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.rebuildCollection = runCutoverStep_('rebuildCollectionRowsFromEvents', rebuildCollectionRowsFromEvents_);
  if (!steps.rebuildCollection.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.setupUserDashboard = runCutoverStep_('setupUserDashboard', function() {
    return setupUserDashboard(rowLimit);
  });
  if (!steps.setupUserDashboard.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.applyFinalSheetVisibility = runCutoverStep_('applyFinalSheetVisibility', applyFinalSheetVisibility);
  if (!steps.applyFinalSheetVisibility.ok) return finishCutoverApply_(steps, rowLimit, started);

  steps.healthCheck = runCutoverStep_('prodCutoverHealthCheck', function() {
    return prodCutoverHealthCheck_({ rowLimit: rowLimit });
  });
  return finishCutoverApply_(steps, rowLimit, started);
}

function finishCutoverApply_(steps, rowLimit, started) {
  return {
    ok: areCutoverStepsOk_(steps),
    dryRun: false,
    rowLimit: rowLimit,
    steps: steps,
    elapsedMs: new Date().getTime() - started,
  };
}

function prodCutoverHealthCheck_(options) {
