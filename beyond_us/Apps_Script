  const bbbSections = getBBBSectionSettingsMap_();

  return {
    ok:          true,
    prayer:      tabMap.holdpray, // API ĒéżļŖö 'prayer' ņ£Āņ¦Ć (index.html/admin.html ĒśĖĒÖś)
    secret:      tabMap.secret,
    chat:        tabMap.chat,
    qt:          tabMap.qt,
    pilgrim:     tabMap.pilgrim,
    specialPack: tabMap.specialPack,
    bbbSections: bbbSections
  };
