function eventDateKey_(value) {
  if (value instanceof Date) return Utilities.formatDate(value, 'Asia/Seoul', 'yyyy-MM-dd');
  return String(value || '').trim();
}

function eventWeekKeyFromBonusSource_(source) {
  const match = String(source || '').match(/^hp_(w\d+)$/);
  return match ? match[1] : '';
}

function eventReasonFromBonusSource_(source) {
  const text = String(source || '');
  if (text.indexOf('hp_') === 0) return 'hp_correct';
  if (text === 'bbb_photo') return 'bbb_photo';
  if (text.indexOf('bbb_') === 0) return 'bbb_mission';
  return text || 'bonus';
}

function eventTradeTerminalType_(status) {
  const text = String(status || '').trim().toLowerCase();
  if (!text || text === 'pending') return '';
  if (text === 'accepted') return EVENT_TYPES.TRADE_ACCEPTED;
  if (text === 'rejected' || text.indexOf('거절') !== -1) return EVENT_TYPES.TRADE_REJECTED;
  if (text === 'cancelled' || text === 'canceled' || text.indexOf('취소') !== -1) return EVENT_TYPES.TRADE_CANCELLED;
  if (text === 'expired' || text.indexOf('시간') !== -1 || text.indexOf('초과') !== -1) return EVENT_TYPES.TRADE_EXPIRED;
  return EVENT_TYPES.TRADE_REJECTED;
}

function setupUserDashboard(rowLimit) {
  const limit = Math.max(Number(rowLimit) || USER_DASHBOARD_DEFAULT_ROWS, 1);
  const sheet = getOrCreateUserDashboardSheet_();
  ensureUserDashboardSheet_(sheet, limit);
  const result = {
    ok: true,
    sheetName: SHEET_NAMES.USER_DASHBOARD,
    rowsPrepared: limit,
    dataRange: 'A' + SCHEMA.USER_DASHBOARD.dataStartRow + ':AA' + (SCHEMA.USER_DASHBOARD.dataStartRow + limit - 1),
    firstUserFormula: sheet.getRange(SCHEMA.USER_DASHBOARD.dataStartRow, 1).getFormula(),
  };
  return logJsonResult_('setupUserDashboard result', result);
}

function getOrCreateUserDashboardSheet_() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.USER_DASHBOARD);
  if (!sheet) sheet = ss.insertSheet(SHEET_NAMES.USER_DASHBOARD);
  return sheet;
}

function ensureUserDashboardSheet_(sheet, rowLimit) {
  const schema = SCHEMA.USER_DASHBOARD;
  const requiredRows = schema.dataStartRow + rowLimit - 1;
  if (sheet.getMaxColumns() < USER_DASHBOARD_COL_COUNT) {
    sheet.insertColumnsAfter(sheet.getMaxColumns(), USER_DASHBOARD_COL_COUNT - sheet.getMaxColumns());
  }
  if (sheet.getMaxRows() < requiredRows) {
    sheet.insertRowsAfter(sheet.getMaxRows(), requiredRows - sheet.getMaxRows());
  }

  sheet.getRange(1, 1, requiredRows, USER_DASHBOARD_COL_COUNT).clearContent();
  sheet.getRange(1, 1, 1, USER_DASHBOARD_COL_COUNT).setValues([USER_DASHBOARD_LABELS.slice()]);
  sheet.getRange(schema.headerRow, 1, 1, USER_DASHBOARD_COL_COUNT).setValues([getSchemaHeaders_(schema)]);
  sheet.getRange(schema.dataStartRow, 1, rowLimit, USER_DASHBOARD_COL_COUNT).setFormulas(buildUserDashboardFormulas_(rowLimit));
  sheet.setFrozenRows(2);
  sheet.setFrozenColumns(3);
  sheet.setTabColor(USER_DASHBOARD_TAB_COLOR);
  applyUserDashboardFormatting_(sheet, rowLimit);
}

function buildUserDashboardFormulas_(rowLimit) {
  const formulas = [];
  for (let i = 0; i < rowLimit; i++) {
    const sheetRow = SCHEMA.USER_DASHBOARD.dataStartRow + i;
    const userRow = SCHEMA.USERS.dataStartRow + i;
    formulas.push(buildUserDashboardFormulaRow_(sheetRow, userRow));
  }
  return formulas;
}

function buildUserDashboardFormulaRow_(sheetRow, userRow) {
  const userCell = 'A' + sheetRow;
  const eventsUserRange = 'Events!C$3:C$' + USER_DASHBOARD_EVENT_MAX_ROW;
  const eventsTypeRange = 'Events!D$3:D$' + USER_DASHBOARD_EVENT_MAX_ROW;
  const eventsRefRange = 'Events!E$3:E$' + USER_DASHBOARD_EVENT_MAX_ROW;
  const eventsAmountRange = 'Events!F$3:F$' + USER_DASHBOARD_EVENT_MAX_ROW;
  const eventsTimeRange = 'Events!B$3:B$' + USER_DASHBOARD_EVENT_MAX_ROW;
  const tradesRequesterRange = 'Trades!B$2:B$' + USER_DASHBOARD_DOMAIN_MAX_ROW;
  const tradesTargetRange = 'Trades!E$2:E$' + USER_DASHBOARD_DOMAIN_MAX_ROW;
  const tradesStatusRange = 'Trades!H$2:H$' + USER_DASHBOARD_DOMAIN_MAX_ROW;

  const row = [
    '=IF(Users!A' + userRow + '="","",Users!A' + userRow + ')',
    '=IFERROR(VLOOKUP(' + userCell + ',Users!A:C,3,0),"")',
    '=IFERROR(VLOOKUP(' + userCell + ',Users!A:D,4,0),"")',
    '=IF(' + userCell + '="","",COUNTIFS(' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.MISSION_SUBMITTED + '"))',
    '=IF(' + userCell + '="","",SUMIFS(' + eventsAmountRange + ',' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.TICKET_GRANTED + '"))',
    '=IF(' + userCell + '="","",SUMIFS(' + eventsAmountRange + ',' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.TICKET_CONSUMED + '"))',
    '=IF(' + userCell + '="","",E' + sheetRow + '-F' + sheetRow + ')',
    '=IF(' + userCell + '="","",COUNTIFS(' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.CARD_DRAWN + '"))',
  ];

  for (let cardId = 1; cardId <= 10; cardId++) {
    const drawnCount = 'COUNTIFS(' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.CARD_DRAWN + '",' + eventsRefRange + ',"' + cardId + '")';
    const grantedSum = 'SUMIFS(' + eventsAmountRange + ',' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.CARD_GRANTED + '",' + eventsRefRange + ',"' + cardId + '")';
    const removedSum = 'SUMIFS(' + eventsAmountRange + ',' + eventsUserRange + ',' + userCell + ',' + eventsTypeRange + ',"' + EVENT_TYPES.CARD_REMOVED + '",' + eventsRefRange + ',"' + cardId + '")';
    row.push('=IF(' + userCell + '="","",MAX(0,' + drawnCount + '+' + grantedSum + '-' + removedSum + '))');
  }

  row.push(
    '=IF(' + userCell + '="","",SUM(I' + sheetRow + ':R' + sheetRow + '))',
    '=IF(' + userCell + '="","",COUNTIFS(' + tradesRequesterRange + ',' + userCell + ',' + tradesStatusRange + ',"pending")+COUNTIFS(' + tradesTargetRange + ',' + userCell + ',' + tradesStatusRange + ',"pending"))',
    '=IFERROR(INDEX(SORT(FILTER(' + eventsTimeRange + ',' + eventsUserRange + '=' + userCell + '),1,FALSE),1),"")',
    '=IFERROR(VLOOKUP(' + userCell + ',Collection!A:D,4,0),"")',
    '=IFERROR(VLOOKUP(' + userCell + ',Collection!A:N,14,0),"")',
    '=IFERROR(VLOOKUP(' + userCell + ',Collection!A:C,3,0),"")',
    '=IF(' + userCell + '="","",IF(N(G' + sheetRow + ')=N(V' + sheetRow + '),"✓","❌"))',
    '=IF(' + userCell + '="","",IF(N(S' + sheetRow + ')=N(W' + sheetRow + '),"✓","❌"))',
    '=IF(' + userCell + '="","",IF(N(H' + sheetRow + ')=N(X' + sheetRow + '),"✓","❌"))'
  );
  return row;
}

function applyUserDashboardFormatting_(sheet, rowLimit) {
  const schema = SCHEMA.USER_DASHBOARD;
  const dataRange = sheet.getRange(schema.dataStartRow, 1, rowLimit, USER_DASHBOARD_COL_COUNT);
  const checkRange = sheet.getRange(schema.dataStartRow, 25, rowLimit, 3);
  const rowRule = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied('=OR($Y3="❌",$Z3="❌",$AA3="❌")')
    .setBackground('#FFE0E0')
    .setRanges([dataRange])
    .build();
  const cellRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('❌')
    .setBackground('#FF4444')
    .setFontColor('#FFFFFF')
    .setRanges([checkRange])
    .build();
  sheet.setConditionalFormatRules([rowRule, cellRule]);
  sheet.getRange(1, 1, 2, USER_DASHBOARD_COL_COUNT).setFontWeight('bold');
  sheet.getRange(1, 1, 1, USER_DASHBOARD_COL_COUNT).setBackground('#DBEAFE');
  sheet.getRange(2, 1, 1, USER_DASHBOARD_COL_COUNT).setBackground('#EFF6FF');
}

function applyFinalSheetVisibility() {
  const ss = getSpreadsheet();
  const shown = [];
  const hidden = [];
  const missing = [];

  FINAL_VISIBLE_SHEET_NAMES.forEach(function(sheetName) {
    const sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      missing.push(sheetName);
      return;
    }
    sheet.showSheet();
    shown.push(sheetName);
  });

  FINAL_HIDDEN_SHEET_NAMES.forEach(function(sheetName) {
    const sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      missing.push(sheetName);
      return;
    }
    sheet.hideSheet();
    hidden.push(sheetName);
  });

  return logJsonResult_('applyFinalSheetVisibility result', {
    ok: true,
    shown: shown,
    hidden: hidden,
    missing: missing,
  });
}

