// pending 상태에서 5분(300초) 초과 시 자동 만료
function _expireOldTrades(sheet) {
  const last = sheet.getLastRow();
  if (last < 2) return;
  const rows = sheet.getRange(2, 1, last - 1, 10).getValues();
  const now  = Date.now();
  const TIMEOUT_MS = 5 * 60 * 1000; // 5분
  rows.forEach((row, i) => {
    if (String(row[7]) !== 'pending') return;
    const createdAt = new Date(String(row[8])).getTime();
    if (isNaN(createdAt) || now - createdAt < TIMEOUT_MS) return;
    sheet.getRange(i + 2, 8).setValue('실패 (시간 초과)');
    sheet.getRange(i + 2, 10).setValue(new Date().toISOString());
  });
}

function getTrades(userId) {
  const sheet = getOrCreateTradesSheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { ok: true, incoming: [], outgoing: [] };

  _expireOldTrades(sheet);
  const rows = sheet.getRange(2, 1, last - 1, 12).getValues();
  const incoming = [], outgoing = [];
  rows.forEach(row => {
    if (!row[0]) return;
    const t = {
      id: String(row[0]), requester: String(row[1]),
      requesterCardId: Number(row[2]), requesterCardName: String(row[3]),
      target: String(row[4]),
      targetCardId: Number(row[5]), targetCardName: String(row[6]),
      status: String(row[7]), createdAt: String(row[8]), resolvedAt: String(row[9]),
      requesterPrayed: !!row[10], targetPrayed: !!row[11]
    };
    if (t.target   === userId) incoming.push(t);
    if (t.requester === userId) outgoing.push(t);
  });
  incoming.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
  outgoing.sort((a, b) => b.createdAt.localeCompare(a.createdAt));

  // 완료된 교환에 상대방 H&P 기도제목 첨부
  // Users 시트에서 닉네임→실명 실시간 조회 → 기도제목 매칭
  const hasAccepted = [...incoming, ...outgoing].some(function(t) { return t.status === 'accepted'; });
  if (hasAccepted) {
    const usersData = getSpreadsheet().getSheetByName('Users').getDataRange().getValues();
    const nickToName = {};
    for (var i = 1; i < usersData.length; i++) {
      if (usersData[i][0]) nickToName[String(usersData[i][0])] = String(usersData[i][2]);
    }
    [...incoming, ...outgoing].forEach(function(t) {
      if (t.status === 'accepted') {
        const otherNick = (t.target === userId) ? t.requester : t.target;
        const realName = nickToName[otherNick] || '';
        const entry = realName ? HOLD_PRAY_ENTRIES.find(function(e) { return e.n === realName; }) : null;
        t.otherPrayer = entry ? entry.c : '';
      }
    });
  }

  return { ok: true, incoming, outgoing };
}

function prayForTrade(body) {
  const tradeId  = String(body.tradeId  || '');
  const nickname = String(body.nickname || '').trim();
  if (!tradeId || !nickname) return { error: 'missing params' };

  const sheet = getOrCreateTradesSheet();
