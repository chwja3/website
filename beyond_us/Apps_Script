function getNotices() {
  const cacheKey = cacheKey_('notices_v1');
  const cached = cacheGetJson_(cacheKey);
  if (cached) return cached;

  const sheet = getOrCreateNoticeSheet();
  const last = sheet.getLastRow();
  if (last < SCHEMA.NOTICES.dataStartRow) {
    const emptyResult = { ok: true, notices: [] };
    cachePutJson_(cacheKey, emptyResult, 30);
    return emptyResult;
  }
  const col = getNoticeColumns_(sheet);
  const rows = getNoticeRows_(sheet);
  const notices = rows
    .filter(r => r[col.id])
    .map((r, i) => ({
      rowIndex: i + SCHEMA.NOTICES.dataStartRow,
      id: String(r[col.id]),
      title: r[col.title],
      content: r[col.content],
      createdAt: r[col.createdAt],
      imageUrl: r[col.imageUrl] || '',
      updatedAt: r[col.updatedAt] || r[col.createdAt]
    }))
    .reverse();
  const result = { ok: true, notices };
  cachePutJson_(cacheKey, result, 30);
  return result;
}

function postNotice(body) {
  const title   = String(body.title   || '').trim();
  const content = String(body.content || '').trim();
  if (!title || !content) return { error: 'missing_fields' };

  let imageUrl = String(body.imageUrl || '').trim();
  if (!imageUrl && body.imageFiles && body.imageFiles.length) {
    try {
      const urls = uploadMultipleImages(body.imageFiles);
      imageUrl = JSON.stringify(urls);
    } catch(e) {
      Logger.log('Drive upload error: ' + e);
      return { error: 'drive_upload_failed', detail: String(e) };
    }
  }

  const sheet = getOrCreateNoticeSheet();
  const now = new Date().toISOString();
  sheet.appendRow([new Date().getTime(), title, content, now, imageUrl, now]);
  clearNoticesCache_();
  return { ok: true };
}

function deleteNotice(body) {
  const rowIndex = Number(body.rowIndex);
  if (!rowIndex || rowIndex < 2) return { error: 'invalid_row' };
  const sheet = getOrCreateNoticeSheet();
  const col = getNoticeColumns_(sheet);
  const imageUrl = String(sheet.getRange(rowIndex, col.imageUrl + 1).getValue() || '');
  sheet.deleteRow(rowIndex);
  deleteDriveImages(imageUrl);
  clearNoticesCache_();
  return { ok: true };
}

function deleteDriveImages(imageUrl) {
  if (!imageUrl) return;
  let urls = [];
  try { const p = JSON.parse(imageUrl); if (Array.isArray(p)) urls = p; } catch(e) {}
  if (!urls.length && imageUrl) urls = [imageUrl];
  urls.forEach(url => {
    const m = url.match(/[?&]id=([a-zA-Z0-9_-]+)/) || url.match(/thumbnail\?id=([a-zA-Z0-9_-]+)/);
    if (!m) return;
    try { DriveApp.getFileById(m[1]).setTrashed(true); } catch(e) { Logger.log('Drive delete error: ' + e); }
  });
}

