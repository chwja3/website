  if (tabSheet && tabSheet.getLastRow() >= SCHEMA.TAB_SETTINGS.dataStartRow) {
    const tabCol = getTabSettingsColumns_(tabSheet);
    getTabSettingsRows_(tabSheet).forEach(function(r) {
      const key = String(r[tabCol.key]).trim();
      if (Object.prototype.hasOwnProperty.call(tabMap, key)) tabMap[key] = r[tabCol.enabled] === true;
    });
  } else {
    const hpSetting = getAppSetting_(APP_SETTING_KEYS.HOLD_PRAY_OPEN, null);
    const secretSetting = getAppSetting_(APP_SETTING_KEYS.SECRET_OPEN, null);
