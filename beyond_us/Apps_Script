/**
 * Users 시트의 parish 컬럼(D)에서 "장년" → "목양교구" 일괄 치환.
 * Apps Script 에디터에서 직접 Run으로 실행 (1회성).
 * 실행한 GAS 프로젝트의 SPREADSHEET_ID Property가 가리키는 시트에 적용됨.
 */
function migrateParishJangnyeon() {
  const sheet = getSpreadsheet().getSheetByName(SHEET_NAMES.USERS);
  if (!sheet) throw new Error('Users 시트를 찾을 수 없습니다.');
  const last = sheet.getLastRow();
  const schema = SCHEMA.USERS;
  if (last < schema.dataStartRow) { Logger.log('Users 시트가 비어있음.'); return; }
  const col = getUserColumns_(sheet);
  const range = sheet.getRange(schema.dataStartRow, col.parish + 1, last - schema.dataStartRow + 1, 1);
  const values = range.getValues();
  let changed = 0;
  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0]).trim() === '장년') {
      values[i][0] = '목양교구';
      changed++;
    }
  }
  if (changed > 0) {
    range.setValues(values);
  }
  Logger.log('migrateParishJangnyeon 완료. 변경된 행 수: ' + changed + ' / 전체 ' + values.length);
}

function ensureUserSessionColumns_(sheet) {
  const col = getUserColumns_(sheet);
  const maxCol = Math.max(sheet.getLastColumn(), col.sessionUpdatedAt + 1);
  const headers = sheet.getRange(1, 1, 1, maxCol).getValues()[0];
  if (String(headers[col.sessionToken] || '') !== SCHEMA.USERS.columns.sessionToken) {
    sheet.getRange(SCHEMA.USERS.headerRow, col.sessionToken + 1).setValue(SCHEMA.USERS.columns.sessionToken);
  }
  if (String(headers[col.sessionUpdatedAt] || '') !== SCHEMA.USERS.columns.sessionUpdatedAt) {
    sheet.getRange(SCHEMA.USERS.headerRow, col.sessionUpdatedAt + 1).setValue(SCHEMA.USERS.columns.sessionUpdatedAt);
  }
}

function findUserRow_(sheet, nickname) {
  const clean = String(nickname || '').trim();
  if (!clean) return -1;
  const last = sheet.getLastRow();
  const schema = SCHEMA.USERS;
  if (last < schema.dataStartRow) return -1;
  const col = getUserColumns_(sheet);
  const ids = sheet.getRange(schema.dataStartRow, col.nickname + 1, last - schema.dataStartRow + 1, 1).getValues();
  for (let i = 0; i < ids.length; i++) {
    if (String(ids[i][0]).trim() === clean) return i + schema.dataStartRow;
  }
  return -1;
}

function makeSessionToken_() {
  return Utilities.getUuid().replace(/-/g, '') + Utilities.getUuid().replace(/-/g, '');
}

/**
 * Column H의 sessionToken 셀을 토큰 문자열 배열로 파싱.
 * 신규 포맷: JSON 배열 ["tokA","tokB",...]
 * 구버전 포맷: 단일 문자열 → [단일문자열] 로 자동 wrap (backward compat)
 */
function parseTokenArray_(cellValue) {
  const raw = String(cellValue || '').trim();
  if (!raw) return [];
  if (raw.charAt(0) === '[') {
    try {
      const arr = JSON.parse(raw);
      if (Array.isArray(arr)) return arr.filter(function(t) { return typeof t === 'string' && t.length > 0; });
    } catch(e) { /* fall through to single-string handling */ }
  }
  return [raw]; // 구버전 단일 토큰 호환
}

function serializeTokenArray_(arr) {
  if (!Array.isArray(arr) || arr.length === 0) return '';
  return JSON.stringify(arr);
}

const MAX_TOKENS_PER_USER = 10;

function issueSessionToken_(sheet, rowIndex) {
  ensureUserSessionColumns_(sheet);
  const col = getUserColumns_(sheet);
  const existing = sheet.getRange(rowIndex, col.sessionToken + 1).getValue();
  const tokens = parseTokenArray_(existing);
  const newToken = makeSessionToken_();
  tokens.push(newToken);
  // 가장 오래된 것부터 evict, 최신 MAX_TOKENS_PER_USER 개 유지
  const trimmed = tokens.length > MAX_TOKENS_PER_USER
    ? tokens.slice(tokens.length - MAX_TOKENS_PER_USER)
    : tokens;
  sheet.getRange(rowIndex, col.sessionToken + 1).setValue(serializeTokenArray_(trimmed));
  sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).setValue(new Date().toISOString());
  return newToken;
}

function clearSessionToken_(sheet, rowIndex) {
  ensureUserSessionColumns_(sheet);
  const col = getUserColumns_(sheet);
  sheet.getRange(rowIndex, col.sessionToken + 1).clearContent();
  sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).clearContent();
}

function touchSessionToken_(sheet, rowIndex) {
  ensureUserSessionColumns_(sheet);
  const col = getUserColumns_(sheet);
  sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).setValue(new Date().toISOString());
}

function verifySession(nickname, sessionToken) {
  const cleanToken = String(sessionToken || '').trim();
  if (!String(nickname || '').trim() || !cleanToken) return false;
  try {
    const sheet = getUsersSheet_();
    const rowIndex = findUserRow_(sheet, nickname);
    if (rowIndex < 2) return false;
    const col = getUserColumns_(sheet);
    const rawTokens = sheet.getRange(rowIndex, col.sessionToken + 1).getValue();
    const updatedAt = sheet.getRange(rowIndex, col.sessionUpdatedAt + 1).getValue();
    const tokens = parseTokenArray_(rawTokens);
    if (tokens.indexOf(cleanToken) === -1) return false;

    const updatedMs = updatedAt instanceof Date ? updatedAt.getTime() : new Date(String(updatedAt || '')).getTime();
    if (!isNaN(updatedMs) && Date.now() - updatedMs > SESSION_MAX_AGE_MS) return false;
    return true;
  } catch(e) {
    return false;
  }
}

function requireSessionForUser_(source, userId) {
  const uid = String(userId || '').trim();
  if (!uid) return { error: 'missing_userId' };
  if (!verifySession(uid, source && source.sessionToken)) {
    return { error: 'unauthorized', authRequired: true };
  }
  return null;
}

function hasValidUserAuth_(body, nickname) {
  return verifySession(nickname, body && body.sessionToken) ||
         verifyUserPassword(nickname, body && body.password);
}

function cacheKey_(name, scope) {
