function getUserStatus(userId, weekKey) {
  const ss     = getSpreadsheet();
  const config = getConfig();
  let weekScore = 0, drawnThisWeek = false, weekCard = null;
  const collection = [];
  const todayItems   = [];
  const todayIndices = [];
  const weekDates    = [];

  const today = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyy-MM-dd');

  // 이번 주 월~일 범위 계산 (KST)
  const nowKST = new Date(new Date().getTime() + 9 * 60 * 60 * 1000);
  const dow = nowKST.getUTCDay() || 7;
  const monday = new Date(nowKST);
  monday.setUTCDate(nowKST.getUTCDate() - (dow - 1));
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  const weekStart = monday.toISOString().slice(0, 10);
  const weekEnd   = sunday.toISOString().slice(0, 10);

  // raw_checkins 전체 읽기 (이번 주 점수 + 오늘 항목 + 이월 계산에 재사용)
  // 10열까지 읽어 J열(ticketEarned) 포함
  let allRows = [];
  let earnedTicketThisWeek = false;
  try {
    const raw     = ss.getSheetByName(RAW_SHEET_NAME);
    const lastRow = raw.getLastRow();
    if (lastRow >= 2) {
      allRows = raw.getRange(2, 1, lastRow - 1, 10).getValues();
      for (const row of allRows) {
        if (String(row[3]) !== userId) continue;
        if (String(row[1]) === config.weekTitle) {
          weekScore += Number(row[6]) || 0;
          if (Number(row[9]) === 1) earnedTicketThisWeek = true; // J열 ticketEarned
          const rowDate = row[5] instanceof Date ? Utilities.formatDate(row[5], 'Asia/Seoul', 'yyyy-MM-dd') : String(row[5]).trim();
          // 이번 주 제출 날짜 수집
          if (rowDate >= weekStart && rowDate <= weekEnd && !weekDates.includes(rowDate)) {
            weekDates.push(rowDate);
          }
          if (rowDate === today) {
            try { JSON.parse(row[2] || '[]').forEach(item => {
              todayItems.push(item);
              // 인덱스 미저장 구 데이터: 현재 config 텍스트와 매칭해 인덱스 역추적
              const idx = config.items.indexOf(item);
              if (idx >= 0) todayIndices.push(idx);
            }); } catch(e) {}
            // 신규 데이터: 저장된 인덱스 추가 (텍스트 변경 후에도 유지)
            try { JSON.parse(row[7] || '[]').forEach(idx => { if (typeof idx === 'number') todayIndices.push(idx); }); } catch(e) {}
          }
        }
      }
    }
  } catch(e) {}

  // 카드 뽑기 이력 (drawnThisWeek, weekCard, 총 뽑기 수 카운트용)
  let totalDraws = 0;
  try {
    const draws = getOrCreateDrawSheet();
    const last  = draws.getLastRow();
    if (last >= 2) {
      const rows = draws.getRange(2, 1, last - 1, 5).getValues();
      for (const row of rows) {
        if (String(row[0]) !== userId) continue;
        totalDraws++;
        const card = SPIRIT_CARDS.find(c => c.id === Number(row[2]));
        if (!card) continue;
        if (String(row[1]) === weekKey) { drawnThisWeek = true; weekCard = card; }
      }
    }
  } catch(e) {}

  // 컬렉션 (Collection 시트에서 읽기 — 교환 결과 반영됨)
  try {
    const collCounts = getUserCollection(userId);
    SPIRIT_CARDS.forEach(card => {
      const cnt = collCounts[card.id] || 0;
      for (let j = 0; j < cnt; j++) collection.push({...card});
    });
  } catch(e) {}

  // 뽑기권 현황: Collection 시트 D열(남은개수) 직접 읽기
  let pendingDraws = 0;
  try {
    pendingDraws = getCollectionTickets(userId).remaining;
  } catch(e) {}

  return {
    ok: true,
    weekScore,
    drawThreshold: config.drawThreshold,
    canDraw: pendingDraws > 0,
    pendingDraws,
    earnedTicketThisWeek,
    drawnThisWeek,
    weekCard,
    collection,
    todayItems,
    todayIndices,
    weekDates
  };
}

function drawCard(userId, weekKey, testMode) {
  if (!userId) return { ok: false, error: '닉네임이 없습니다.' };

  const config = getConfig();
  const ss     = getSpreadsheet();

  // DEV 환경은 뽑기권 검증 스킵 (테스트 자유롭게)
  if (!_devMode) {
    const pendingDraws = getCollectionTickets(userId).remaining;
    if (pendingDraws <= 0) {
      return { ok: false, error: '사용 가능한 뽑기권이 없습니다.' };
    }
  }

  const drawableCards = SPIRIT_CARDS.filter(function(c) { return c.id !== 10; });
  const card = drawableCards[Math.floor(Math.random() * drawableCards.length)];

  // 뽑기 전 기존 보유 여부 확인 (isNew 계산용 — updateCollectionSheet 전에 읽어야 정확)
  let isNew = true;
  try {
    const existingCounts = getUserCollection(userId);
    isNew = !(existingCounts[card.id] > 0);
  } catch(e) {}

  // 항상 시트에 기록 (DEV → DEV 시트, PROD → PROD 시트)
  const draws = getOrCreateDrawSheet();
  draws.appendRow([userId, weekKey, card.id, card.name, new Date().toISOString()]);
  updateCollectionSheet(userId, card.id, 1);
  try { updateTicketCols(userId); } catch(e) {}
  return { ok: true, card, isNew };
}

