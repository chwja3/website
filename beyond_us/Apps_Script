function postHpHint(body) {
  const nickname  = String(body.nickname  || '').trim();
  const weekKey   = String(body.weekKey   || '').trim();
  const cardIndex = Number(body.cardIndex) || 0;
  if (!nickname || !weekKey) return { error: 'missing_fields' };

  // getHoldPrayņÖĆ ļÅÖņØ╝ĒĢ£ ļĪ£ņ¦üņ£╝ļĪ£ ĒĢ┤ļŗ╣ ņ╣┤ļō£ņØś ņŗżņĀ£ ņĀĢļŗĄ ĒÖĢņØĖ (Rendezvous hashing)
  const entries = getYouthHpEntries();
  const n = entries.length;
  const picked = [];
  const usedIdx = new Set();
  for (let i = 0; i < 3; i++) {
    const seed = weekKey + nickname + String(i);
    let bestScore = -1, bestIdx = 0;
    entries.forEach(function(e, idx) {
      if (usedIdx.has(idx)) return;
      const score = hashStr(seed + '\x00' + e.n + '\x00' + e.p);
      if (score > bestScore) { bestScore = score; bestIdx = idx; }
    });
    usedIdx.add(bestIdx);
    picked.push(entries[bestIdx]);
  }
  if (picked.every(function(e) { return e.a; })) {
    for (let j = 0; j < n; j++) {
      if (!usedIdx.has(j) && !entries[j].a) { picked[2] = entries[j]; break; }
    }
  }
  const target = picked[cardIndex];
  const answerInfo = target
    ? (target.a ? '(ņØĄļ¬ģ)' : target.n + ' (' + target.p + ')')
    : '(ĒÖĢņØĖļČłĻ░Ć)';

  const sheet = getOrCreateInquirySheet();
  const id = new Date().getTime();
  const content = '[H&P Ē×īĒŖĖ ņÜöņ▓Ł] ņŻ╝ņ░©: ' + weekKey + ', ņ╣┤ļō£: ' + (cardIndex + 1) + 'ļ▓ł | ņĀĢļŗĄ: ' + answerInfo;
  sheet.appendRow([id, nickname, content, new Date().toISOString(), '', '']);
  return { ok: true, id: String(id) };
}

function getInquiries(source) {
  const params = source || {};
  const adminAuthorized = isAdminAuthorized_(params.adminPw);
  const requester = String(params.nickname || params.userId || '').trim();
  const userAuthorized = !adminAuthorized && requester && verifySession(requester, params.sessionToken);
  if (!adminAuthorized && !userAuthorized) return { error: 'unauthorized', authRequired: true };

  const sheet = getOrCreateInquirySheet();
  const last  = sheet.getLastRow();
  if (last < SCHEMA.INQUIRIES.dataStartRow) return { ok: true, inquiries: [] };
  const col = getInquiryColumns_(sheet);
  const rows = getInquiryRows_(sheet);
  const inquiries = rows
    .map((r, i) => ({ row: r, rowIndex: i + SCHEMA.INQUIRIES.dataStartRow }))
    .filter(item => item.row[col.id])
    .filter(item => adminAuthorized || String(item.row[col.nickname]).trim() === requester)
    .map(item => ({
      rowIndex:  item.rowIndex,
      id:        String(item.row[col.id]),
      nickname:  String(item.row[col.nickname]),
      content:   String(item.row[col.content]),
      createdAt: item.row[col.createdAt],
      reply:     String(item.row[col.reply] || ''),
      repliedAt: item.row[col.repliedAt] || ''
    }))
    .reverse();
  return { ok: true, inquiries };
}

