// ŌöĆ TF(isStaff=TRUE) ņøÉĒśĢ ņł£ĒÖś ļ¦żņ╣Ł Ēøä BBB ņŗ£ĒŖĖņŚÉ ĻĖ░ļĪØ
// GAS ņŚÉļööĒä░ņŚÉņä£ ĒĢ£ ļ▓łļ¦ī ņŗżĒ¢ē
function setupBBBMatching() {
  const userSheet = getSpreadsheet().getSheetByName(SHEET_NAMES.USERS);
  const col       = getUserColumns_(userSheet);
  const data      = getUserRows_(userSheet);

  // isTFRetreat=TRUE ņØĖ ņ£ĀņĀĆ ņČöņČ£
  const staff = [];
  for (let i = 0; i < data.length; i++) {
    if (data[i][col.isDev] === true && data[i][col.nickname]) {
      staff.push({ nickname: String(data[i][col.nickname]).trim(), name: String(data[i][col.name]).trim() });
    }
  }
  if (staff.length < 2) return { error: 'isTFRetreat=TRUE ņØĖņøÉņØ┤ 2ļ¬ģ ņØ┤ņāüņØ┤ņ¢┤ņĢ╝ ĒĢ®ļŗłļŗż.' };

  // ņøÉĒśĢ ņł£ĒÖś ļ¦żņ╣Ł: ņģöĒöī Ēøä i ŌåÆ (i+1)%n ļ░®ņŗØ ŌåÆ ņ×ÉĻĖ░ ņ×ÉņŗĀ ļ░░ņĀĢ ļČłĻ░Ć
  _shuffle(staff);
  const n = staff.length;

  const bbbSheet = getOrCreateBBBSheet();
  // ĻĖ░ņĪ┤ ļŹ░ņØ┤Ēä░ ņ┤łĻĖ░ĒÖö (ĒŚżļŹö ņĀ£ņÖĖ)
  if (bbbSheet.getLastRow() >= SCHEMA.BBB.dataStartRow) {
    bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, bbbSheet.getLastRow() - SCHEMA.BBB.dataStartRow + 1, 6).clearContent();
  }

  // iņØś ņ╝Ćņ¢┤ļ▓äļöö = (i+1)%n, iņØś ņŗ£Ēü¼ļ”┐ļ▓äļöö = (i-1+n)%n
  const rows = staff.map((person, i) => {
    const careBuddy   = staff[(i + 1) % n];
    const secretBuddy = staff[(i - 1 + n) % n];
    return [person.nickname, careBuddy.nickname, careBuddy.name, false, secretBuddy.nickname, secretBuddy.name];
  });
  bbbSheet.getRange(SCHEMA.BBB.dataStartRow, 1, rows.length, 6).setValues(rows);

  Logger.log('BBB ļ¦żņ╣Ł ņÖäļŻī: ' + rows.map(function(r) {
    const [userId, , careBuddyName, , , secretBuddyName] = r;
    return userId + ' ŌåÆ ņ╝Ćņ¢┤:' + careBuddyName + ' / ņŗ£Ēü¼ļ”┐:' + secretBuddyName;
  }).join(', '));
  return {
    ok: true,
    matched: rows.length,
    pairs: rows.map(function(r) {
      const [userId, , careBuddyName] = r;
      return { from: userId, careBuddy: careBuddyName };
    })
  };
}

// ŌöĆ ļé┤ BBB ņĀĢļ│┤ ņĪ░ĒÜī
function getBBB(userId) {
  const bbbSheet = getOrCreateBBBSheet();
  const bbbCol = getBbbColumns_(bbbSheet);
  const last = bbbSheet.getLastRow();
  if (last < SCHEMA.BBB.dataStartRow) return { ok: false, error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };

  const rows = getBbbRows_(bbbSheet);

  // ļé┤ row ņ░ŠĻĖ░ (E=secretBuddyId, F=secretBuddyName ĒÅ¼ĒĢ©)
  let myRow = null, myRowIdx = -1;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === userId) { myRow = rows[i]; myRowIdx = i; break; }
  }
  if (!myRow) return { ok: false, error: 'ļ¦żņ╣Ł ņĀĢļ│┤Ļ░Ć ņŚåņ¢┤ņÜö.' };

  const revealed        = true; // ņ×äņŗ£ ņĀäņ▓┤ Ļ│ĄĻ░£
  const secretBuddyId   = String(myRow[bbbCol.secretBuddyId] || '');
  const secretBuddyName = String(myRow[bbbCol.secretBuddyName] || '');

  // ļé┤ ņ╝Ćņ¢┤ļ▓äļööĻ░Ć ļéśļź╝ ņŗ£Ēü¼ļ”┐ļ▓äļööļĪ£ ļ¦×ĒśöļŖöņ¦Ć (= ļé┤Ļ░Ć ļōżņ╝░ļŖöņ¦Ć)
  // ņ╝Ćņ¢┤ļ▓äļöö rowņŚÉņä£ secretBuddyId === userId ņØ┤Ļ│Ā secretRevealed === true ņØĖņ¦Ć ĒÖĢņØĖ
  const careBuddyId = String(myRow[bbbCol.careBuddyId]);
  let caughtByBuddy = false;
  for (let i = 0; i < rows.length; i++) {
    if (String(rows[i][bbbCol.userId]) === careBuddyId) {
      caughtByBuddy = rows[i][bbbCol.secretRevealed] === true;
      break;
    }
  }

  // BBB ļ®öņŗ£ņ¦Ć ņśżĒöł ņŚ¼ļČĆ
  const msgOpen = isBBBMessageOpen();

  // ļé┤ ņé¼ņ¦ä (M1 / M2 / M3 ņŖżĒī¤ 5Ļ░£)
  let myPhoto = null, myPhotoM2 = null;
  let myPhotoStatusM1 = '', myPhotoStatusM2 = '';
  const myPhotoM3 = [null, null, null, null, null, null, null];
  try {
    const photoSheet = getOrCreateBBBPhotosSheet();
    const pLast = photoSheet.getLastRow();
    if (pLast >= SCHEMA.BBB_PHOTOS.dataStartRow) {
      const photoCol = getBbbPhotoColumns_(photoSheet);
      const pRows = getBbbPhotoRows_(photoSheet);
      pRows.forEach(function(r) {
        if (String(r[photoCol.userId]) !== userId) return;
        const mt = String(r[photoCol.missionType] || 'm1');
        const src = String(r[photoCol.photoBase64]);
        if (mt === 'm1') {
          myPhoto = src;
          myPhotoStatusM1 = getBBBPhotoApprovalStatus_(r, photoCol, null);
        }
        else if (mt === 'm2') {
          myPhotoM2 = src;
          myPhotoStatusM2 = getBBBPhotoApprovalStatus_(r, photoCol, null);
        }
        else if (mt.startsWith('m3_')) {
          const idx = Number(mt.split('_')[1]);
          if (idx >= 0 && idx < 7) myPhotoM3[idx] = src;
        }
      });
    }
  } catch(e) {}

  // M1/M2/M3 ļĮæĻĖ░ĻČī ņłśļĀ╣ ņŚ¼ļČĆ
  let m1Rewarded = false, m2Rewarded = false, m3Rewarded = false;
  try {
    const bbbPhotoRewardMap = getBBBPhotoRewardEventMap_();
    m1Rewarded = !!bbbPhotoRewardMap[getBBBPhotoRewardEventKey_(userId, 'bbb_photo')];
    m2Rewarded = !!bbbPhotoRewardMap[getBBBPhotoRewardEventKey_(userId, 'bbb_m2')];
    m3Rewarded = !!bbbPhotoRewardMap[getBBBPhotoRewardEventKey_(userId, 'bbb_m3')];
  } catch(e) {}

  return {
    ok: true,
    myPhoto,
    myPhotoM2,
    myPhotoM3,
    m1Rewarded,
    m2Rewarded,
    m3Rewarded,
    m1ApprovalStatus: myPhoto ? (m1Rewarded ? 'approved' : (myPhotoStatusM1 || 'pending')) : '',
    m2ApprovalStatus: myPhotoM2 ? (m2Rewarded ? 'approved' : (myPhotoStatusM2 || 'pending')) : '',
    careBuddy: {
      nickname: careBuddyId,
      name:     String(myRow[bbbCol.careBuddyName])
    },
    secretBuddy: secretBuddyId ? {
      revealed,
      name:     revealed ? secretBuddyName : null,
