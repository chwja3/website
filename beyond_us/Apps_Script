  if (last < 2) return { error: 'not_found' };

  const rows = sheet.getRange(2, 1, last - 1, 5).getValues();
  for (var i = 0; i < rows.length; i++) {
    if (String(rows[i][0]) !== tradeId) continue;
    const requester = String(rows[i][1]);
    const target    = String(rows[i][4]);
    if (nickname === requester) {
      sheet.getRange(i + 2, 11).setValue(new Date().toISOString());
      return { ok: true };
    }
    if (nickname === target) {
      sheet.getRange(i + 2, 12).setValue(new Date().toISOString());
      return { ok: true };
    }
    return { error: 'unauthorized' };
  }
  return { error: 'not_found' };
}

function getAdminTrades() {
  const sheet = getOrCreateTradesSheet();
  const last  = sheet.getLastRow();
  if (last < 2) return { ok: true, trades: [] };

  _expireOldTrades(sheet);
  const rows = sheet.getRange(2, 1, last - 1, 10).getValues();
  const trades = rows
    .filter(r => r[0])
    .map(row => ({
      id: String(row[0]), requester: String(row[1]),
      requesterCardId: Number(row[2]), requesterCardName: String(row[3]),
      target: String(row[4]),
      targetCardId: Number(row[5]), targetCardName: String(row[6]),
      status: String(row[7]), createdAt: String(row[8]), resolvedAt: String(row[9])
    }));
  trades.sort((a, b) => b.createdAt.localeCompare(a.createdAt));
  return { ok: true, trades };
}

// ── 자동 백업 ─────────────────────────────────────
const BACKUP_FOLDER_NAME = 'BeyondUs_Backup';
const BACKUP_KEEP_COUNT  = 7; // 최근 N개만 유지

function backupSpreadsheet() {
  try {
    // 백업 폴더 찾기 (없으면 생성)
    let folder;
    const folders = DriveApp.getFoldersByName(BACKUP_FOLDER_NAME);
    folder = folders.hasNext() ? folders.next() : DriveApp.createFolder(BACKUP_FOLDER_NAME);

    const dateStr = Utilities.formatDate(new Date(), 'Asia/Seoul', 'yyyyMMdd_HHmm');

    // PROD 백업
    DriveApp.getFileById(SPREADSHEET_ID)
      .makeCopy('BeyondUs_PROD_' + dateStr, folder);
    _cleanOldBackups(folder, 'BeyondUs_PROD_');

    // DEV 백업
    DriveApp.getFileById(DEV_SPREADSHEET_ID)
      .makeCopy('BeyondUs_DEV_' + dateStr, folder);
    _cleanOldBackups(folder, 'BeyondUs_DEV_');

    Logger.log('백업 완료: ' + dateStr);
    return { ok: true, backed_up: dateStr };
  } catch(e) {
    Logger.log('백업 오류: ' + e);
    return { error: String(e) };
  }
}

function _cleanOldBackups(folder, prefix) {
  const files = [];
  const iter = folder.getFiles();
  while (iter.hasNext()) {
    const f = iter.next();
    if (f.getName().startsWith(prefix)) files.push(f);
  }
  files.sort((a, b) => a.getName() < b.getName() ? -1 : 1);
  while (files.length > BACKUP_KEEP_COUNT) {
    files.shift().setTrashed(true);
  }
}

