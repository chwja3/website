      const guessCol = getHpGuessColumns_(guessSheet);
      const rows = getHpGuessRows_(guessSheet);
      rows.forEach(function(r) {
        if (String(r[guessCol.nickname]) !== nickname || String(r[guessCol.weekKey]) !== weekKey) return;
        const cardIdx = Number(r[guessCol.cardIndex]);
        const storedGuess = String(r[guessCol.guessedName]);
        const currentEntry = pickedEntries[cardIdx];
        if (currentEntry && !currentEntry.a && currentEntry.n === storedGuess) {
          correctMap[cardIdx] = storedGuess;
        }
      });
    }
  }

  // ņØ┤ļ▓ł ņŻ╝ ļĮæĻĖ░ĻČī ņØ┤ļ»Ė ņłśļĀ╣ ņŚ¼ļČĆ ĒÖĢņØĖ (w3/w6)
  let ticketAlreadyAwarded = false;
  let ticketCardIdx = -1;
  if (nickname && (weekKey === 'w3' || weekKey === 'w6')) {
    const source = 'hp_' + weekKey;
    ticketAlreadyAwarded = hasBonusTicketGrant_(nickname, source, weekKey);
    if (ticketAlreadyAwarded) {
      const guessSheet = getOrCreateHPGuessesSheet();
      const gLast = guessSheet.getLastRow();
      if (gLast >= SCHEMA.HP_GUESSES.dataStartRow) {
        const guessCol = getHpGuessColumns_(guessSheet);
        const gRows = getHpGuessRows_(guessSheet);
        const myRows = gRows.filter(function(r) {
          return String(r[guessCol.nickname]) === nickname && String(r[guessCol.weekKey]) === weekKey;
        });
        if (myRows.length > 0) {
          myRows.sort(function(a, b) { return new Date(a[guessCol.answeredAt]) - new Date(b[guessCol.answeredAt]); });
          ticketCardIdx = Number(myRows[0][guessCol.cardIndex]);
        }
      }
    }
  }

  // Ē×īĒŖĖ ļŗĄļ│Ć ņĪ░ĒÜī
  const hintReplies = {};
  if (nickname) {
    const inqSheet = getOrCreateInquirySheet();
    const inqLast = inqSheet.getLastRow();
    if (inqLast >= SCHEMA.INQUIRIES.dataStartRow) {
      const inqCol = getInquiryColumns_(inqSheet);
      const inqRows = getInquiryRows_(inqSheet);
      inqRows.forEach(function(r) {
        if (String(r[inqCol.nickname]) !== nickname) return;
        const reply = String(r[inqCol.reply] || '').trim();
        if (!reply) return;
        const match = String(r[inqCol.content]).match(/ņŻ╝ņ░©: ([^,]+), ņ╣┤ļō£: (\d+)ļ▓ł/);
        if (match && match[1] === weekKey) {
          hintReplies[Number(match[2]) - 1] = reply;
        }
      });
    }
  }

  return { ok: true, weekKey, hpRevision, cards, correctMap, ticketAlreadyAwarded, ticketCardIdx, hintReplies };
}

function submitHoldPrayGuess(weekKey, guess, nickname, cardIndex) {
  if (!weekKey || !guess) return { ok: false, error: 'missing params' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' }; }

  try {
  const entries = getYouthHpEntries();
  const n = entries.length;
  const ci = Number(cardIndex) || 0;
  const usedIdx = new Set();
  const allEntryIdxs = [];

  // getHoldPrayņÖĆ ļÅÖņØ╝ĒĢśĻ▓ī 3ņ×ź ņĀäņ▓┤ ņäĀĒāØ (Rendezvous hashing)
  for (let i = 0; i < 3; i++) {
    const seed = weekKey + (nickname || '') + String(i);
    let bestScore = -1, bestIdx = 0;
    entries.forEach(function(e, idx) {
      if (usedIdx.has(idx)) return;
      const score = hashStr(seed + '\x00' + e.n + '\x00' + e.p);
      if (score > bestScore) { bestScore = score; bestIdx = idx; }
    });
    usedIdx.add(bestIdx);
    allEntryIdxs.push(bestIdx);
  }

  let entryIdx = allEntryIdxs[ci];

  // 3ņ×ź ļ¬©ļæÉ ņØĄļ¬ģņØ┤ļ®┤ ļ¦łņ¦Ćļ¦ē ņ╣┤ļō£ ĻĄÉņ▓┤ (getHoldPrayņÖĆ ļÅÖņØ╝)
  const allAnon = allEntryIdxs.every(function(i) { return entries[i].a; });
  if (allAnon && ci === 2) {
    for (let j = 0; j < n; j++) {
      if (!usedIdx.has(j) && !entries[j].a) {
        entryIdx = j;
        break;
      }
    }
  }

  const entry = entries[entryIdx];
  if (entry.a) return { ok: false, error: 'anon entry' };
  const correct = entry.n.replace(/\s/g, '').toLowerCase() === guess.trim().replace(/\s/g, '').toLowerCase();
  if (correct) {
    // ņĀĢļŗĄ ĻĖ░ļĪØ (Ēü¼ļĪ£ņŖż-ĻĖ░ĻĖ░ ļÅÖĻĖ░ĒÖöņÜ®) ŌĆö ņżæļ│Ą ļ░®ņ¦Ć
    const guessSheet = getOrCreateHPGuessesSheet();
    const last = guessSheet.getLastRow();
    let alreadyRecorded = false;
    if (last >= SCHEMA.HP_GUESSES.dataStartRow) {
      const guessCol = getHpGuessColumns_(guessSheet);
      const rows = getHpGuessRows_(guessSheet);
      alreadyRecorded = rows.some(function(r) {
        return String(r[guessCol.nickname]) === nickname && String(r[guessCol.weekKey]) === weekKey && Number(r[guessCol.cardIndex]) === ci;
      });
    }
    if (!alreadyRecorded) {
      const answeredAt = new Date().toISOString();
      guessSheet.appendRow([nickname, weekKey, ci, guess.trim(), answeredAt]);
      Events_append_(EVENT_TYPES.HP_GUESSED, nickname, {
        timestamp: answeredAt,
        weekKey: weekKey,
        payload: {
          cardIndex: ci,
          guessedName: guess.trim(),
        },
        source: EVENT_SOURCES.WEB,
      });
    }
  }
  let ticketAwarded = false;
  if (correct && (weekKey === 'w3' || weekKey === 'w6')) {
    const source = 'hp_' + weekKey;
    const alreadyAwarded = hasBonusTicketGrant_(nickname, source, weekKey);
    if (!alreadyAwarded) {
      const awardedAt = new Date().toISOString();
      Events_append_(EVENT_TYPES.TICKET_GRANTED, nickname, {
        timestamp: awardedAt,
        amount: 1,
        weekKey: weekKey,
        payload: {
          reason: 'hp_correct',
          legacySource: source,
        },
        source: EVENT_SOURCES.WEB,
      });
      rebuildCollectionRow_(nickname);
      ticketAwarded = true;
    }
  }
  return { ok: true, correct, ticketAwarded };
  } finally {
    lock.releaseLock();
  }
}

