 통하여서 하나님의 더 크신 뜻을 알아가길!","a":false,"nick":"햇님달님"},{"n":"임다혜","p":"2청","c":"1.친동생(임서준) 하나님 믿고 예수님 영접하길. 2.남편(서현덕,3청)과 서로 사랑하고 존중하며 오직 하나님만 섬기는 가정 세워나가길. 3. 졸업준비(6월 디펜스, 학위논문) 성실하게 잘 해내길 4. 졸업 이후 취업. 이끄시고 보내주시는 곳으로 가서 그 곳에서 예배할 수 있길. 5. 수련회 통해 하나님과 더 깊은 교제, 할 수 있길.","a":false,"nick":""},{"n":"임서경","p":"2청","c":"하나님의 예비하심을 믿고 살아갈 수 있도록 해주세요!","a":false,"nick":""},{"n":"장한나","p":"2청","c":"하나님의 사랑으로 가득 채워지는 수련회가 되길 기도합니다.","a":false,"nick":"장한나"},{"n":"정대호","p":"2청","c":"나의 힘으로 하려고 하기보다 하나님께 맡겨드릴 수 있게 + 할머니, 할아버지 영혼 구원.","a":false,"nick":"콘푸로스트1"},{"n":"조학준","p":"2청","c":"새로운 환경에 적응하고 있는 가운데, 걱정되고 불안한 일들이 많지만 나를 '사랑'하시는 주님의 함께하심을 믿고 잘 적응해가길 바랍니다.","a":false,"nick":""},{"n":"지윤성","p":"2청","c":"1. 세상의 신(돈, 사람들의 인정)이 아니라 하나님만 온전히 사랑할 수 있길 2. 사람을 만나고 대할 때에 필요한 지혜와 사랑의 마음을 주시기를. 3. 수면시간이 부족한데, 건강과 체력을 위하여.","a":false,"nick":"공도리곰도리"},{"n":"최가은","p":"2청","c":"하나님 성품을 더 닮아가고 싶어요. 제 안에 주님의 사랑이 더 가득해지도록 도와주세요.","a":false,"nick":"벳딸랑구"},{"n":"최보슬","p":"2청","c":"1. 매 순간 하나님이 우선이길 2. 삶의 예배가 회복되길","a":false,"nick":""},{"n":"한정인","p":"2청","c":"하나님을 믿지 않는 사랑하는 사람들이 예수님의 사랑을 알아봐주길.","a":false,"nick":"한정인"},{"n":"홍수연","p":"2청","c":"속해있는 공동체가 사랑으로 넘치도록","a":false,"nick":""},{"n":"임동표","p":"2청(사역자)","c":"수련회를 기도하며 준비하고 기쁘게 청년들을 섬길 수 있도록. 한 영혼도 놓치지 않고 끝까지 사랑으로 붙들 수 있도록 기도해주세요.","a":false,"nick":"나는목사다"},{"n":"곽지섭","p":"3청","c":"대학원 학위과정 중에 하나님의 계획과 인도하심을 경험할 수 있도록.","a":false,"nick":""},{"n":"김승현","p":"3청","c":"주님, 장인어른을 교회로 오게 하시니 감사드립니다. 아내의 순산도 믿습니다. 10분컷 순산.","a":false,"nick":""},{"n":"김아현","p":"3청","c":"불안해하거나 조급해하지 않길. 주변을 돌아보고 더 사랑할 수 있길. 계속 진행 중이지만 잘 해결되길. 진심으로 주님께 맡길 수 있길.","a":false,"nick":"애용"},{"n":"김영진","p":"3청","c":"염려, 불안, 걱정이 아닌 하나님의 사랑으로 세상이 줄 수 없는 평안 가운데 살아갈 수 있도록. 우리 가정이 하나님의 사랑으로 충만하여 그 사랑을 주위로 흘려보낼 수 있도록.","a":false,"nick":"초코맛꼬북칩"},{"n":"김은정","p":"3청","c":"믿음의 가정. 나만을 위함이 아닌 주변을 위한 믿음이 되길.","a":false,"nick":""},{"n":"김지훈","p":"3청","c":"성령 충만.","a":false,"nick":"김지훈D"},{"n":"김효정","p":"3청(2청?)","c":"1. 가족의 건강 지켜주시길 2. 동생의 편입 준비 함께해주시길 3. 법인 지원 고민에 답을 주셨으면 4. 일을 하면서 신앙과 타협해야 하는 경우가 있는데, 그러한 상황을 현명하게 헤쳐나갈 수 있길. 5. 사랑하는 친구들이 주님을 만날 수 있길.","a":false,"nick":""},{"n":"박민혁","p":"3청","c":"1. 웃는 삶 살기 2. 건강하기 3. 쿵후 잘하기 이 모든 것을 주님 안에서 이룰 수 있기를 기도합니다.","a":false,"nick":""},{"n":"서현덕","p":"3청","c":"제 시선이 항상 주님을 향하고, 성령님과 동행하며, 삶이 예배가 되게 하소서. 저희 가족이 주님을 경배하게 하시고, 하나님께서 기뻐하시는 공동체가 되게 하소서. 아직 주위에 믿지 않는 지체들이 많습니다. 하나님의 계획대로 그들이 교회로 올 수 있기를 간절히 기도합니다.","a":false,"nick":""},{"n":"안성재","p":"3청","c":"하나님께서 허락하신 가정과 교회와 직장에서 주님 다시 오실 길을 예비하는 예배자로 서게 하시고, 깨끗하고 순전한 마음으로 맡겨진 자리마다 충성할 수 있도록 기도해 주세요. 감사합니다.","a":false,"nick":"카니보어시즌2"},{"n":"양찬미","p":"3청","c":"주의 권능의 날에 주의 백성이 거룩한 옷을 입고 즐거이 헌신하니 새벽이슬 같은 주의 청년들이 주께 나오는도다(시 110:3) 큰은혜 아름다운 청년들을 주님의 이름으로 축복합니다.","a":false,"nick":""},{"n":"영빈","p":"3청","c":"무릎 회복","a":false,"nick":""},{"n":"윤시환","p":"3청","c":"제 삶의 계획을 가지고 계신 주님과 더욱 가까워질 수 있기를 기도합니다.","a":false,"nick":""},{"n":"윤영록","p":"3청","c":"가족과 가까운 친구들이 예수님을 아직 모릅니다. 하나님께서 콜링하실 때 응답하기를... 내게 맡겨진 영혼들을 더욱 힘써 섬길 수 있기를~.","a":false,"nick":"영화로운 사슴"},{"n":"이원철","p":"3청","c":"선교가게 해주세요ㅠㅠ","a":false,"nick":""},{"n":"이은서","p":"3청","c":"그냥 살 수 있기를.","a":false,"nick":""},{"n":"이지은","p":"3청","c":"가족의 평안. 큰오빠의 건강 회복. 졸업 연구와 체력. 믿음의 가정을 이룰 배우자.","a":false,"nick":""},{"n":"이찬영","p":"3청","c":"하나님이 원하시는 삶이 무엇인지 알도록. 기쁘고 평안.","a":false,"nick":"고양이"},{"n":"이평화","p":"3청","c":"미래에 대한 염려가 아닌 현재에 최선을 다하고 집중할 수 있기를, 먼저 그의 나라와 그의 의를 구하게 하소서.","a":false,"nick":""},{"n":"전도현","p":"3청","c":"스스로 흔들리지 않고 항상 하나님 우선으로 중심을 잡고 살 수 있도록.","a":false,"nick":"SingSangSong"},{"n":"정혜진","p":"3청","c":"내 신앙에 흔들림 없게 해주시고 내 신앙으로 인해 힘든 것이 아니라 위로를 받을 수 있도록 해주세요.","a":false,"nick":""},{"n":"조연주","p":"3청","c":"중심이 하나님이 되어 살아갈 수 있도록 해주세요. 사랑을 베풀 수 있도록 사랑으로 가득찬 마음을 주세요. 내가 가고자 하는 방향이 아닌 주님의 방향대로 잘 이끌어 주세요.","a":false,"nick":""},{"n":"주찬형","p":"3청","c":"1. 십자가 보혈의 은혜에 감사하며, 삶의 현장에서 예수님의 제자로 복음을 전하게 하소서 2. 합창단 정단원 합격과 국립합창단 청년단원 생활의 유종의 미를 거두게 하소서.","a":false,"nick":""},{"n":"천신원","p":"3청","c":"1. 일상에서 하나님의 사랑을 실천하고 주님과 항상 동행할 수 있도록 도와주세요. 2. 좋은 가정을 꾸릴 수 있도록 도와주세요.","a":false,"nick":""},{"n":"최한나","p":"3청","c":"함께 하나님의 일꾼으로 쓰임 받으며 믿음의 가정을 함께 세워나갈 배우자를 위해 기도합니다.","a":false,"nick":"한나둘셋넷"},{"n":"황주원","p":"3청","c":"1. 힘들 때일 수록 더욱 하나님과 가까이 하는 삶이 되기를. 2. 유아부 봉사를 좀 더 믿음으로 실천하기를 3. 언니의 가정이 다시 하나님을 섬기고 가까운 교회에서 신앙생활 하기를 4. 육신의 건강... (나와 가족, 친구... 주변인들 모두...)","a":false,"nick":""},{"n":"J","p":"4청","c":"주님의 사랑과 시선으로 공동체를 바라보고 섬길 수 있게 해주세요 거룩하고 정결하게 살아가게 하시고 주님의 영광을 위해 온전히 쓰임 받는 삶을 살게 해주세요","a":false,"nick":""},{"n":"404팀","p":"4청","c":"하나님이 나를 사랑하신다는 사실을 늘 기억하고 스스로를 사랑하길, 무엇을 하더라도 나의 생각과 판단이 아닌 하나님을 먼저 떠올릴 수 있기를, 논문 심사를 준비하는 과정에서 지혜를 주시고 마음에 평안함을 주시길, 우리 강아지가 조금만 덜 아프고 건강하게 말년을 보내게 도와주세요, 직장 문제...아시죠 하나님이 방식대로 잘 해결되게 해주세요.","a":false,"nick":""},{"n":"김광희","p":"4청","c":"AGC 청년 수련회 함께하는 청년들이 은혜와 감사가 가득하도록. 나의 시선이 주님께, 나의 것을 내려놓고 말씀 속 주님을 바라보는 예배자로 지혜와 은혜 더해주소서. 다른 것 근심, 염려 속지 않고 주님의 일하심을 믿고 행함이 있는 믿음 속에 살아가도록.","a":false,"nick":"광광"},{"n":"김동욱","p":"4청","c":"1. 좋은 배우자, 믿음의 배우자 만나도록 2. 믿음이 성장하고 복음 전파에 힘쓰도록 3. 하나님의 자녀로 그 신분에 걸맞게 살아가고, 하나님 뜻이 나의 뜻이 되는 삶이 되기를.","a":false,"nick":""},{"n":"김민희","p":"4청","c":"이직한 직장에 잘 적응할 수 있기를! 성가대 여호수아를 기쁘게 잘 섬기게 해주세요. 사람과의 관계에서 상처받지 않고 항상 감사하며 겸손하게 섬기게! 기도 드립니다.","a":false,"nick":""},{"n":"김진웅","p":"4청","c":"1. 하나님과 동행하는 내가 될 수 있도록 2. 새로 시작하는 일들 잘 해낼 수 있도록 3. 몸도 마음도 건강한 내가 될 수 있도록 4. 나와 타인 모두 용납하고 사랑할 수 있도록","a":false,"nick":""},{"n":"문진우","p":"4청","c":"1. 비전을 보여 주십시오 2. 염려하는 부분이 있는데 하나님 뜻대로 될 수 있게 3. 눈(시력) 회복","a":false,"nick":"문진우"},{"n":"박성온","p":"4청","c":"수련회를 기대하는 마음으로 준비, 하나님께서 주시는 지혜를 간구하며, 겸손히 준비할 수 있도록!","a":false,"nick":"on"},{"n":"박현우","p":"4청","c":"1. 가정의 화평과 발전, 새로운 생활을 위해 2. 맡은 학생들 심신이 건강하게 올해 보내고, 발전해가는 한해 되기를 3. 남동생이 이뤄갈 새 가정에도 하나님의 복이 있기를 4. 부모님 건강하게 신앙생활 잘 이어가시기를","a":false,"nick":""},{"n":"서지원","p":"4청","c":"1. 미국생활 잘 적응하고 안전하게 다녀오기 2. 모든 연구 결과를 통해 하나님 기쁨 되길! 3. 미국에서도 신앙생활 잘하기! 4. 배우자기도","a":false,"nick":""},{"n":"유하진","p":"4청","c":"하나님께서 제게 주신 기업을 열심히 일구어서 하나님께 영광 돌릴 수 있도록 해주세요! 하루하루 성실하게 최선을 다해 살아갈 수 있도록 건강 허락해주세요. 좋은 믿음의 배우자를 허락해주세요. -사랑하는 하진-","a":false,"nick":""},{"n":"유한나","p":"4청","c":"1. 부모님 건강 2. 개인의 발전 3. 주변 비기독교인 지인들의 삶속에 주님 들어가셔서 만나주시길 4. 꾸준한 신앙생활","a":false,"nick":""},{"n":"유형준","p":"4청","c":"가족 모두 건강하도록. 솜이(강아지)가 건강하기를 기도해주세요.","a":false,"nick":""},{"n":"이가희","p":"4청","c":"바쁜 5월 주님 주시는 지혜와 체력으로 잘 감당하기를. 나의 필요를 아시는 주님을 믿고 염려하지 않고 더욱 기도하는 예배자 되기를.","a":false,"nick":""},{"n":"이성영","p":"4청","c":"하나님과 더 가까워지고 우리 팀(셀)이 더 신앙의 성숙이 되었으면 좋겠습니다.","a":false,"nick":"이썽"},{"n":"이성호","p":"4청","c":"누나의 건강과 하는 일들이 잘 풀리고 행복만 가득하기를","a":false,"nick":""},{"n":"이세희","p":"4청","c":"마음의 기쁨과 평안함 주시기를 원합니다. 작은 것에 감사하는 자 되기를 원합니다. 늘 주님과 동행할 수 있기를 원하고 주님의 동행하심을 느끼는 자 되기를 원합니다. 하나님의 축복하심이 넘치길 소망합니다. 가정과 주변 사람들의 건강 지켜주시고 주님 안에서 모두 하나 되기를 소원합니다.","a":false,"nick":""},{"n":"임하련","p":"4청","c":"강건하고 평안하고 형통하고 맡은 바를 잘하고 가족이 모두 강건하기를.","a":false,"nick":""},{"n":"전승훈","p":"4청","c":"가족의 건강. 2세 만들기. 대학원 무사졸업. 여호수아 찬양대의 번영.","a":false,"nick":""},{"n":"정다운","p":"4청","c":"올해 성경 1독할 수 있게. 하나님과 더 가까워지고 잠깐 불타는 신앙이 아닌 평생 이어질 수 있도록. 믿음의 결실을 함께 나눌 배우자를 만날 수 있게 해주세요. 새벽기도 드리는 청년이 100명이 될 수 있게 부흥하길!!","a":false,"nick":"댜니"},{"n":"천혜영","p":"4청","c":"우리 가정에 뜻하신 일을 알게 하소서. 슬픔에 잠기지 않고 천국 소망 바라보며 날마다 감사하고 기뻐하는 삶이 되게 하소서. 나의 삶의 중심이 예배가 되게 하소서. 우리 팀원들의 삶속에 주의 인도하심을 통해 평안과 기쁨이 넘치게 하소서.","a":false,"nick":""},{"n":"최지호","p":"4청","c":"지성이(친동생)과 처남이 교회에 등록하고 하나님을 만나도록 기도해주세요.","a":false,"nick":"지호초이"},{"n":"허경웅","p":"4청","c":"1. 글쓰는 것을 좋아합니다. 문학공모전 등에서 수상 또는 책을 발간하는 기회가 오길. 2. 영어 등 외국어 공부 중입니다.","a":false,"nick":""},{"n":"허완","p":"4청","c":"1. 연애하게 해주세요 2. 학업 무사히 마치게 해주세요 3. 건강하고 지치지 않게 운동,컨디션 관리 잘하기 4. 꾸준히 신앙생활 잘 하기, 나태해지지 않기.","a":false,"nick":""},{"n":"이정실","p":"목양3교구","c":"우리 교회 모든 성도님들과 주위 이웃들이 아프지 않고 건강하기를 기도합니다! 청년들이 희망 잃지 않고 행복하기를!","a":false,"nick":""},{"n":"최혜선","p":"목양3교구","c":"1. 김경호집사(남편)가 예배를 잘 드렸으면 좋겠습니다(소년부 교사 후, 대예배 안드림). 2. 김이삭(아이)가 밥을 스스로 잘 먹고 즐거워했으면 좋겠습니다.","a":false,"nick":""},{"n":"","p":"*미기입","c":"하나님을 삶에 우선순위로 둘 수 있도록. 진로를 잘 인도해 주시기를. 예쁜 가정도 이룰 수 있도록.","a":true,"nick":""},{"n":"","p":"*미기입","c":"지치지 않고 주어진 것들을 감당할 힘과 지혜를 주시길, 앞으로 나아갈 용기를 불어넣어 주시길.","a":true,"nick":""},{"n":"","p":"*미기입","c":"서울 생활 잘 적응하고 믿음 생활 잘 하도록 도와주세요.","a":true,"nick":""},{"n":"","p":"*미기입","c":"새로운 분야를 공부할 때 지혜를 주시고 주님의 영광을 빛낼 일이 되길","a":true,"nick":""},{"n":"","p":"*미기입","c":"항상 건강하기 졸업 잘할 수 있도록 열심히 하기","a":true,"nick":""},{"n":"LLIKE","p":"*미기입","c":"Hope, I can always predict three steps ahead and make the right choice everytime.","a":false,"nick":""},{"n":"김노현","p":"*미기입","c":"몇 년 만에 교회를 다시 등록하게 되었습니다. 믿음 회복, 신앙생활 적응 잘할 수 있도록 기도합니다.","a":false,"nick":""},{"n":"김예지","p":"*미기입","c":"가족들의 건강회복","a":false,"nick":""},{"n":"김준범","p":"*미기입","c":"업무가 상당히 바쁜 와중에 지혜롭게 해결해나갈 수 있게 인도하여 주시길. 고난의 순간을 주님이 예비하신 길로 보게 하시고, 믿고 나아가길.","a":false,"nick":""},{"n":"김지수","p":"*미기입","c":"원하는 목표를 이루게 되길. 하나님을 더 바라보게 되길. 기도를 더 많이하고 들어주시길.","a":false,"nick":""},{"n":"유진키티","p":"*미기입","c":"지금부터 1년 반 이내로 하고싶어 한 일(취업) 달성 주변에 좋은 사람들만 있길, 가족과 나의 건강","a":false,"nick":""},{"n":"윤갑식","p":"*미기입","c":"하나님께서 기뻐하시는 청년들 믿음을 더하시고 항상 동행해주셔서 하나님의 귀한 일꾼들 되게 하소서.","a":false,"nick":""},{"n":"이다현","p":"*미기입","c":"교생실습기간 체력적으로 너무 지치지 않도록.","a":false,"nick":""},{"n":"정하은","p":"*미기입","c":"원하는 회사에 취업할 수 있도록 지혜와 끈기를 주세요.","a":false,"nick":""},{"n":"천은경","p":"*미기입","c":"하나님 나라를 소망할 수 있기를. 사랑할 수 있는 마음을 주시기를.","a":false,"nick":""},{"n":"최승원","p":"*미기입","c":"주님, 인도해주신 사명에 따라 결식아동을 돕기 위해 시작한 저의 활동이 현실적인 그리고 금전적인 문제로 더 이상 이어나아가기 힘들어졌습니다. 부족하고 인도해주신 사명을 끝까지 완수하지 못했다는 죄책감과 좌절이 저를 묶어놓고 있습니다. 죄송하다고 말씀 드리고 싶었어요. 더 잘하고 싶었습니다. 그래도 저를 위로해주심에 정말 감사드립니다.","a":false,"nick":""}];

function hashStr(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}

function getYouthHpEntries() {
  const sheet = getOrCreateHoldPraySheet();
  const last = sheet.getLastRow();
  if (last < SCHEMA.HOLD_PRAY.dataStartRow) {
    // 시트 마이그레이션 전 fallback
    return HOLD_PRAY_ENTRIES.filter(function(e) {
      return e.p.indexOf('목양') === -1 && e.p.indexOf('초등') === -1;
    });
  }
  const col = getHoldPrayColumns_(sheet);
  return getHoldPrayRows_(sheet)
    .filter(function(r) {
      const parish = String(r[col.parish]).trim();
      if (!parish) return false;
      if (parish.indexOf('목양') !== -1) return false;
      if (parish.indexOf('초등') !== -1) return false;
      return String(r[col.content]).trim() !== ''; // 기도제목 없는 행 제외
    })
    .map(function(r) {
      const name = String(r[col.name]).trim();
      const isMugimyung = !name || name === '무기명';
      const anon = isMugimyung || r[col.anonymous] === true || String(r[col.anonymous]).toLowerCase() === 'true';
      return {
        n: isMugimyung ? '무기명' : name,
        p: String(r[col.parish]).trim(),
        c: String(r[col.content]).trim(),
        a: anon,
        nick: String(r[col.nickname]).trim()
      };
    });
}

// 시트의 빈 이름 셀을 "무기명"으로 일괄 수정 (1회 실행용)
function fixHoldPrayBlankNames() {
  const sheet = getOrCreateHoldPraySheet();
  const last = sheet.getLastRow();
  if (last < SCHEMA.HOLD_PRAY.dataStartRow) return '데이터 없음';
  const col = getHoldPrayColumns_(sheet);
  const values = getHoldPrayRows_(sheet);
  let fixed = 0;
  values.forEach(function(r, i) {
    const rowIndex = i + SCHEMA.HOLD_PRAY.dataStartRow;
    const name = String(r[col.name]).trim();
    if (!name || name === '무기명') {
      if (!name) {
        sheet.getRange(rowIndex, col.name + 1).setValue('무기명');
        fixed++;
      }
      // 익명 칸도 TRUE 보장
      if (r[col.anonymous] !== true && String(r[col.anonymous]).toLowerCase() !== 'true') {
        sheet.getRange(rowIndex, col.anonymous + 1).setValue(true);
      }
    }
  });
  return '완료: ' + fixed + '개 행 수정됨';
}

function getHoldPray(weekKey, nickname) {
  if (!weekKey) weekKey = 'w' + getCurrentWeek_();
  const entries = getYouthHpEntries();
  const hpRevision = String(hashStr(JSON.stringify(entries.map(function(e) {
    return [e.n, e.p, e.c, e.a === true, e.nick || ''];
  }))));
  const n = entries.length;
  const cards = [];
  const pickedEntries = [];
  const usedIdx = new Set();
  // Rendezvous hashing: 각 슬롯마다 entry별 점수를 매겨 가장 높은 항목 선택
  // n(행 수)에 의존하지 않으므로 시트에 행 추가/삭제 시 영향 최소화
  for (let i = 0; i < 3; i++) {
    const seed = weekKey + (nickname || '') + String(i);
    let bestScore = -1, bestIdx = 0;
    entries.forEach(function(e, idx) {
      if (usedIdx.has(idx)) return;
      const score = hashStr(seed + '\x00' + e.n + '\x00' + e.p);
      if (score > bestScore) { bestScore = score; bestIdx = idx; }
    });
    usedIdx.add(bestIdx);
    const entry = entries[bestIdx];
    pickedEntries.push(entry);
    cards.push({ cardIndex: i, parish: entry.p, content: entry.c, anon: entry.a });
  }
  // 3장 모두 익명이면 마지막 카드를 비익명으로 교체
  if (cards.every(function(c) { return c.anon; })) {
    for (let j = 0; j < n; j++) {
      if (!usedIdx.has(j) && !entries[j].a) {
        const entry = entries[j];
        pickedEntries[2] = entry;
        cards[2] = { cardIndex: 2, parish: entry.p, content: entry.c, anon: false };
        break;
      }
    }
  }

  // 이전에 정답을 맞춘 카드 목록 조회 (크로스-기기 동기화)
  // pickedEntries와 대조하여 현재 주차 엔트리와 이름이 일치하는 경우만 포함 (인덱스 불일치 방지)
  const correctMap = {};
  if (nickname) {
    const guessSheet = getOrCreateHPGuessesSheet();
    const last = guessSheet.getLastRow();
    if (last >= SCHEMA.HP_GUESSES.dataStartRow) {
      const guessCol = getHpGuessColumns_(guessSheet);
      const rows = getHpGuessRows_(guessSheet);
      rows.forEach(function(r) {
        if (String(r[guessCol.nickname]) !== nickname || String(r[guessCol.weekKey]) !== weekKey) return;
        const cardIdx = Number(r[guessCol.cardIndex]);
        const storedGuess = String(r[guessCol.guessedName]);
        const currentEntry = pickedEntries[cardIdx];
        if (currentEntry && !currentEntry.a && currentEntry.n === storedGuess) {
          correctMap[cardIdx] = storedGuess;
        }
      });
    }
  }

  // 이번 주 뽑기권 이미 수령 여부 확인 (w3/w6)
  let ticketAlreadyAwarded = false;
  let ticketCardIdx = -1;
  if (nickname && (weekKey === 'w3' || weekKey === 'w6')) {
    const source = 'hp_' + weekKey;
    ticketAlreadyAwarded = hasBonusTicketGrant_(nickname, source, weekKey);
    if (ticketAlreadyAwarded) {
      const guessSheet = getOrCreateHPGuessesSheet();
      const gLast = guessSheet.getLastRow();
      if (gLast >= SCHEMA.HP_GUESSES.dataStartRow) {
        const guessCol = getHpGuessColumns_(guessSheet);
        const gRows = getHpGuessRows_(guessSheet);
        const myRows = gRows.filter(function(r) {
          return String(r[guessCol.nickname]) === nickname && String(r[guessCol.weekKey]) === weekKey;
        });
        if (myRows.length > 0) {
          myRows.sort(function(a, b) { return new Date(a[guessCol.answeredAt]) - new Date(b[guessCol.answeredAt]); });
          ticketCardIdx = Number(myRows[0][guessCol.cardIndex]);
        }
      }
    }
  }

  // 힌트 답변 조회
  const hintReplies = {};
  if (nickname) {
    const inqSheet = getOrCreateInquirySheet();
    const inqLast = inqSheet.getLastRow();
    if (inqLast >= SCHEMA.INQUIRIES.dataStartRow) {
      const inqCol = getInquiryColumns_(inqSheet);
      const inqRows = getInquiryRows_(inqSheet);
      inqRows.forEach(function(r) {
        if (String(r[inqCol.nickname]) !== nickname) return;
        const reply = String(r[inqCol.reply] || '').trim();
        if (!reply) return;
        const match = String(r[inqCol.content]).match(/주차: ([^,]+), 카드: (\d+)번/);
        if (match && match[1] === weekKey) {
          hintReplies[Number(match[2]) - 1] = reply;
        }
      });
    }
  }

  return { ok: true, weekKey, hpRevision, cards, correctMap, ticketAlreadyAwarded, ticketCardIdx, hintReplies };
}

function submitHoldPrayGuess(weekKey, guess, nickname, cardIndex) {
  if (!weekKey || !guess) return { ok: false, error: 'missing params' };

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) { return { ok: false, error: '잠시 후 다시 시도해주세요.' }; }

  try {
  const entries = getYouthHpEntries();
  const n = entries.length;
  const ci = Number(cardIndex) || 0;
  const usedIdx = new Set();
  const allEntryIdxs = [];

  // getHoldPray와 동일하게 3장 전체 선택 (Rendezvous hashing)
  for (let i = 0; i < 3; i++) {
    const seed = weekKey + (nickname || '') + String(i);
    let bestScore = -1, bestIdx = 0;
    entries.forEach(function(e, idx) {
      if (usedIdx.has(idx)) return;
      const score = hashStr(seed + '\x00' + e.n + '\x00' + e.p);
      if (score > bestScore) { bestScore = score; bestIdx = idx; }
    });
    usedIdx.add(bestIdx);
    allEntryIdxs.push(bestIdx);
  }

  let entryIdx = allEntryIdxs[ci];

  // 3장 모두 익명이면 마지막 카드 교체 (getHoldPray와 동일)
  const allAnon = allEntryIdxs.every(function(i) { return entries[i].a; });
  if (allAnon && ci === 2) {
    for (let j = 0; j < n; j++) {
      if (!usedIdx.has(j) && !entries[j].a) {
        entryIdx = j;
        break;
      }
    }
  }

  const entry = entries[entryIdx];
  if (entry.a) return { ok: false, error: 'anon entry' };
  const correct = entry.n.replace(/\s/g, '').toLowerCase() === guess.trim().replace(/\s/g, '').toLowerCase();
  if (correct) {
    // 정답 기록 (크로스-기기 동기화용) — 중복 방지
    const guessSheet = getOrCreateHPGuessesSheet();
    const last = guessSheet.getLastRow();
    let alreadyRecorded = false;
    if (last >= SCHEMA.HP_GUESSES.dataStartRow) {
      const guessCol = getHpGuessColumns_(guessSheet);
      const rows = getHpGuessRows_(guessSheet);
      alreadyRecorded = rows.some(function(r) {
        return String(r[guessCol.nickname]) === nickname && String(r[guessCol.weekKey]) === weekKey && Number(r[guessCol.cardIndex]) === ci;
      });
    }
    if (!alreadyRecorded) {
      const answeredAt = new Date().toISOString();
      guessSheet.appendRow([nickname, weekKey, ci, guess.trim(), answeredAt]);
      Events_append_(EVENT_TYPES.HP_GUESSED, nickname, {
        timestamp: answeredAt,
        weekKey: weekKey,
        payload: {
          cardIndex: ci,
          guessedName: guess.trim(),
        },
        source: EVENT_SOURCES.WEB,
      });
    }
  }
  let ticketAwarded = false;
  if (correct && (weekKey === 'w3' || weekKey === 'w6')) {
    const source = 'hp_' + weekKey;
    const alreadyAwarded = hasBonusTicketGrant_(nickname, source, weekKey);
    if (!alreadyAwarded) {
      const awardedAt = new Date().toISOString();
      Events_append_(EVENT_TYPES.TICKET_GRANTED, nickname, {
        timestamp: awardedAt,
        amount: 1,
        weekKey: weekKey,
        payload: {
          reason: 'hp_correct',
          legacySource: source,
        },
        source: EVENT_SOURCES.WEB,
      });
      rebuildCollectionRow_(nickname);
      ticketAwarded = true;
    }
  }
  return { ok: true, correct, ticketAwarded };
  } finally {
    lock.releaseLock();
  }
}

// ── 탭 설정 ──────────────────────────────────────
// TabSettings 시트 구조:
// A열: tab_key (holdpray / secret / chat / qt)
// B열: label   (Hold & Pray / B.B.B 미션 / 채팅방 / Q.T. 말씀 묵상)
// C열: enabled (TRUE/FALSE)
//
// BBBSettings 시트 구조:
// A열: key (careBuddy / m1 / m2 / m3 / secretBuddy / msgOpen)
// B열: open (TRUE/FALSE)
// C열: text (Coming Soon 표시 문구)

var BBB_SECTIONS_DEFAULT = {
  careBuddy:   { open: false, text: 'Coming Soon!\n6/20 Open' },
  m1:          { open: false, text: 'Coming Soon!\n6/14 Open' },
  m2:          { open: false, text: 'Coming Soon!\n6/20 Open' },
  m3:          { open: false, text: 'Coming Soon!\n6/21 Open' },
  secretBuddy: { open: false, text: 'Coming Soon!\n6/14 Open' },
  msgOpen:     { open: false },
};

function getTabSettingsDefaultRows_() {
  var holdprayVal = getAppSetting_(APP_SETTING_KEYS.HOLD_PRAY_OPEN, true) === true;
  var secretVal   = getAppSetting_(APP_SETTING_KEYS.SECRET_OPEN, true) === true;
  var chatVal     = getAppSetting_(APP_SETTING_KEYS.CHAT_OPEN, false) === true;
  return [
    ['holdpray', 'Hold & Pray', holdprayVal],
    ['secret',   'B.B.B 미션',   secretVal],
    ['chat',     '채팅방',        chatVal],
    ['qt',       'Q.T. 말씀 묵상', true],
  ];
}

function ensureTabSettingsDefaultRows_(sheet) {
  sheet.getRange(SCHEMA.TAB_SETTINGS.headerRow, 1, 1, 3).setValues([getSchemaHeaders_(SCHEMA.TAB_SETTINGS)]);
  const tabCol = getTabSettingsColumns_(sheet);
  const rows = getTabSettingsRows_(sheet);
  const existing = {};
  rows.forEach(function(row, index) {
    const key = String(row[tabCol.key] || '').trim();
    if (key) existing[key] = { rowIndex: index + SCHEMA.TAB_SETTINGS.dataStartRow, row: row };
  });

  const rowsToAppend = [];
  getTabSettingsDefaultRows_().forEach(function(defaultRow) {
    const key = defaultRow[0];
    if (existing[key]) {
      if (String(existing[key].row[tabCol.label] || '') !== defaultRow[1]) {
        sheet.getRange(existing[key].rowIndex, tabCol.label + 1).setValue(defaultRow[1]);
      }
      return;
    }
    rowsToAppend.push(defaultRow);
  });

  if (rowsToAppend.length) {
    const startRow = Math.max(sheet.getLastRow() + 1, SCHEMA.TAB_SETTINGS.dataStartRow);
    sheet.getRange(startRow, 1, rowsToAppend.length, 3).setValues(rowsToAppend);
  }
}

function getOrCreateTabSettingsSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.TAB_SETTINGS);
  if (sheet) {
    ensureTabSettingsDefaultRows_(sheet);
    return sheet;
  }

  sheet = ss.insertSheet(SHEET_NAMES.TAB_SETTINGS);
  sheet.getRange(SCHEMA.TAB_SETTINGS.headerRow, 1, 1, 3).setValues([getSchemaHeaders_(SCHEMA.TAB_SETTINGS)]);
  sheet.setFrozenRows(1);

  sheet.getRange(SCHEMA.TAB_SETTINGS.dataStartRow, 1, 4, 3).setValues(getTabSettingsDefaultRows_());
  return sheet;
}

function getOrCreateBBBSettingsSheet() {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(SHEET_NAMES.BBB_SETTINGS);
  if (sheet) return sheet;

  sheet = ss.insertSheet(SHEET_NAMES.BBB_SETTINGS);
  sheet.getRange(SCHEMA.BBB_SETTINGS.headerRow, 1, 1, 3).setValues([getSchemaHeaders_(SCHEMA.BBB_SETTINGS)]);
  sheet.setFrozenRows(1);

  const rows = Object.keys(BBB_SECTIONS_DEFAULT).map(function(key) {
    const def = BBB_SECTIONS_DEFAULT[key];
    const openValue = key === 'msgOpen'
      ? getAppSetting_(APP_SETTING_KEYS.BBB_MESSAGE_OPEN, def.open === true) === true
      : def.open === true;
    return [key, openValue, def.text || ''];
  });
  sheet.getRange(SCHEMA.BBB_SETTINGS.dataStartRow, 1, rows.length, 3).setValues(rows);
  return sheet;
}

function isBBBMessageOpen() {
  try {
    const bbbSheet = getOrCreateBBBSettingsSheet();
    const last = bbbSheet.getLastRow();
    if (last >= SCHEMA.BBB_SETTINGS.dataStartRow) {
      const bbbCol = getBbbSettingsColumns_(bbbSheet);
      const rows = getBbbSettingsRows_(bbbSheet);
      for (var i = 0; i < rows.length; i++) {
        if (String(rows[i][bbbCol.key]).trim() === 'msgOpen') return rows[i][bbbCol.open] === true;
      }
    }
  } catch(e) {}

  try {
    const appSettingValue = getAppSetting_(APP_SETTING_KEYS.BBB_MESSAGE_OPEN, null);
    if (appSettingValue !== null && appSettingValue !== undefined) return appSettingValue === true;
    return false;
  } catch(e) {
    return false;
  }
}

function getBBBSectionSettingsMap_() {
  const sections = JSON.parse(JSON.stringify(BBB_SECTIONS_DEFAULT));
  const bbbSheet = getOrCreateBBBSettingsSheet();
  const bbbLastRow = bbbSheet.getLastRow();
  if (bbbLastRow >= SCHEMA.BBB_SETTINGS.dataStartRow) {
    const bbbCol = getBbbSettingsColumns_(bbbSheet);
    getBbbSettingsRows_(bbbSheet).forEach(function(r) {
      const key = String(r[bbbCol.key]).trim();
      if (!key || !Object.prototype.hasOwnProperty.call(sections, key)) return;
      sections[key] = { open: r[bbbCol.open] === true, text: String(r[bbbCol.text] || '') };
      if (!sections[key].text) delete sections[key].text;
    });
  }
  return sections;
}

function getTabSettings() {
  // TabSettings 시트에서 holdpray/secret/chat/qt 읽기
  const tabSheet = getOrCreateTabSettingsSheet();
  const tabMap = { holdpray: true, secret: true, chat: false, qt: true };
  if (tabSheet && tabSheet.getLastRow() >= SCHEMA.TAB_SETTINGS.dataStartRow) {
    const tabCol = getTabSettingsColumns_(tabSheet);
    getTabSettingsRows_(tabSheet).forEach(function(r) {
      const key = String(r[tabCol.key]).trim();
      if (Object.prototype.hasOwnProperty.call(tabMap, key)) tabMap[key] = r[tabCol.enabled] === true;
    });
  } else {
    const hpSetting = getAppSetting_(APP_SETTING_KEYS.HOLD_PRAY_OPEN, null);
    const secretSetting = getAppSetting_(APP_SETTING_KEYS.SECRET_OPEN, null);
    const chatSetting = getAppSetting_(APP_SETTING_KEYS.CHAT_OPEN, null);
    if (hpSetting !== null && hpSetting !== undefined) tabMap.holdpray = hpSetting === true;
    if (secretSetting !== null && secretSetting !== undefined) tabMap.secret = secretSetting === true;
    if (chatSetting !== null && chatSetting !== undefined) tabMap.chat = chatSetting === true;
  }

  // BBBSettings 시트에서 현장미션 섹션 오픈 설정 읽기
  const bbbSections = getBBBSectionSettingsMap_();

  return {
    ok:          true,
    prayer:      tabMap.holdpray, // API 키는 'prayer' 유지 (index.html/admin.html 호환)
    secret:      tabMap.secret,
    chat:        tabMap.chat,
    qt:          tabMap.qt,
    bbbSections: bbbSections
  };
}

function setTabSettings(body) {
  if (!isAdminAuthorized_(body.adminPw)) return { error: 'unauthorized' };

  // TabSettings 시트 업데이트
  const tabSheet = getOrCreateTabSettingsSheet();
  const tabLastRow = tabSheet.getLastRow();
  if (tabLastRow >= SCHEMA.TAB_SETTINGS.dataStartRow) {
    const tabCol = getTabSettingsColumns_(tabSheet);
    const tabRange = tabSheet.getRange(SCHEMA.TAB_SETTINGS.dataStartRow, 1, tabLastRow - SCHEMA.TAB_SETTINGS.dataStartRow + 1, 3);
    const tabRows = tabRange.getValues();
    tabRows.forEach(function(r) {
      const key = String(r[tabCol.key]).trim();
      if (key === 'holdpray' && body.prayer !== undefined) r[tabCol.enabled] = body.prayer !== false;
      if (key === 'secret'   && body.secret !== undefined) r[tabCol.enabled] = body.secret  !== false;
      if (key === 'chat'     && body.chat   !== undefined) r[tabCol.enabled] = body.chat    !== false;
      if (key === 'qt'       && body.qt     !== undefined) r[tabCol.enabled] = body.qt      !== false;
    });
    tabRange.setValues(tabRows);
  }

  // BBBSettings 시트 업데이트
  if (body.bbbSections) {
    const bbbSheet = getOrCreateBBBSettingsSheet();
    const bbbLastRow = bbbSheet.getLastRow();
    if (bbbLastRow >= SCHEMA.BBB_SETTINGS.dataStartRow) {
      const bbbCol = getBbbSettingsColumns_(bbbSheet);
      const bbbRange = bbbSheet.getRange(SCHEMA.BBB_SETTINGS.dataStartRow, 1, bbbLastRow - SCHEMA.BBB_SETTINGS.dataStartRow + 1, 3);
      const bbbRows = bbbRange.getValues();
      bbbRows.forEach(function(r) {
        const key = String(r[bbbCol.key]).trim();
        if (!key || !Object.prototype.hasOwnProperty.call(body.bbbSections, key)) return;
        const sec = body.bbbSections[key];
        r[bbbCol.open] = sec.open === true;
        if (sec.text !== undefined) r[bbbCol.text] = sec.text;
      });
      bbbRange.setValues(bbbRows);
    }
  }
  clearConfigCaches_();
  return { ok: true };
}

function getAppOpenDate() {
  const value = getAppSetting_(APP_SETTING_KEYS.APP_OPEN_DATE, '');
  return value ? eventDateKey_(value) : '';
}

// ── 유저 인증 ─────────────────────────────────────
function registerUser(body) {
  const sheet    = getUsersSheet_();
  const col      = getUserColumns_(sheet);
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const name     = String(body.name     || '').trim();
  const parish   = String(body.parish   || '').trim();

  if (!nickname || !password || !name || !parish) return { error: 'missing_fields' };

  const data = getUserRows_(sheet);
  for (let i = 0; i < data.length; i++) {
    if (String(data[i][col.nickname]).trim() === nickname) return { error: 'duplicate' };
  }

  sheet.appendRow([nickname, '', name, parish, new Date(), '', '', '', '']);
  const rowIndex = sheet.getLastRow();
  const pwCell = sheet.getRange(rowIndex, col.password + 1);
  pwCell.setNumberFormat('@');
  pwCell.setValue(password);
  const sessionToken = issueSessionToken_(sheet, rowIndex);
  return { ok: true, sessionToken };
}

function loginUser(body) {
  const sheet    = getUsersSheet_();
  const schema   = SCHEMA.USERS;
  const col      = getUserColumns_(sheet);
  const nickname = String(body.nickname || '').trim();
  const password = String(body.password || '').trim();
  const sessionToken = String(body.sessionToken || '').trim();

  const data = getUserRows_(sheet);
  for (let i = 0; i < data.length; i++) {
    if (String(data[i][col.nickname]).trim() === nickname) {
      const rowIndex = i + schema.dataStartRow;
      const passwordOk = password && String(data[i][col.password]).trim() === password;
      const sessionOk = !password && sessionToken && verifySession(nickname, sessionToken);
      if (passwordOk || sessionOk) {
        const token = passwordOk ? issueSessionToken_(sheet, rowIndex) : sessionToken;
        if (sessionOk) touchSessionToken_(sheet, rowIndex);
        return {
          ok:          true,
          parish:      data[i][col.parish],
          isStaff:     data[i][col.isStaff] === true,
          isDev:       data[i][col.isDev] === true,
          appOpenDate: getAppOpenDate(),
          sessionToken: token
        };
      }
      return { error: 'wrong_password' };
    }
  }
  return { error: 'not_found' };
}

function resetPassword(body) {
  const sheet       = getUsersSheet_();
  const schema      = SCHEMA.USERS;
  const col         = getUserColumns_(sheet);
  const nickname    = String(body.nickname    || '').trim();
  const name        = String(body.name        || '').trim();
  const parish      = String(body.parish      || '').trim();
  const newPassword = String(body.newPassword || '').trim();

  if (!newPassword || newPassword.length < 4) return { error: 'invalid_password' };

  const data = getUserRows_(sheet);

  // 닉네임이 명시된 경우: 이름+교구+닉네임 정확히 일치하는 계정 변경
  if (nickname) {
    for (let i = 0; i < data.length; i++) {
      const rowIndex = i + schema.dataStartRow;
      if (String(data[i][col.nickname]).trim() === nickname &&
          String(data[i][col.name]).trim() === name &&
          String(data[i][col.parish]).trim() === parish) {
        const cell = sheet.getRange(rowIndex, col.password + 1);
        cell.setNumberFormat('@');
        cell.setValue(newPassword);
        clearSessionToken_(sheet, rowIndex);
        return { ok: true };
      }
    }
    return { error: 'not_found' };
  }

  // 닉네임 없이 이름+교구로 검색
  const matches = [];
  for (let i = 0; i < data.length; i++) {
    if (String(data[i][col.name]).trim() === name &&
        String(data[i][col.parish]).trim() === parish) {
      matches.push({ row: i + schema.dataStartRow, nickname: String(data[i][col.nickname]).trim() });
    }
  }

  if (matches.length === 0) return { error: 'not_found' };

  // 동명이인: 닉네임 선택 요청
  if (matches.length > 1) {
    return { duplicates: matches.map(m => m.nickname) };
  }

  // 1명: 바로 변경
  const cell = sheet.getRange(matches[0].row, col.password + 1);
  cell.setNumberFormat('@');
  cell.setValue(newPassword);
  clearSessionToken_(sheet, matches[0].row);
  return { ok: true };
}

