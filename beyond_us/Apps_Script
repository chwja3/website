function getPasswordPepper_() {
  const props = PropertiesService.getScriptProperties();
  let pepper = props.getProperty(SCRIPT_PROPERTY_KEYS.PASSWORD_PEPPER);
  if (!pepper) {
    pepper = Utilities.getUuid().replace(/-/g, '') + Utilities.getUuid().replace(/-/g, '');
    props.setProperty(SCRIPT_PROPERTY_KEYS.PASSWORD_PEPPER, pepper);
  }
  return pepper;
}

function makePasswordSalt_() {
  return Utilities.getUuid().replace(/-/g, '') + Utilities.getUuid().replace(/-/g, '');
}

function computePasswordHash_(password, salt, iterations) {
  const pepper = getPasswordPepper_();
  let digest = String(salt || '') + '\n' + String(password || '') + '\n' + pepper;
  for (let i = 0; i < iterations; i++) {
    digest = Utilities.base64Encode(Utilities.computeDigest(
      Utilities.DigestAlgorithm.SHA_256,
      digest,
      Utilities.Charset.UTF_8
    ));
  }
  return digest;
}

function makePasswordHash_(password) {
  const salt = makePasswordSalt_();
  const hash = computePasswordHash_(password, salt, PASSWORD_HASH_ITERATIONS);
  return [PASSWORD_HASH_VERSION, PASSWORD_HASH_ITERATIONS, salt, hash].join('$');
}

function parsePasswordHash_(stored) {
  const parts = String(stored || '').trim().split('$');
  if (parts.length !== 4 || parts[0] !== PASSWORD_HASH_VERSION) return null;
  const iterations = Number(parts[1]) || 0;
  if (!iterations || !parts[2] || !parts[3]) return null;
  return { iterations: iterations, salt: parts[2], hash: parts[3] };
}

function isPasswordHash_(stored) {
  return !!parsePasswordHash_(stored);
}

function secureCompare_(a, b) {
  const left = String(a || '');
  const right = String(b || '');
  let diff = left.length ^ right.length;
  const max = Math.max(left.length, right.length);
  for (let i = 0; i < max; i++) {
    diff |= (left.charCodeAt(i) || 0) ^ (right.charCodeAt(i) || 0);
  }
  return diff === 0;
}

function verifyStoredPassword_(stored, password) {
  const cleanPassword = String(password || '').trim();
  if (!cleanPassword) return false;
  const parsed = parsePasswordHash_(stored);
  if (!parsed) return String(stored || '').trim() === cleanPassword;
  return secureCompare_(computePasswordHash_(cleanPassword, parsed.salt, parsed.iterations), parsed.hash);
}

function setUserPassword_(sheet, rowIndex, password) {
  const col = getUserColumns_(sheet);
  const cell = sheet.getRange(rowIndex, col.password + 1);
  cell.setNumberFormat('@');
