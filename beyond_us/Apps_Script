function revokeInvalidBBBPhotoRewardsApply() {
  const audit = auditBBBPhotoRewardSecurity_();
  const invalidRewards = audit.invalidRewards || [];
  if (!invalidRewards.length) {
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', {
      ok: true,
      dryRun: false,
      revoked: 0,
      invalidCount: 0,
      affectedUsers: [],
    });
  }

  const lock = LockService.getScriptLock();
  try { lock.waitLock(10000); } catch(e) {
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', { ok: false, error: 'ņ×Āņŗ£ Ēøä ļŗżņŗ£ ņŗ£ļÅäĒĢ┤ņŻ╝ņäĖņÜö.' });
  }

  try {
    const now = new Date().toISOString();
    const affectedUsers = {};
    const revoked = [];
    invalidRewards.forEach(function(item) {
      const amount = Math.max(1, Math.abs(Number(item.amount) || 1));
      const revokeType = item.rewardType === EVENT_TYPES.SPECIAL_PACK_GRANTED
        ? EVENT_TYPES.SPECIAL_PACK_GRANTED
        : EVENT_TYPES.TICKET_GRANTED;
      const event = Events_append_(revokeType, item.userId, {
        timestamp: now,
        amount: -amount,
        weekKey: '',
        payload: {
          reason: 'bbb_security_revoke',
          revokedEventId: item.eventId,
          revokedRewardType: item.rewardType || EVENT_TYPES.TICKET_GRANTED,
          revokedLegacySource: item.legacySource,
          missionType: item.missionType,
          validationError: item.error,
        },
        source: EVENT_SOURCES.ADMIN,
      });
      affectedUsers[item.userId] = true;
      revoked.push({ revokedEventId: item.eventId, revokeEventId: event.event.eventId, userId: item.userId, amount: amount, rewardType: revokeType });
    });
    Object.keys(affectedUsers).forEach(function(userId) {
      rebuildCollectionRow_(userId);
    });
    return logJsonResult_('revokeInvalidBBBPhotoRewardsApply result', {
      ok: true,
      dryRun: false,
      revoked: revoked.length,
      affectedUsers: Object.keys(affectedUsers),
      revokedEvents: revoked,
    });
  } finally {
    lock.releaseLock();
  }
}

function getBBBPhotoRewardEventKey_(userId, legacySource) {
  return String(userId || '').trim() + '::' + String(legacySource || '').trim();
}

function getBBBPhotoRewardEventMap_() {
  const map = {};
  const events = Events_readAll_();
  events.forEach(function(event) {
    if (!isBBBPhotoRewardEvent_(event)) return;
    if (hasBBBRewardRevokeEvent_(event.eventId, events)) return;
    const legacySource = String((event.payload && event.payload.legacySource) || '').trim();
    const key = getBBBPhotoRewardEventKey_(event.userId, legacySource);
    if (!map[key]) map[key] = event;
  });
  return map;
}

function getBBBPhotoApprovalValue_(row, col, key) {
  return col[key] === undefined ? '' : row[col[key]];
}

function setBBBPhotoApproval_(sheet, rowIndex, col, status, approvedAt, approvedBy, rewardEventId) {
  sheet.getRange(rowIndex, col.approvalStatus + 1).setValue(status || '');
  sheet.getRange(rowIndex, col.approvedAt + 1).setValue(approvedAt || '');
  sheet.getRange(rowIndex, col.approvedBy + 1).setValue(approvedBy || '');
  sheet.getRange(rowIndex, col.rewardEventId + 1).setValue(rewardEventId || '');
}

function getBBBPhotoApprovalStatus_(row, col, rewardEvent) {
  if (rewardEvent) return 'approved';
  const status = String(getBBBPhotoApprovalValue_(row, col, 'approvalStatus') || '').trim();
  if (status === 'approved') return 'approved';
  if (status === 'rejected') return 'rejected';
  return 'pending';
}

function hasActiveBBBPhotoReward_(userId, legacySource) {
  return !!getBBBPhotoRewardEventMap_()[getBBBPhotoRewardEventKey_(userId, legacySource)];
}

function grantBBBSpecialPack_(userId, legacySource, missionType, options) {
  const opts = options || {};
  const payload = {
    reason: opts.reason || 'bbb_mission',
    legacySource: legacySource,
    missionType: missionType,
    reward: 'special_pack',
    packType: 'special',
  };
  if (opts.approvedBy) payload.approvedBy = opts.approvedBy;
  return Events_append_(EVENT_TYPES.SPECIAL_PACK_GRANTED, userId, {
    timestamp: opts.timestamp || new Date().toISOString(),
    amount: 1,
    weekKey: '',
    payload: payload,
    source: opts.source || EVENT_SOURCES.WEB,
  });
}

