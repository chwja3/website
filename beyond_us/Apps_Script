// ── 미션 config 읽기/쓰기 ─────────────────────────
function getMissionConfig(week) {
  if (week < 1 || week > 6) return { error: 'invalid_week' };
  const sheet    = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const startRow = (week - 1) * 8 + 5;
  const title     = sheet.getRange(startRow, 2).getValue();
  const threshold = Number(sheet.getRange(startRow, 3).getValue()) || 6;
  const rawItems  = sheet.getRange(startRow + 1, 1, 6, 3).getValues();
  const items = rawItems.map(([item, score, cat]) => ({ item: String(item || ''), score: Number(score) || 1, cat: String(cat || 'L') }));
  return { ok: true, week, title, threshold, items };
}

function setMissionConfig(body) {
  const week = Number(body.week);
  if (!week || week < 1 || week > 6) return { error: 'invalid_week' };
  const sheet    = getSpreadsheet().getSheetByName(CONFIG_SHEET_NAME);
  const startRow = (week - 1) * 8 + 5;
  sheet.getRange(startRow, 2).setValue(String(body.title || ''));
  sheet.getRange(startRow, 3).setValue(Number(body.threshold) || 6);
  const items = Array.isArray(body.items) ? body.items : [];
  for (let i = 0; i < 6; i++) {
    const it = items[i] || {};
    if (!String(it.item || '').trim()) continue; // 빈 항목은 기존 값 유지
    sheet.getRange(startRow + 1 + i, 1).setValue(String(it.item));
    sheet.getRange(startRow + 1 + i, 2).setValue(Number(it.score) || 1);
    sheet.getRange(startRow + 1 + i, 3).setValue(String(it.cat || 'L'));
  }
  return { ok: true };
}

