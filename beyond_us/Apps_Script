  const rows = getBbbPhotoRows_(photoSheet);
  for (let i = 0; i < rows.length; i++) {
    const mt = String(rows[i][photoCol.missionType] || 'm1');
    if (String(rows[i][photoCol.userId]) === userId && mt === missionType) {
      photoSheet.deleteRow(i + SCHEMA.BBB_PHOTOS.dataStartRow);
      break;
    }
